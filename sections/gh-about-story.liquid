{%- render 'gh-tokens' -%}

<section class="gh-about-story-{{ section.id }}" style="background: {{ section.settings.bg_color | default: '#FDF8F2' }};">
  <div class="gh-about-shell">
    <div class="gh-about-grid">
      <div class="gh-about-image-wrap">
        {% if section.settings.image %}
          {{ section.settings.image | image_url: width: 1600 | image_tag: loading: 'lazy', alt: section.settings.image_alt }}
        {% endif %}
        {% if section.settings.show_corner_accent %}
          <span class="gh-about-corner"></span>
        {% endif %}
      </div>

      <div class="gh-about-content-wrap">
        <p class="gh-eyebrow">{{ section.settings.eyebrow | default: 'Our story' }}</p>
        <h2>{{ section.settings.heading | default: 'Five Generations. One Passion.' }}</h2>
        <p>{{ section.settings.body_1 | default: "Charlie's grandfather (Carmine) amongst his farming activities he also grew grapes and produced wine for the local community. This was the beginning of Charlie's involvement in the wine industry." }}</p>
        <p>{{ section.settings.body_2 | default: 'Recalling the early age of 6 when his grandfather asked him to wash his feet thoroughly so that he could place him in the large wooden vats of grapes to crush with his feet.' }}</p>
        <p>{{ section.settings.body_3 | default: 'From those early days to today, the family tradition continues with the same passion for winemaking, the land and the Barossa Valley.' }}</p>
        {% if section.settings.btn_label != blank and section.settings.btn_url != blank %}
          <a href="{{ section.settings.btn_url }}" class="gh-btn">{{ section.settings.btn_label }}</a>
        {% endif %}

        {% if section.settings.show_quote_card %}
          <div class="gh-quote-card" style="background: {{ section.settings.quote_bg_color | default: '#F5EFE3' }};">
            <p class="gh-quote-mark" style="color: {{ section.settings.quote_accent_color | default: '#B8913A' }};">"</p>
            <p class="gh-quote-text">{{ section.settings.quote | default: 'When making wine my actions are controlled by my perfectionist nature to everything I do in life, and most importantly how well can I serve the consumer.' }}</p>
            <p class="gh-quote-name" style="color: {{ section.settings.quote_accent_color | default: '#B8913A' }};">{{ section.settings.quote_name | default: 'Charlie Scalzi' }}</p>
            <p class="gh-quote-role">{{ section.settings.quote_role | default: 'Chief Winemaker' }}</p>
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</section>

<style>
  .gh-about-story-{{ section.id }} {
    padding: 96px 40px;
  }
  .gh-about-story-{{ section.id }} .gh-about-shell {
    width: min(1280px, 100%);
    margin: 0 auto;
  }
  .gh-about-story-{{ section.id }} .gh-about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: center;
  }
  .gh-about-story-{{ section.id }} .gh-about-image-wrap {
    height: 520px;
    border-radius: 3px;
    overflow: hidden;
    position: relative;
    background: var(--gh-cream);
  }
  .gh-about-story-{{ section.id }} .gh-about-image-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .gh-about-story-{{ section.id }} .gh-about-corner {
    position: absolute;
    width: 140px;
    height: 140px;
    border: 1.5px solid {{ section.settings.accent_color | default: '#B8913A' }};
    border-radius: 3px;
    opacity: 0.35;
    bottom: -20px;
    right: -20px;
  }
  .gh-about-story-{{ section.id }} .gh-eyebrow {
    margin: 0 0 8px;
    font: 600 10px/1.3 'Inter', sans-serif;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--gh-gold);
  }
  .gh-about-story-{{ section.id }} h2 {
    margin: 0 0 16px;
    font: 400 42px/1.05 'EB Garamond', Georgia, serif;
    color: var(--gh-vine);
  }
  .gh-about-story-{{ section.id }} p {
    color: var(--gh-muted);
  }
  .gh-about-story-{{ section.id }} .gh-btn {
    display: inline-block;
    margin-top: 10px;
    border: 1px solid var(--gh-gold);
    color: var(--gh-gold);
    text-decoration: none;
    padding: 10px 14px;
  }
  .gh-about-story-{{ section.id }} .gh-quote-card {
    margin-top: 24px;
    border-radius: 4px;
    padding: 32px;
  }
  .gh-about-story-{{ section.id }} .gh-quote-mark {
    margin: 0;
    font: 400 64px/1 'EB Garamond', Georgia, serif;
  }
  .gh-about-story-{{ section.id }} .gh-quote-text {
    font: italic 400 19px/1.6 'EB Garamond', Georgia, serif;
    color: var(--gh-vine);
  }
  .gh-about-story-{{ section.id }} .gh-quote-name {
    margin: 16px 0 2px;
    font: italic 400 17px/1.2 'EB Garamond', Georgia, serif;
  }
  .gh-about-story-{{ section.id }} .gh-quote-role {
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 10px;
  }
  @media (max-width: 768px) {
    .gh-about-story-{{ section.id }} {
      padding: 56px 20px;
    }
    .gh-about-story-{{ section.id }} .gh-about-grid {
      grid-template-columns: 1fr;
    }
    .gh-about-story-{{ section.id }} .gh-about-image-wrap {
      height: 420px;
    }
  }
</style>

{% schema %}
{
  "name": "GH — About Story",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Story image" },
    { "type": "text", "id": "image_alt", "label": "Image alt text", "default": "Charlie Scalzi in the vineyard at God's Hill" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Our story" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Five Generations. One Passion." },
    { "type": "textarea", "id": "body_1", "label": "First paragraph", "default": "Charlie's grandfather (Carmine) amongst his farming activities he also grew grapes and produced wine for the local community. This was the beginning of Charlie's involvement in the wine industry." },
    { "type": "textarea", "id": "body_2", "label": "Second paragraph", "default": "Recalling the early age of 6 when his grandfather asked him to wash his feet thoroughly so that he could place him in the large wooden vats of grapes to crush with his feet." },
    { "type": "textarea", "id": "body_3", "label": "Third paragraph", "default": "From those early days to today, the family tradition continues with the same passion for winemaking, the land and the Barossa Valley." },
    { "type": "text", "id": "btn_label", "label": "CTA button label", "default": "Discover our wines" },
    { "type": "url", "id": "btn_url", "label": "CTA button URL" },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#FDF8F2" },
    { "type": "checkbox", "id": "show_corner_accent", "label": "Show decorative corner accent", "default": true },
    { "type": "color", "id": "accent_color", "label": "Accent colour", "default": "#B8913A" },
    { "type": "checkbox", "id": "show_quote_card", "label": "Show quote card", "default": true },
    { "type": "textarea", "id": "quote", "label": "Quote text", "default": "When making wine my actions are controlled by my perfectionist nature to everything I do in life, and most importantly how well can I serve the consumer." },
    { "type": "text", "id": "quote_name", "label": "Person name", "default": "Charlie Scalzi" },
    { "type": "text", "id": "quote_role", "label": "Person role", "default": "Chief Winemaker" },
    { "type": "color", "id": "quote_bg_color", "label": "Quote card background", "default": "#F5EFE3" },
    { "type": "color", "id": "quote_accent_color", "label": "Quote accent colour", "default": "#B8913A" }
  ],
  "presets": [{ "name": "GH — About Story" }]
}
{% endschema %}
