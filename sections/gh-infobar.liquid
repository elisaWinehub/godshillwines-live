{% render 'gh-tokens' %}
{% assign bg_color = section.settings.bg_color | default: '#000000' %}
{% assign text_color = section.settings.text_color | default: '#F5EFE3' %}
{% assign accent = section.settings.accent_color | default: '#B8913A' %}

<section class="gh-infobar gh-infobar-{{ section.id }}" {{ section.shopify_attributes }}>
  <div class="gh-infobar__inner">
    {% for block in section.blocks %}
      <div class="gh-infobar__item" {{ block.shopify_attributes }}>
        <span class="gh-infobar__icon" aria-hidden="true">
          {% case block.settings.icon %}
            {% when 'pin' %}
              <svg viewBox="0 0 24 24"><path d="M12 22s-7-6.1-7-12a7 7 0 1 1 14 0c0 5.9-7 12-7 12Zm0-9a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z"/></svg>
            {% when 'phone' %}
              <svg viewBox="0 0 24 24"><path d="M6.7 10.8A15.4 15.4 0 0 0 13.2 17l2.1-2.1a1 1 0 0 1 1-.2c1 .3 2.1.4 3.2.4a1 1 0 0 1 1 1V20a1 1 0 0 1-1 1C11.6 21 3 12.4 3 2.5a1 1 0 0 1 1-1H7.7a1 1 0 0 1 1 1c0 1.1.1 2.2.4 3.2a1 1 0 0 1-.2 1L6.7 8.8Z"/></svg>
            {% when 'car' %}
              <svg viewBox="0 0 24 24"><path d="M5 13h14l-1.2-4a2 2 0 0 0-1.9-1.4H8.1A2 2 0 0 0 6.2 9L5 13Zm14 1H5a2 2 0 0 0-2 2v2h2a2 2 0 1 0 4 0h6a2 2 0 1 0 4 0h2v-2a2 2 0 0 0-2-2Z"/></svg>
            {% when 'calendar' %}
              <svg viewBox="0 0 24 24"><path d="M7 2v2H5a2 2 0 0 0-2 2v13a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2h-2V2h-2v2H9V2H7Zm12 7H5v10h14V9Z"/></svg>
            {% when 'mail' %}
              <svg viewBox="0 0 24 24"><path d="M3 6h18a1 1 0 0 1 1 1v10a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V7a1 1 0 0 1 1-1Zm9 6 8-4H4l8 4Z"/></svg>
            {% else %}
              <svg viewBox="0 0 24 24"><path d="M12 6v6l4 2m5-2a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>
          {% endcase %}
        </span>
        <p>{{ block.settings.text }}</p>
      </div>
    {% endfor %}
  </div>
</section>

<style>
  .gh-infobar-{{ section.id }} {
    background: {{ bg_color }};
    border-top: 0.5px solid rgba(184, 145, 58, 0.22);
  }
  .gh-infobar-{{ section.id }} .gh-infobar__inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 16px 40px;
    display: flex;
  }
  .gh-infobar-{{ section.id }} .gh-infobar__item {
    flex: 1;
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 0 16px;
  }
  .gh-infobar-{{ section.id }} .gh-infobar__item + .gh-infobar__item {
    border-left: 0.5px solid rgba(245, 239, 227, 0.12);
  }
  .gh-infobar-{{ section.id }} .gh-infobar__icon {
    width: 16px;
    height: 16px;
    color: {{ accent }};
    display: inline-flex;
  }
  .gh-infobar-{{ section.id }} .gh-infobar__icon svg {
    width: 16px;
    height: 16px;
    fill: currentColor;
  }
  .gh-infobar-{{ section.id }} p {
    margin: 0;
    color: color-mix(in srgb, {{ text_color }} 55%, transparent);
    font: 400 12px/1.4 'Inter', sans-serif;
  }
  @media (max-width: 900px) {
    .gh-infobar-{{ section.id }} .gh-infobar__inner {
      padding: 16px 20px;
      flex-direction: column;
      gap: 10px;
    }
    .gh-infobar-{{ section.id }} .gh-infobar__item {
      width: 100%;
      padding: 0;
    }
    .gh-infobar-{{ section.id }} .gh-infobar__item + .gh-infobar__item {
      border-left: 0;
      border-top: 0.5px solid rgba(245, 239, 227, 0.12);
      padding-top: 10px;
    }
  }
</style>

{% schema %}
{
  "name": "GH — Infobar",
  "max_blocks": 4,
  "settings": [
    { "type": "color", "id": "bg_color", "label": "Background colour", "default": "#000000" },
    { "type": "color", "id": "text_color", "label": "Text colour", "default": "#F5EFE3" },
    { "type": "color", "id": "accent_color", "label": "Icon accent colour", "default": "#B8913A" }
  ],
  "blocks": [
    {
      "type": "info_item",
      "name": "Info item",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "default": "clock",
          "options": [
            { "value": "clock", "label": "Clock" },
            { "value": "pin", "label": "Pin" },
            { "value": "phone", "label": "Phone" },
            { "value": "car", "label": "Car" },
            { "value": "calendar", "label": "Calendar" },
            { "value": "mail", "label": "Mail" }
          ]
        },
        { "type": "text", "id": "text", "label": "Info text", "default": "Cellar door: Thu – Sun, 11am – 5pm" }
      ]
    }
  ],
  "presets": [
    {
      "name": "GH — Infobar",
      "blocks": [
        { "type": "info_item", "settings": { "icon": "clock", "text": "Cellar door: Thu – Sun, 11am – 5pm" } },
        { "type": "info_item", "settings": { "icon": "pin", "text": "34 Moppert Rd, Lyndoch SA 5351" } },
        { "type": "info_item", "settings": { "icon": "phone", "text": "+61 408 838 004" } },
        { "type": "info_item", "settings": { "icon": "car", "text": "Only 55 min from Adelaide CBD" } }
      ]
    }
  ]
}
{% endschema %}
