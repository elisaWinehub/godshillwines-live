{% comment %}
  To use: in the Shopify admin → Online Store → Themes → Customize → Footer section group, remove the existing footer section and add gh-footer instead.
{% endcomment %}
{% render 'gh-tokens' %}

<footer class="gh-footer gh-footer-{{ section.id }}" {{ section.shopify_attributes }}>
  <div class="gh-footer__inner">
    <div class="gh-footer__top">
      <div class="gh-footer__brand">
        <a href="{{ routes.root_url }}" class="gh-footer__logo">
          {% if section.settings.logo %}
            {{ section.settings.logo | image_url: width: 280 | image_tag: alt: section.settings.logo_text }}
          {% else %}
            <span class="gh-footer__logo-text">{{ section.settings.logo_text | default: "God's Hill Wines" }}</span>
            <span class="gh-footer__logo-sub">{{ section.settings.logo_subtext | default: 'Barossa Valley · Australia' }}</span>
          {% endif %}
        </a>
        <p>{{ section.settings.brand_desc | default: 'A family-owned business producing premium quality red and white wines, situated in the famous Barossa Valley. Our style continues a tradition practiced since Roman times in Central Italy.' }}</p>
        <div class="gh-footer__social">
          <a href="{{ section.settings.instagram_url | default: 'https://instagram.com/godshillwines' }}">Instagram</a>
          <a href="{{ section.settings.facebook_url | default: 'https://facebook.com/godshillwines' }}">Facebook</a>
        </div>
      </div>
      <div>
        <h3>{{ section.settings.quick_links_heading | default: 'Quick links' }}</h3>
        <ul>
          {% if section.settings.quick_links_menu != blank %}
            {% for link in linklists[section.settings.quick_links_menu].links %}
              <li><a href="{{ link.url }}">{{ link.title }}</a></li>
            {% endfor %}
          {% endif %}
        </ul>
      </div>
      <div>
        <h3>{{ section.settings.cellar_heading | default: 'Cellar door' }}</h3>
        <p>{{ section.settings.address | default: '34 Moppert Rd, Lyndoch SA 5351' }}</p>
        <p>{{ section.settings.phone | default: '+61 408 838 004' }}</p>
        <p>{{ section.settings.hours | default: 'Open Thu – Sun, 11am – 5pm' }}</p>
      </div>
      <div>
        <h3>{{ section.settings.newsletter_heading | default: 'Stay in the loop' }}</h3>
        <p>{{ section.settings.newsletter_blurb | default: 'Subscribe to hear about new releases, events & offers.' }}</p>
        {% form 'customer', id: 'gh-footer-newsletter-form' %}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <div class="gh-footer__newsletter-row">
            <input type="email" name="contact[email]" required placeholder="Your email address">
            <button type="submit">{{ section.settings.newsletter_btn_label | default: 'Subscribe' }}</button>
          </div>
        {% endform %}
      </div>
    </div>
    <div class="gh-footer__bottom">
      <p>{{ section.settings.legal_text | default: "Under the Liquor Licensing Act it is an offence for liquor to be delivered to a person under the age of 18 years. Please drink God's Hill Wines responsibly. © 2025 God's Hill Wines." }}</p>
      {% if section.settings.show_afterpay %}
        <span class="gh-footer__afterpay">{{ section.settings.afterpay_label | default: 'Payments via' }} <strong>Afterpay</strong></span>
      {% endif %}
    </div>
  </div>
</footer>

<style>
  .gh-footer-{{ section.id }} {
    background: {{ section.settings.bg_color | default: '#111B10' }};
    color: {{ section.settings.text_color | default: '#F5EFE3' }};
    padding: 64px 40px 32px;
  }
  .gh-footer-{{ section.id }} .gh-footer__inner {
    max-width: 1280px;
    margin: 0 auto;
  }
  .gh-footer-{{ section.id }} .gh-footer__top {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1.2fr;
    gap: 48px;
    padding-bottom: 48px;
    border-bottom: 0.5px solid rgba(245, 239, 227, 0.1);
  }
  .gh-footer-{{ section.id }} h3 {
    margin: 0 0 14px;
    font: 500 12px/1.3 'Inter', sans-serif;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: {{ section.settings.accent_color | default: '#B8913A' }};
  }
  .gh-footer-{{ section.id }} .gh-footer__logo {
    text-decoration: none;
    color: var(--gh-cream);
    display: inline-flex;
    flex-direction: column;
    margin-bottom: 14px;
  }
  .gh-footer-{{ section.id }} .gh-footer__logo img {
    max-height: 42px;
    width: auto;
  }
  .gh-footer-{{ section.id }} .gh-footer__logo-text {
    font: 400 24px/1 'EB Garamond', Georgia, serif;
  }
  .gh-footer-{{ section.id }} .gh-footer__logo-sub {
    margin-top: 6px;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    font: 500 9px/1.2 'Inter', sans-serif;
    color: rgba(245, 239, 227, 0.75);
  }
  .gh-footer-{{ section.id }} p,
  .gh-footer-{{ section.id }} li,
  .gh-footer-{{ section.id }} a,
  .gh-footer-{{ section.id }} input {
    color: rgba(245, 239, 227, 0.75);
    font: 400 13px/1.7 'Inter', sans-serif;
  }
  .gh-footer-{{ section.id }} ul {
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .gh-footer-{{ section.id }} a {
    text-decoration: none;
  }
  .gh-footer-{{ section.id }} .gh-footer__social {
    margin-top: 12px;
    display: flex;
    gap: 14px;
  }
  .gh-footer-{{ section.id }} .gh-footer__newsletter-row {
    margin-top: 10px;
    display: flex;
    gap: 8px;
  }
  .gh-footer-{{ section.id }} .gh-footer__newsletter-row input {
    flex: 1;
    min-width: 0;
    background: transparent;
    border: 1px solid rgba(245, 239, 227, 0.25);
    padding: 10px;
  }
  .gh-footer-{{ section.id }} .gh-footer__newsletter-row button {
    border: 1px solid {{ section.settings.accent_color | default: '#B8913A' }};
    background: {{ section.settings.accent_color | default: '#B8913A' }};
    color: var(--gh-cream);
    text-transform: uppercase;
    letter-spacing: 0.13em;
    font: 600 10px/1 'Inter', sans-serif;
    padding: 10px 12px;
  }
  .gh-footer-{{ section.id }} .gh-footer__bottom {
    margin-top: 22px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 20px;
  }
  .gh-footer-{{ section.id }} .gh-footer__afterpay {
    border: 1px solid rgba(245, 239, 227, 0.25);
    border-radius: 999px;
    padding: 7px 12px;
    font: 500 11px/1 'Inter', sans-serif;
    color: rgba(245, 239, 227, 0.85);
  }
  .gh-footer-{{ section.id }} .gh-footer__afterpay strong {
    color: var(--gh-cream);
  }
  @media (max-width: 768px) {
    .gh-footer-{{ section.id }} {
      padding: 60px 20px 28px;
    }
    .gh-footer-{{ section.id }} .gh-footer__top {
      grid-template-columns: 1fr;
      gap: 26px;
    }
    .gh-footer-{{ section.id }} .gh-footer__bottom {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>

{% schema %}
{
  "name": "GH — Footer",
  "settings": [
    { "type": "image_picker", "id": "logo", "label": "Footer logo" },
    { "type": "text", "id": "logo_text", "label": "Logo text fallback", "default": "God's Hill Wines" },
    { "type": "text", "id": "logo_subtext", "label": "Logo subline", "default": "Barossa Valley · Australia" },
    { "type": "textarea", "id": "brand_desc", "label": "Brand description", "default": "A family-owned business producing premium quality red and white wines, situated in the famous Barossa Valley. Our style continues a tradition practiced since Roman times in Central Italy." },
    { "type": "url", "id": "instagram_url", "label": "Instagram URL" },
    { "type": "url", "id": "facebook_url", "label": "Facebook URL" },
    { "type": "link_list", "id": "quick_links_menu", "label": "Quick links menu", "default": "footer" },
    { "type": "text", "id": "quick_links_heading", "label": "Quick links heading", "default": "Quick links" },
    { "type": "text", "id": "cellar_heading", "label": "Cellar door column heading", "default": "Cellar door" },
    { "type": "text", "id": "address", "label": "Address", "default": "34 Moppert Rd, Lyndoch SA 5351" },
    { "type": "text", "id": "phone", "label": "Phone", "default": "+61 408 838 004" },
    { "type": "text", "id": "hours", "label": "Opening hours", "default": "Open Thu – Sun, 11am – 5pm" },
    { "type": "text", "id": "newsletter_heading", "label": "Newsletter column heading", "default": "Stay in the loop" },
    { "type": "text", "id": "newsletter_blurb", "label": "Newsletter blurb", "default": "Subscribe to hear about new releases, events & offers." },
    { "type": "text", "id": "newsletter_btn_label", "label": "Newsletter button label", "default": "Subscribe" },
    { "type": "textarea", "id": "legal_text", "label": "Legal / disclaimer", "default": "Under the Liquor Licensing Act it is an offence for liquor to be delivered to a person under the age of 18 years. Please drink God's Hill Wines responsibly. © 2025 God's Hill Wines." },
    { "type": "checkbox", "id": "show_afterpay", "label": "Show Afterpay badge", "default": true },
    { "type": "text", "id": "afterpay_label", "label": "Afterpay label", "default": "Payments via" },
    { "type": "color", "id": "bg_color", "label": "Background colour", "default": "#111B10" },
    { "type": "color", "id": "text_color", "label": "Body text colour", "default": "#F5EFE3" },
    { "type": "color", "id": "accent_color", "label": "Accent / icon colour", "default": "#B8913A" }
  ],
  "presets": [{ "name": "GH — Footer" }]
}
{% endschema %}
