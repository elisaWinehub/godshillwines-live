{% comment %}
  Default collection layout: full-bleed hero + Horizon native facets (sidebar) + custom product grid.
  Scoped to this section only — does not alter global product-card blocks.
{% endcomment %}
{% liquid
  assign per_raw = section.settings.products_per_page | default: 9
  assign products_per_page = per_raw
  assign mod9 = per_raw | modulo: 9
  unless mod9 == 0
    assign products_per_page = per_raw | minus: mod9 | at_least: 9
  endunless

  assign op = section.settings.hero_overlay_opacity | divided_by: 100.0
  assign hero_img = collection.image
  if hero_img == blank and section.settings.hero_fallback_image != blank
    assign hero_img = section.settings.hero_fallback_image
  endif

  assign aspect_val = section.settings.card_image_aspect | default: 'ratio_4_5'
  assign aspect_css = '4 / 5'
  case aspect_val
    when 'adapt'
      assign aspect_css = 'auto'
    when 'ratio_square'
      assign aspect_css = '1 / 1'
    when 'ratio_4_5'
      assign aspect_css = '4 / 5'
    when 'ratio_3_4'
      assign aspect_css = '3 / 4'
    when 'ratio_landscape'
      assign aspect_css = '4 / 3'
  endcase

  assign root_classes = 'godshill-mcp-root'
  unless section.settings.mobile_filter_drawer
    assign root_classes = root_classes | append: ' godshill-mcp--filters-inline-mobile'
  endunless
  if section.settings.sticky_filter_sidebar
    assign root_classes = root_classes | append: ' godshill-mcp--sticky-sidebar'
  endif

  assign hero_align_modifier = ''
  case section.settings.hero_title_align
    when 'left'
      assign hero_align_modifier = 'godshill-mcp__hero-inner--left'
    when 'right'
      assign hero_align_modifier = 'godshill-mcp__hero-inner--right'
    else
      assign hero_align_modifier = 'godshill-mcp__hero-inner--center'
  endcase
%}

<div
  id="GodshillMCP-{{ section.id }}"
  class="{{ root_classes }}"
  data-section-id="{{ section.id }}"
  data-card-aspect="{{ aspect_val }}"
  style="
    --mcp-cols-d: {{ section.settings.columns_desktop }};
    --mcp-cols-t: {{ section.settings.columns_tablet }};
    --mcp-cols-m: {{ section.settings.columns_mobile }};
    --mcp-gap: {{ section.settings.grid_gap }}px;
    --mcp-hero-h-m: {{ section.settings.hero_height_mobile }}px;
    --mcp-hero-h-d: {{ section.settings.hero_height_desktop }}px;
    --mcp-badge-sale-bg: {{ section.settings.badge_sale_bg }};
    --mcp-badge-sale-fg: {{ section.settings.badge_sale_fg }};
    --mcp-badge-muted-bg: {{ section.settings.badge_muted_bg }};
    --mcp-badge-muted-fg: {{ section.settings.badge_muted_fg }};
    --mcp-badge-accent-bg: {{ section.settings.badge_accent_bg }};
    --mcp-badge-accent-fg: {{ section.settings.badge_accent_fg }};
    --facets-vertical-col-width: {{ section.settings.sidebar_column_span }};
  "
>
  <div class="section-background color-{{ section.settings.color_scheme }}"></div>

  {% comment %} --- Collection hero (full viewport width) --- {% endcomment %}
  <header class="godshill-mcp__hero" aria-label="{{ collection.title }}">
    <div class="godshill-mcp__hero-media">
      {% if hero_img != blank %}
        {{
          hero_img
          | image_url: width: 2400
          | image_tag:
            loading: 'eager',
            fetchpriority: 'high',
            widths: '720,1100,1600,2000,2400',
            sizes: '100vw',
            class: 'godshill-mcp__hero-img'
        }}
      {% else %}
        <div class="godshill-mcp__hero-placeholder" role="presentation" aria-hidden="true"></div>
      {% endif %}
      <div
        class="godshill-mcp__hero-overlay"
        style="background: {{ section.settings.hero_overlay_color }}; opacity: {{ op }};"
      ></div>
      <div class="godshill-mcp__hero-inner {{ hero_align_modifier }} color-{{ section.settings.hero_color_scheme }}">
        <h1 class="godshill-mcp__hero-title" style="
            font-size: clamp({{ section.settings.hero_title_size_mobile }}px, 4vw, {{ section.settings.hero_title_size_desktop }}px);
            font-weight: {{ section.settings.hero_title_weight }};
          ">
          {{ collection.title }}
        </h1>
        {% if collection.description != blank and section.settings.show_collection_description %}
          <div class="godshill-mcp__hero-desc rte">{{ collection.description }}</div>
        {% endif %}
      </div>
    </div>
  </header>

  {% comment %} --- Horizon facet grid + products (facets block must stay in collection-wrapper) --- {% endcomment %}
  <div
    class="collection-wrapper grid gap-style collection-wrapper--full-width godshill-mcp__collection-shell"
    style="--padding-block-start: {{ section.settings.padding_top }}px; --padding-block-end: {{ section.settings.padding_bottom }}px;"
  >
    {% render 'godshill-collection-facets',
      results: collection,
      results_size: collection.products_count
    %}

    {% paginate collection.products by products_per_page %}
      <div
        id="ResultsList"
        class="grid main-collection-grid godshill-mcp__results spacing-style {% if section.settings.inherit_section_color_scheme == false %}color-{{ section.settings.product_area_color_scheme }}{% endif %}"
        style="
          --padding-block-start: {{ section.settings.padding_top }}px;
          --padding-block-end: {{ section.settings.padding_bottom }}px;
          --padding-inline-start: {{ section.settings.grid_padding_inline }}px;
          --padding-inline-end: {{ section.settings.grid_padding_inline }}px;
          --padding-inline-desktop: clamp(16px, 4vw, 56px);
        "
      >
        {% render 'skip-to-content-link', href: '#MCP-product-grid-{{ section.id }}', text: 'accessibility.skip_to_text' %}

        <div style="grid-column: var(--full-width);" class="godshill-mcp__toolbar">
          {% assign cnt = collection.products_count %}
          {% if cnt > 0 %}
            <p class="godshill-mcp__count" role="status">
              {{ 'content.search_results_resource_products_count' | t: count: cnt }}
            </p>
          {% endif %}
        </div>

        <div style="grid-column: var(--full-width);" id="MCP-product-grid-{{ section.id }}">
          {% if collection.products.size == 0 %}
            <div class="godshill-mcp__empty">
              <h2 class="h4">{{ 'content.no_products_found' | t }}</h2>
              <p>
                {{ 'content.use_fewer_filters_html' | t: link: collection.url, class: 'link' }}
              </p>
            </div>
          {% else %}
            <ul class="godshill-mcp__grid list-unstyled" role="list">
              {% for product in collection.products %}
                <li class="godshill-mcp__cell"
                  id="{{ section.id }}-{{ product.id }}"
                  data-page="{{ paginate.current_page }}"
                  data-product-id="{{ product.id }}"
                >
                  {% render 'godshill-collection-product-card', product: product, section: section %}
                </li>
              {% endfor %}
            </ul>

            {% if paginate.pages > 1 %}
              <div class="godshill-mcp__pagination-wrap">
                {% render 'pagination-controls', paginate: paginate %}
              </div>
            {% endif %}
          {% endif %}
        </div>
      </div>
    {% endpaginate %}
  </div>
</div>

<style>
  /* Clip breakout hero at the Shopify section root (avoids document horizontal scroll). */
  #shopify-section-{{ section.id }} {
    overflow-x: clip;
  }

  #GodshillMCP-{{ section.id }} .godshill-mcp__collection-shell.collection-wrapper {
    grid-column: 1 / -1;
  }

  #GodshillMCP-{{ section.id }}.godshill-mcp-root {
    padding-bottom: {{ section.settings.padding_bottom }}px;
    overflow-x: clip;
  }

  #GodshillMCP-{{ section.id }} .godshill-mcp__hero {
    box-sizing: border-box;
    position: relative;
    overflow: hidden;
    width: 100vw;
    max-width: 100vw;
    margin-left: calc(50% - 50vw);
    margin-right: calc(50% - 50vw);
    min-height: var(--mcp-hero-h-m);
  }

  /* Header overlay — nav transparent over hero, solid white on scroll (matches homepage) */
  body:has([data-gh-custom-header][data-gh-overlay='true']) #GodshillMCP-{{ section.id }} > .section-background {
    display: none;
  }

  body:has([data-gh-custom-header][data-gh-overlay='true']) #GodshillMCP-{{ section.id }} .godshill-mcp__hero {
    z-index: 1;
    min-height: 50svh;
    height: 50svh;
  }

  body:has([data-gh-custom-header][data-gh-overlay='true']) #GodshillMCP-{{ section.id }} .godshill-mcp__hero-media {
    min-height: 100%;
    height: 100%;
  }

  body:has([data-gh-custom-header][data-gh-overlay='true']) #GodshillMCP-{{ section.id }} .godshill-mcp__hero-img,
  body:has([data-gh-custom-header][data-gh-overlay='true']) #GodshillMCP-{{ section.id }} .godshill-mcp__hero-placeholder {
    min-height: 100%;
    height: 100%;
  }

  body:has([data-gh-custom-header][data-gh-overlay='true']) #GodshillMCP-{{ section.id }} .godshill-mcp__hero-inner {
    padding-top: calc(var(--header-height, 80px) + clamp(16px, 4vw, 48px));
  }
  #GodshillMCP-{{ section.id }} .godshill-mcp__hero-media {
    position: relative;
    min-height: inherit;
    display: grid;
    place-items: stretch;
  }
  #GodshillMCP-{{ section.id }} .godshill-mcp__hero-img,
  #GodshillMCP-{{ section.id }} .godshill-mcp__hero-placeholder {
    width: 100%;
    height: 100%;
    min-height: inherit;
    object-fit: cover;
    display: block;
  }
  #GodshillMCP-{{ section.id }} .godshill-mcp__hero-placeholder {
    background: linear-gradient(145deg, #f3f2ef 0%, #dfd9cc 48%, #b8aa8e 100%);
  }
  #GodshillMCP-{{ section.id }} .godshill-mcp__hero-overlay {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }
  #GodshillMCP-{{ section.id }} .godshill-mcp__hero-inner {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    padding: clamp(24px, 6vw, 90px);
    text-align: inherit;
    z-index: 1;
  }
  #GodshillMCP-{{ section.id }} .godshill-mcp__hero-inner--center {
    text-align: center;
    align-items: center;
    padding-inline: clamp(24px, 7vw, 120px);
  }
  #GodshillMCP-{{ section.id }} .godshill-mcp__hero-inner--left {
    text-align: left;
    align-items: flex-start;
    padding-inline: clamp(24px, 7vw, 120px);
    padding-inline-end: clamp(24px, 6vw, 80px);
  }
  #GodshillMCP-{{ section.id }} .godshill-mcp__hero-inner--right {
    text-align: right;
    align-items: flex-end;
    padding-inline: clamp(24px, 7vw, 120px);
    padding-inline-start: clamp(24px, 6vw, 80px);
  }

  #GodshillMCP-{{ section.id }} .godshill-mcp__hero-title {
    margin: 0;
    letter-spacing: 0.03em;
    color: inherit;
    text-wrap: balance;
    font-family: Georgia, 'Times New Roman', serif;
  }
  #GodshillMCP-{{ section.id }} .godshill-mcp__hero-desc {
    margin: 14px 0 0;
    max-width: 560px;
    font-size: 1rem;
    line-height: 1.55;
    opacity: 0.94;
    color: inherit;
  }
  #GodshillMCP-{{ section.id }} .godshill-mcp__hero-inner--left .godshill-mcp__hero-desc {
    margin-left: 0;
    margin-right: 0;
  }
  #GodshillMCP-{{ section.id }} .godshill-mcp__hero-inner--right .godshill-mcp__hero-desc {
    margin-left: auto;
    margin-right: 0;
    text-align: right;
  }
  #GodshillMCP-{{ section.id }} .godshill-mcp__hero-inner--center .godshill-mcp__hero-desc {
    margin-inline: auto;
    text-align: center;
  }
  #GodshillMCP-{{ section.id }} .godshill-mcp__results.main-collection-grid {
    background: rgb(var(--color-background-rgb) / 1);
  }
  #GodshillMCP-{{ section.id }} .godshill-mcp__toolbar {
    margin-bottom: 8px;
  }
  #GodshillMCP-{{ section.id }} .godshill-mcp__count {
    margin: 0;
    font-size: 13px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    opacity: 0.65;
    color: var(--color-foreground);
  }
  #GodshillMCP-{{ section.id }} .godshill-mcp__grid {
    display: grid;
    gap: var(--mcp-gap);
    margin: 0;
    grid-template-columns: repeat(var(--mcp-cols-m), minmax(0, 1fr));
    align-items: stretch;
    padding-inline: {{ section.settings.grid_padding_mobile }}px;
  }
  #GodshillMCP-{{ section.id }} .godshill-mcp__cell {
    display: flex;
    flex-direction: column;
    min-height: 100%;
    height: 100%;
  }
  #GodshillMCP-{{ section.id }} .godshill-mcp__cell > .mcp-card {
    flex: 1 1 auto;
    width: 100%;
  }
  @media screen and (min-width: 750px) {
    body:not(:has([data-gh-custom-header][data-gh-overlay='true'])) #GodshillMCP-{{ section.id }} .godshill-mcp__hero {
      min-height: var(--mcp-hero-h-d);
    }
    #GodshillMCP-{{ section.id }} .godshill-mcp__grid {
      grid-template-columns: repeat(var(--mcp-cols-t), minmax(0, 1fr));
      padding-inline-start: clamp(24px, 4vw, 56px);
      padding-inline-end: clamp(24px, 4vw, 56px);
    }
  }
  @media screen and (min-width: 990px) {
    #GodshillMCP-{{ section.id }} .godshill-mcp__grid {
      grid-template-columns: repeat(var(--mcp-cols-d), minmax(0, 1fr));
    }
  }

  #GodshillMCP-{{ section.id }} .godshill-mcp__pagination-wrap .pagination {
    margin-top: 32px;
  }

  /* Sticky facets column (desktop) */
  @media screen and (min-width: 750px) {
    #GodshillMCP-{{ section.id }}.godshill-mcp--sticky-sidebar .facets-block-wrapper--vertical:not(#filters-drawer) {
      position: sticky;
      top: 24px;
      align-self: start;
      max-height: calc(100vh - 40px);
      overflow-y: auto;
    }
  }

  {% comment %} Minimal polish on Horizon facet panels in sidebar {% endcomment %}
  #GodshillMCP-{{ section.id }} .facets--vertical .facets__panel summary {
    font-family: Arial, Helvetica, sans-serif;
    font-size: 13px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  /* Mobile drawer vs inline facets */
  @media screen and (max-width: 749px) {
    #GodshillMCP-{{ section.id }}.godshill-mcp--filters-inline-mobile .facets-toggle {
      display: none !important;
    }
    #GodshillMCP-{{ section.id }}.godshill-mcp--filters-inline-mobile dialog-component#filters-drawer {
      display: none !important;
    }
    #GodshillMCP-{{ section.id }}.godshill-mcp--filters-inline-mobile .facets-block-wrapper--vertical:not(#filters-drawer) {
      display: block !important;
      grid-column: 1 / -1 !important;
      margin-inline: 0 !important;
    }
    #GodshillMCP-{{ section.id }}.godshill-mcp--filters-inline-mobile .facets.facets--vertical:not(.facets--drawer) {
      display: block !important;
      width: 100%;
      padding-block: 16px !important;
    }
    #GodshillMCP-{{ section.id }}.godshill-mcp--filters-inline-mobile .facets--horizontal.facets-controls-wrapper {
      flex-wrap: wrap;
      gap: 12px !important;
    }
  }

  /* Product cards (scoped via nested classes) */
  #GodshillMCP-{{ section.id }} .mcp-card {
    display: flex;
    flex-direction: column;
    height: 100%;
    background: transparent;
    text-align: center;
  }
  #GodshillMCP-{{ section.id }} .mcp-card__media-wrap {
    position: relative;
    aspect-ratio: var(--mcp-card-aspect, 4 / 5);
    margin-bottom: 18px;
    overflow: hidden;
    background: #f8f7f5;
    border-radius: 0 !important;
  }
  #GodshillMCP-{{ section.id }}[data-card-aspect='adapt'] .mcp-card__media-wrap {
    aspect-ratio: unset !important;
    min-height: 280px;
  }
  #GodshillMCP-{{ section.id }} .mcp-card__media-wrap > a {
    display: block;
    height: 100%;
  }
  #GodshillMCP-{{ section.id }} .mcp-card__media {
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  #GodshillMCP-{{ section.id }} .mcp-card__img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }
  #GodshillMCP-{{ section.id }} .mcp-card__img-placeholder {
    width: 100%;
    height: 100%;
    background: rgb(237 236 231);
  }

  #GodshillMCP-{{ section.id }} .mcp-card__badges {
    position: absolute;
    inset: 10px auto auto 10px;
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    justify-content: flex-start;
    z-index: 1;
    max-width: calc(100% - 16px);
  }
  #GodshillMCP-{{ section.id }} .mcp-badge {
    display: inline-block;
    padding: 4px 9px;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    line-height: 1.25;
    font-family: Arial, Helvetica, sans-serif;
  }
  #GodshillMCP-{{ section.id }} .mcp-badge--sale {
    background: var(--mcp-badge-sale-bg);
    color: var(--mcp-badge-sale-fg);
  }
  #GodshillMCP-{{ section.id }} .mcp-badge--sold,
  #GodshillMCP-{{ section.id }} .mcp-badge--muted {
    background: var(--mcp-badge-muted-bg);
    color: var(--mcp-badge-muted-fg);
  }
  #GodshillMCP-{{ section.id }} .mcp-badge--new,
  #GodshillMCP-{{ section.id }} .mcp-badge--bestseller,
  #GodshillMCP-{{ section.id }} .mcp-badge--custom {
    background: var(--mcp-badge-accent-bg);
    color: var(--mcp-badge-accent-fg);
    border: 1px solid rgb(162 146 104 / 0.45);
  }

  #GodshillMCP-{{ section.id }} .mcp-card__body {
    flex: 1 1 auto;
    display: flex;
    flex-direction: column;
    align-items: stretch;
    padding-inline: 6px 8px;
    gap: 8px;
    min-height: 0;
  }
  #GodshillMCP-{{ section.id }} .mcp-card-form {
    margin-top: auto;
    width: 100%;
    display: flex;
    flex-direction: column;
  }
  #GodshillMCP-{{ section.id }} product-form-component.mcp-card__product-form {
    margin-top: auto;
    width: 100%;
    display: flex;
    flex-direction: column;
  }
  #GodshillMCP-{{ section.id }} .mcp-card__body > .mcp-card__actions {
    margin-top: auto;
    width: 100%;
  }
  #GodshillMCP-{{ section.id }} .mcp-card__vendor {
    margin: 0;
    font-size: 11px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    opacity: 0.6;
    color: var(--color-foreground);
  }
  #GodshillMCP-{{ section.id }} .mcp-card__title {
    margin: 0;
    font-size: 1rem;
    line-height: 1.38;
    font-family: Georgia, 'Times New Roman', serif;
    font-weight: 500;
    color: var(--color-foreground);
    text-wrap: balance;
  }
  #GodshillMCP-{{ section.id }} .mcp-card__title a {
    color: inherit;
    text-decoration: none;
  }
  #GodshillMCP-{{ section.id }} .mcp-card__title a:hover {
    opacity: 0.75;
  }
  #GodshillMCP-{{ section.id }} .mcp-card__price {
    font-family: Arial, Helvetica, sans-serif;
    font-size: 0.9375rem;
    color: var(--color-foreground);
  }

  #GodshillMCP-{{ section.id }} .mcp-card__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    align-items: stretch;
    justify-content: center;
  }
  #GodshillMCP-{{ section.id }} .mcp-card__actions--no-qty {
    justify-content: center;
  }
  #GodshillMCP-{{ section.id }} .mcp-qty-stepper {
    display: inline-flex;
    align-items: stretch;
    height: 40px;
    border: 1px solid rgb(var(--color-foreground-rgb) / var(--opacity-25));
    background: rgb(var(--color-background-rgb) / 1);
  }
  #GodshillMCP-{{ section.id }} .mcp-qty-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    min-width: 32px;
    padding: 0;
    border: none;
    background: transparent;
    color: var(--color-foreground);
    cursor: pointer;
    line-height: 1;
  }
  #GodshillMCP-{{ section.id }} .mcp-qty-btn--minus {
    border-right: none;
  }
  #GodshillMCP-{{ section.id }} .mcp-qty-btn--plus {
    border-left: none;
  }
  #GodshillMCP-{{ section.id }} .mcp-qty-btn:hover:not(:disabled) {
    background: rgb(var(--color-foreground-rgb) / 0.06);
  }
  #GodshillMCP-{{ section.id }} .mcp-qty-btn .svg-wrapper {
    width: var(--icon-size-xs, 12px);
    height: var(--icon-size-xs, 12px);
    opacity: 0.7;
    transition: opacity 0.2s ease;
  }
  #GodshillMCP-{{ section.id }} .mcp-qty-btn:hover:not(:disabled) .svg-wrapper {
    opacity: 1;
  }
  #GodshillMCP-{{ section.id }} .mcp-qty-btn:disabled {
    opacity: 0.35;
    cursor: not-allowed;
  }
  #GodshillMCP-{{ section.id }} .mcp-qty-btn:disabled .svg-wrapper {
    opacity: 0.35;
  }
  #GodshillMCP-{{ section.id }} .mcp-qty-btn .svg-wrapper > svg {
    width: var(--icon-size-xs, 12px);
    height: var(--icon-size-xs, 12px);
  }
  #GodshillMCP-{{ section.id }} .mcp-qty {
    width: 36px;
    min-width: 36px;
    height: 100%;
    text-align: center;
    padding: 0 2px;
    border: none;
    border-radius: 0;
    background: transparent;
    color: var(--color-foreground);
    font-size: 13px;
    appearance: textfield;
    -moz-appearance: textfield;
  }
  #GodshillMCP-{{ section.id }} .mcp-qty::-webkit-outer-spin-button,
  #GodshillMCP-{{ section.id }} .mcp-qty::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }
  #GodshillMCP-{{ section.id }} .mcp-qty:focus-visible {
    outline: 2px solid var(--color-foreground);
    outline-offset: 1px;
  }
  #GodshillMCP-{{ section.id }} .mcp-atc-btn {
    flex: 1;
    min-width: 132px;
    height: 40px;
    border: none;
    border-radius: 0 !important;
    font-family: Arial, Helvetica, sans-serif;
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    cursor: pointer;
    transition: filter 0.2s ease, opacity 0.2s ease;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    position: relative;
  }
  #GodshillMCP-{{ section.id }} .mcp-atc-btn[data-loading='true'] .add-to-cart-icon,
  #GodshillMCP-{{ section.id }} .mcp-atc-btn[data-loading='true'] .mcp-atc-btn__text {
    opacity: 0;
    visibility: hidden;
  }
  #GodshillMCP-{{ section.id }} .mcp-atc-btn__loading {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
  }
  #GodshillMCP-{{ section.id }} .mcp-atc-btn__loading[hidden] {
    display: none;
  }
  #GodshillMCP-{{ section.id }} .mcp-atc-btn__loading-spinner {
    width: 16px;
    height: 16px;
    border: 2px solid rgb(255 255 255 / 0.35);
    border-top-color: currentColor;
    border-radius: 50%;
    animation: mcp-atc-spin 0.65s linear infinite;
  }
  @keyframes mcp-atc-spin {
    to { transform: rotate(360deg); }
  }
  #GodshillMCP-{{ section.id }} .mcp-atc-btn .add-to-cart-icon {
    width: var(--icon-size-xs, 16px);
    height: var(--icon-size-xs, 16px);
    flex-shrink: 0;
  }
  #GodshillMCP-{{ section.id }} .mcp-atc-btn .add-to-cart-icon > svg {
    width: var(--icon-size-xs, 16px);
    height: var(--icon-size-xs, 16px);
  }
  #GodshillMCP-{{ section.id }} .mcp-atc-btn__text {
    font-weight: 400;
  }
  #GodshillMCP-{{ section.id }} .mcp-atc-btn:not(:disabled):hover {
    filter: brightness(0.92);
    background-image: linear-gradient(rgb(0 0 0 / 0%), rgb(0 0 0 / 0.08));
  }
  #GodshillMCP-{{ section.id }} .mcp-atc-btn:disabled {
    cursor: not-allowed;
    opacity: 0.55;
  }
  #GodshillMCP-{{ section.id }} .mcp-atc-btn--link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    border: 1px solid rgb(var(--color-foreground-rgb) / var(--opacity-35));
    color: inherit;
    background: transparent !important;
  }
  #GodshillMCP-{{ section.id }} .mcp-atc-btn--link:hover {
    opacity: 0.75;
    filter: none;
  }

  #GodshillMCP-{{ section.id }} .godshill-mcp__empty {
    padding: 72px 20px;
    text-align: center;
    border: 1px dashed rgb(var(--color-foreground-rgb) / 0.2);
    color: var(--color-foreground);
  }
</style>

<script>
  (function () {
    var root = document.getElementById('GodshillMCP-{{ section.id }}');
    if (!root) return;

    root.addEventListener('click', function (event) {
      var btn = event.target.closest('[data-mcp-qty-minus], [data-mcp-qty-plus]');
      if (!btn || btn.disabled) return;

      var stepper = btn.closest('.mcp-qty-stepper');
      if (!stepper) return;

      var input = stepper.querySelector('.mcp-qty');
      if (!input || input.disabled) return;

      var min = parseFloat(input.min) || 1;
      var max = input.max ? parseFloat(input.max) : Infinity;
      var step = parseFloat(input.step) || 1;
      var value = parseFloat(input.value) || min;

      if (btn.hasAttribute('data-mcp-qty-minus')) {
        value = Math.max(min, value - step);
      } else {
        value = Math.min(max, value + step);
      }

      input.value = value;
    });

    function openCartDrawer() {
      var drawer = document.querySelector('cart-drawer-component');
      if (drawer && typeof drawer.open === 'function') {
        drawer.open();
      }
    }

    function setMcpAtcLoading(productForm, isLoading) {
      var btn = productForm.querySelector('[data-mcp-atc-btn]');
      if (!btn) return;
      var loadingEl = btn.querySelector('.mcp-atc-btn__loading');

      if (isLoading) {
        btn.dataset.loading = 'true';
        btn.setAttribute('aria-busy', 'true');
        btn.disabled = true;
        if (loadingEl) loadingEl.hidden = false;
      } else {
        delete btn.dataset.loading;
        btn.removeAttribute('aria-busy');
        btn.disabled = false;
        if (loadingEl) loadingEl.hidden = true;
      }
    }

    root.querySelectorAll('product-form-component.mcp-card__product-form').forEach(function (productForm) {
      var loadingTimeout;

      productForm.addEventListener('submit', function () {
        clearTimeout(loadingTimeout);
        setMcpAtcLoading(productForm, true);
        loadingTimeout = setTimeout(function () {
          setMcpAtcLoading(productForm, false);
        }, 15000);
      });

      productForm.addEventListener('cart:update', function (event) {
        clearTimeout(loadingTimeout);
        setMcpAtcLoading(productForm, false);
        if (!event.detail?.data?.didError) {
          openCartDrawer();
        }
      });

      productForm.addEventListener('cart:error', function () {
        clearTimeout(loadingTimeout);
        setMcpAtcLoading(productForm, false);
      });
    });
  })();
</script>

