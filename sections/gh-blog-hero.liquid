{%- render 'gh-tokens' -%}
<style>
  .gh-blog-hero-{{ section.id }} {
    position: relative;
    height: {{ section.settings.hero_height | default: 380 }}px;
    overflow: hidden;
    display: flex;
    align-items: flex-end;
    background: #1C2B1A;
  }
  .gh-blog-hero-{{ section.id }} .gh-blog-hero-bg-{{ section.id }} {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    z-index: 0;
  }
  .gh-blog-hero-{{ section.id }} .gh-blog-hero-overlay-{{ section.id }} {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(20, 28, 18, {{ section.settings.overlay_opacity | default: 65 | divided_by: 100.0 | times: 0.4 }}) 0%,
      rgba(20, 28, 18, {{ section.settings.overlay_opacity | default: 65 | divided_by: 100.0 }}) 100%
    );
    z-index: 1;
  }
  .gh-blog-hero-{{ section.id }} .gh-blog-hero-content-{{ section.id }} {
    position: relative;
    z-index: 2;
    padding: 0 40px 52px;
    max-width: 1280px;
    width: 100%;
    margin: 0 auto;
  }
  .gh-blog-hero-{{ section.id }} .gh-blog-hero-content-{{ section.id }} p {
    margin: 0;
  }
  .gh-blog-hero-{{ section.id }} .gh-blog-hero-eyebrow {
    margin: 0;
    font: 500 10px/1.2 'Inter', sans-serif;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--gh-gold);
  }
  .gh-blog-hero-{{ section.id }} .gh-blog-hero-divider {
    width: 40px;
    height: 1px;
    background: var(--gh-gold);
    opacity: 0.7;
    margin: 14px 0 18px;
    display: block;
  }
  .gh-blog-hero-{{ section.id }} .gh-blog-hero-title {
    margin: 0 0 12px;
    color: #F5EFE3;
    font-family: 'EB Garamond', Georgia, serif;
    font-size: clamp(40px, 5vw, 68px);
    line-height: 1;
  }
  .gh-blog-hero-{{ section.id }} .gh-blog-hero-title em {
    color: var(--gh-gold-light);
    font-style: italic;
  }
  .gh-blog-hero-{{ section.id }} .gh-blog-hero-subheading {
    margin: 0;
    max-width: 520px;
    color: rgba(245, 239, 227, 0.65);
    font: 400 14px/1.7 'Inter', sans-serif;
  }
  @media (max-width: 768px) {
    .gh-blog-hero-{{ section.id }} .gh-blog-hero-content-{{ section.id }} {
      padding: 0 20px 36px;
    }
  }
</style>

<section class="gh-blog-hero-{{ section.id }}" id="gh-blog-hero-{{ section.id }}">
  <div
    class="gh-blog-hero-bg-{{ section.id }}"
    {% if section.settings.hero_image %}
      style="background-image: url('{{ section.settings.hero_image | image_url: width: 1600 }}')"
    {% else %}
      style="background-color: #1C2B1A;"
    {% endif %}>
  </div>
  <div class="gh-blog-hero-overlay-{{ section.id }}"></div>
  <div class="gh-blog-hero-content-{{ section.id }}">
    <p class="gh-blog-hero-eyebrow">{{ section.settings.hero_eyebrow | default: "God's Hill Wines" }}</p>
    <span class="gh-blog-hero-divider"></span>
    <div class="gh-blog-hero-title">{{ section.settings.hero_title }}</div>
    {% if section.settings.hero_subheading != blank %}
      <p class="gh-blog-hero-subheading">{{ section.settings.hero_subheading }}</p>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "GH — Blog Hero",
  "settings": [
    { "type": "image_picker", "id": "hero_image", "label": "Background image" },
    { "type": "text", "id": "hero_eyebrow", "label": "Eyebrow text", "default": "God's Hill Wines" },
    { "type": "richtext", "id": "hero_title", "label": "Hero title", "default": "<p>News <em>&amp; Events</em></p>" },
    { "type": "text", "id": "hero_subheading", "label": "Subheading", "default": "Stories, releases, charity events and happenings from the Scalzi family and Barossa Valley." },
    { "type": "range", "id": "hero_height", "label": "Hero height (px)", "min": 240, "max": 560, "step": 20, "default": 380 },
    { "type": "range", "id": "overlay_opacity", "label": "Overlay darkness %", "min": 0, "max": 90, "step": 5, "default": 65 }
  ],
  "presets": [
    { "name": "GH — Blog Hero" }
  ]
}
{% endschema %}
