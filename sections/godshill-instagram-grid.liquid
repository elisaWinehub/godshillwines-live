{% comment %} Instagram teaser grid {% endcomment %}
{% liquid
  assign imgs = section.blocks | where: 'type', 'image'
%}
{% unless section.settings.section_enabled %}
  <div {{ section.shopify_attributes }} hidden></div>
{% else %}
  <section
    id="GHGram-{{ section.id }}"
    class="gh-gram {{ section.settings.custom_css_class | strip }}"
    {{ section.shopify_attributes }}
    style="
      background:{{ section.settings.section_bg }};
      --pt:{{ section.settings.pad_top }}px;
      --pb:{{ section.settings.pad_bottom }}px;
      --mw:{{ section.settings.content_width }}px;
      --d:{{ section.settings.cols_d }};
      --t:{{ section.settings.cols_t }};
      --m:{{ section.settings.cols_m }};
      --gap:{{ section.settings.cell_gap }}px;
    "
  >
  <div class="gh-gram__inner">
    {% if section.settings.subheading != blank %}
      <p class="gh-gram__eye">{{ section.settings.subheading }}</p>
    {% endif %}
    {% if section.settings.heading != blank %}
      <h2 class="gh-gram__ttl">{{ section.settings.heading }}</h2>
    {% endif %}

    <div class="gh-gram__grid">
      {% for block in imgs %}
        <div {{ block.shopify_attributes }} class="gh-gram__cell-wrap">
          {% if block.settings.image != blank %}
            {% capture ig_img %}
              {{
                block.settings.image
                | image_url: width: 840
                | image_tag: loading: 'lazy', class: 'gh-gram__thumb', widths: '200,340,560', alt: ''
              }}
            {% endcapture %}
            {% if block.settings.link != blank %}
              <a class="gh-gram__link" href="{{ block.settings.link }}">{{ ig_img }}</a>
            {% else %}
              {{ ig_img }}
            {% endif %}
          {% else %}
            <div class="gh-gram__thumb gh-gram__ph"></div>
          {% endif %}
        </div>
      {% endfor %}
    </div>

    {% if section.settings.cta_style == 'secondary' %}
      {% render 'godshill-cta-btn',
        label: section.settings.cta_label,
        url: section.settings.cta_link,
        style: 'secondary',
        bg: section.settings.sf_bg,
        fg: section.settings.sf_fg,
        border_c: section.settings.sf_bd,
        h_bg: section.settings.sf_hbg,
        h_fg: section.settings.sf_hf,
        h_border: section.settings.sf_hbd
      %}
    {% else %}
      {% render 'godshill-cta-btn',
        label: section.settings.cta_label,
        url: section.settings.cta_link,
        style: 'primary',
        bg: section.settings.p_bg,
        fg: section.settings.p_fg,
        border_c: section.settings.p_bd,
        h_bg: section.settings.p_hbg,
        h_fg: section.settings.p_hf,
        h_border: section.settings.p_hbd
      %}
    {% endif %}
  </div>
</section>

<style>
  #GHGram-{{ section.id }}.gh-gram {
    padding-block: var(--pt) var(--pb);
    color: {{ section.settings.head_color }};
    text-align: center;
  }
  #GHGram-{{ section.id }} .gh-gram__inner {
    width: min(100%, var(--mw));
    margin-inline: auto;
    padding-inline: clamp(12px, 3vw, 24px);
  }
  #GHGram-{{ section.id }} .gh-gram__eye {
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: {{ section.settings.eye_color | default: '#A67B22' }};
    font-weight: 700;
    margin: 0 0 10px;
  }
  #GHGram-{{ section.id }} .gh-gram__ttl {
    margin: 0 auto 26px;
    font-family: Georgia, serif;
    font-weight: {{ section.settings.head_weight | default: 500 }};
    font-size: {{ section.settings.head_size }}px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: {{ section.settings.head_color }};
  }
  #GHGram-{{ section.id }} .gh-gram__grid {
    display: grid;
    grid-template-columns: repeat(var(--m), minmax(0, 1fr));
    gap: var(--gap);
    margin-bottom: 28px;
  }
  @media screen and (min-width: 750px) {
    #GHGram-{{ section.id }} .gh-gram__grid {
      grid-template-columns: repeat(var(--t), minmax(0, 1fr));
    }
  }
  @media screen and (min-width: 990px) {
    #GHGram-{{ section.id }} .gh-gram__grid {
      grid-template-columns: repeat(var(--d), minmax(0, 1fr));
    }
  }
  #GHGram-{{ section.id }} .gh-gram__cell-wrap {
    position: relative;
    aspect-ratio: 1 / 1;
    box-shadow: 0 10px 20px rgb(0 0 0 / 0.08);
  }
  #GHGram-{{ section.id }} .gh-gram__thumb {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    border-radius: 0;
  }
  #GHGram-{{ section.id }} .gh-gram__link {
    display: block;
    height: 100%;
  }
  #GHGram-{{ section.id }} .gh-gram__ph {
    background: linear-gradient(135deg, #d9d6cc, #8d8577);
    height: 100%;
    min-height: 120px;
  }
  #GHGram-{{ section.id }} .gh-cta {
    display: inline-flex;
    align-items: center;
    gap: 11px;
    padding: 12px 20px;
    text-transform: uppercase;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-decoration: none;
    transition: 0.22s ease;
  }

  #GHGram-{{ section.id }} .gh-cta::after {
    content: '\2192';
  }
  #GHGram-{{ section.id }} .gh-cta:hover {
    transform: translateY(-1px);
    background-color: var(--gh-h-bg) !important;
    color: var(--gh-h-fg) !important;
    border-color: var(--gh-h-bd) !important;
  }
</style>
{% endunless %}

{% schema %}
{
  "name": "Godshill Instagram Grid",
  "tag": "section",
  "class": "godshill-instagram",
  "max_blocks": 12,
  "blocks": [
    {
      "type": "image",
      "name": "Grid image",
      "settings": [{ "type": "image_picker", "id": "image", "label": "Image" }, { "type": "url", "id": "link", "label": "Link (optional)", "info": "e.g., Instagram reel URL." }]
    }
  ],
  "settings": [
    { "type": "checkbox", "id": "section_enabled", "label": "Show section", "default": true },
    { "type": "color", "id": "section_bg", "label": "Surface colour", "default": "#FBF8F2" },
    { "type": "range", "id": "pad_top", "label": "Top padding", "min": 30, "max": 140, "step": 2, "unit": "px", "default": 70 },
    {
      "type": "range",
      "id": "pad_bottom",
      "label": "Bottom padding",
      "min": 30,
      "max": 140,
      "step": 2,
      "unit": "px",
      "default": 70
    },
    {
      "type": "range",
      "id": "content_width",
      "label": "Max width canvas",
      "min": 980,
      "max": 1500,
      "step": 10,
      "unit": "px",
      "default": 1200
    },
    {
      "type": "range",
      "id": "cols_d",
      "label": "Columns desktop ≥990px",
      "min": 3,
      "max": 6,
      "step": 1,
      "default": 6
    },
    {
      "type": "range",
      "id": "cols_t",
      "label": "Columns tablet",
      "min": 3,
      "max": 6,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "cols_m",
      "label": "Columns mobile",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 2
    },
    {
      "type": "range",
      "id": "cell_gap",
      "label": "Grid spacing",
      "min": 6,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 18
    },
    { "type": "text", "id": "subheading", "label": "Eyebrow", "default": "Connect With Us" },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "On Instagram",
      "info": "All caps serif-like heading by default typography."
    },
    {
      "type": "range",
      "id": "head_size",
      "label": "Heading size px",
      "min": 20,
      "max": 44,
      "step": 1,
      "default": 26
    },
    {
      "type": "range",
      "id": "head_weight",
      "label": "Heading weight steps",
      "min": 400,
      "max": 800,
      "step": 100,
      "default": 600
    },
    { "type": "color", "id": "head_color", "label": "Heading colour", "default": "#22201C" },

    {
      "type": "select",
      "id": "cta_style",
      "label": "Instagram CTA style",
      "options": [{ "value": "secondary", "label": "Outline" }, { "value": "primary", "label": "Solid" }],
      "default": "secondary"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Instagram CTA copy",
      "default": "Follow Us On Instagram"
    },
    { "type": "url", "id": "cta_link", "label": "Instagram destination" },

    { "type": "color", "id": "p_bg", "label": "Primary BG", "default": "#A67B22" },
    { "type": "color", "id": "p_fg", "label": "Primary text", "default": "#FFFFFF" },
    { "type": "color", "id": "p_bd", "label": "Primary border", "default": "#A67B22" },
    {
      "type": "color",
      "id": "p_hbg",
      "label": "Primary hover bg",
      "default": "#846118"
    },
    { "type": "color", "id": "p_hf", "label": "Primary hover text", "default": "#FFFFFF" },
    {
      "type": "color",
      "id": "p_hbd",
      "label": "Primary hover border",
      "default": "#846118"
    },

    { "type": "color", "id": "sf_bg", "label": "Outline hover tint", "default": "#102219" },
    { "type": "color", "id": "sf_fg", "label": "Outline foreground", "default": "#102219" },
    { "type": "color", "id": "sf_bd", "label": "Outline border", "default": "#A67B22" },
    { "type": "color", "id": "sf_hbg", "label": "Outline hover bg fill", "default": "#A67B22" },
    {
      "type": "color",
      "id": "sf_hf",
      "label": "Outline hover text",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "sf_hbd",
      "label": "Outline hover border",
      "default": "#A67B22"
    },
    {
      "type": "paragraph",
      "content": "`eye_color` used for eyebrows only – adjust via Liquid if required."
    },
    { "type": "color", "id": "eye_color", "label": "Eyebrow colour", "default": "#A67B22" },

    { "type": "text", "id": "custom_css_class", "label": "Tailwind-esque hook class(es)" }
  ],
  "presets": [
    {
      "name": "Godshill Instagram Grid",
      "category": "God's Hill",
      "blocks": [{ "type": "image" }, { "type": "image" }, { "type": "image" }, { "type": "image" }, { "type": "image" }, { "type": "image" }]
    }
  ]
}
{% endschema %}
