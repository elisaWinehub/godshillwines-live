{%- render 'gh-tokens' -%}
<section class="gh-testimonials-grid-{{ section.id }}" style="background: {{ section.settings.bg_color | default: '#FDF8F2' }};">
  <div class="gh-testimonials-shell">
    <div class="gh-heading">
      <p>{{ section.settings.eyebrow | default: 'What our guests say' }}</p>
      <h2>{{ section.settings.heading | default: 'Guest Stories' }}</h2>
    </div>
    <div class="gh-grid">
      {% for block in section.blocks %}
        {% if block.type == 'testimonial' %}
          <article class="gh-card" {{ block.shopify_attributes }} style="background: {{ section.settings.card_bg | default: '#FFFFFF' }};">
            <p class="gh-quote-mark" style="color: {{ section.settings.accent_color | default: '#B8913A' }};">"</p>
            <p class="gh-stars" style="color: {{ section.settings.accent_color | default: '#B8913A' }};">{% for i in (1..block.settings.stars) %}★{% endfor %}</p>
            <p class="gh-text">{{ block.settings.text }}</p>
            <span class="gh-divider" style="background: {{ section.settings.accent_color | default: '#B8913A' }};"></span>
            <p class="gh-name">{{ block.settings.name }}</p>
            <p class="gh-role">{{ block.settings.role }}</p>
          </article>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>
<style>
  .gh-testimonials-grid-{{ section.id }} { padding: 80px 40px; }
  .gh-testimonials-grid-{{ section.id }} .gh-testimonials-shell { width: min(1280px, 100%); margin: 0 auto; }
  .gh-testimonials-grid-{{ section.id }} .gh-heading { text-align: center; margin-bottom: 24px; }
  .gh-testimonials-grid-{{ section.id }} .gh-heading p { margin: 0 0 6px; font-size: 11px; text-transform: uppercase; letter-spacing: 0.12em; color: var(--gh-gold); }
  .gh-testimonials-grid-{{ section.id }} .gh-heading h2 { margin: 0; font: 400 36px/1.15 'EB Garamond', Georgia, serif; color: var(--gh-vine); }
  .gh-testimonials-grid-{{ section.id }} .gh-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
  .gh-testimonials-grid-{{ section.id }} .gh-card { border: 0.5px solid var(--gh-border); border-radius: 4px; padding: 32px; }
  .gh-testimonials-grid-{{ section.id }} .gh-quote-mark { margin: 0; font: 400 48px/1 'EB Garamond', Georgia, serif; }
  .gh-testimonials-grid-{{ section.id }} .gh-stars { margin: 8px 0 10px; font-size: 12px; letter-spacing: 1px; }
  .gh-testimonials-grid-{{ section.id }} .gh-text { color: var(--gh-muted); min-height: 110px; }
  .gh-testimonials-grid-{{ section.id }} .gh-divider { display: block; width: 32px; height: 1px; margin: 18px 0 14px; }
  .gh-testimonials-grid-{{ section.id }} .gh-name { margin: 0; font: 400 17px/1.2 'EB Garamond', Georgia, serif; color: var(--gh-vine); }
  .gh-testimonials-grid-{{ section.id }} .gh-role { margin: 6px 0 0; font-size: 11px; color: var(--gh-muted); }
  @media (max-width: 768px) {
    .gh-testimonials-grid-{{ section.id }} { padding: 56px 20px; }
    .gh-testimonials-grid-{{ section.id }} .gh-grid { grid-template-columns: 1fr; }
  }
</style>
{% schema %}
{
  "name": "GH — Testimonials Grid",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "What our guests say" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Guest Stories" },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#FDF8F2" },
    { "type": "color", "id": "card_bg", "label": "Card background", "default": "#FFFFFF" },
    { "type": "color", "id": "accent_color", "label": "Quote mark + star colour", "default": "#B8913A" }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        { "type": "range", "id": "stars", "label": "Star rating", "min": 1, "max": 5, "step": 1, "default": 5 },
        { "type": "textarea", "id": "text", "label": "Testimonial text", "default": "Thank you soooooooooooo much for the most amazing food and function..." },
        { "type": "text", "id": "name", "label": "Reviewer name", "default": "Lydia R. Porto" },
        { "type": "text", "id": "role", "label": "Reviewer role", "default": "Operations Lead" }
      ]
    }
  ],
  "presets": [{ "name": "GH — Testimonials Grid", "blocks": [{ "type": "testimonial" }, { "type": "testimonial" }, { "type": "testimonial" }] }]
}
{% endschema %}
