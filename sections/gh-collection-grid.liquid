                  {% if part.is_link %}
                    <a href="{{ part.url }}" class="gh-page-btn">{{ part.title }}</a>
                  {% elsif part.title == paginate.current_page %}
                    <span class="gh-page-btn gh-page-active" aria-current="page">{{ part.title }}</span>
                  {% else %}
                    <span class="gh-page-btn gh-page-ellipsis">{{ part.title }}</span>
                  {% endif %}
                {% endfor %}

                {% if paginate.next %}
                  <a href="{{ paginate.next.url }}" class="gh-page-btn gh-page-next" aria-label="Next page">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <path d="M6 4L10 8L6 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
                    </svg>
                  </a>
                {% else %}
                  <span class="gh-page-btn gh-page-next gh-page-disabled" aria-disabled="true">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M6 4L10 8L6 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path></svg>
                  </span>
                {% endif %}
              </nav>
            {% endif %}
        </div>
      </div>
    {% endpaginate %}
  </div>
</section>

<style>
  .gh-collection-grid-{{ section.id }} {
    padding: 32px 40px 80px;
    background: {{ section.settings.bg_color | default: '#FDF8F2' }};
  }

  .gh-collection-grid-{{ section.id }} .gh-collection-grid-shell {
    width: min(1280px, 100%);
    margin: 0 auto;
  }

  .gh-collection-grid-{{ section.id }} .gh-layout {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 48px;
  }

  .gh-collection-grid-{{ section.id }} .gh-filter-sidebar {
    padding-right: 4px;
  }
  .gh-collection-grid-{{ section.id }} .gh-filter-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
  }
  .gh-collection-grid-{{ section.id }} .gh-filter-close {
    display: none;
    border: 0;
    background: transparent;
    color: #000000;
    font-size: 22px;
    line-height: 1;
    cursor: pointer;
    padding: 0;
  }
  .gh-collection-grid-{{ section.id }} .gh-mobile-filter-trigger {
    display: none;
    margin-bottom: 14px;
    padding: 9px 14px;
    border: 0.5px solid #000000;
    border-radius: 2px;
    background: #fff;
    color: #000000;
    font: 500 10px/1 'Inter', sans-serif;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    cursor: pointer;
  }
  .gh-collection-grid-{{ section.id }} .gh-filter-backdrop {
    display: none;
  }

  .gh-collection-grid-{{ section.id }} .gh-filter-title {
    margin: 0 0 16px;
    font: 500 10px/1.3 'Inter', sans-serif;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--gh-muted);
  }

  .gh-collection-grid-{{ section.id }} .gh-filter-group {
    border-bottom: 0.5px solid var(--gh-border);
    padding-bottom: 20px;
    margin-bottom: 20px;
  }

  .gh-collection-grid-{{ section.id }} .gh-filter-group-title {
    display: flex;
    align-items: center;
    justify-content: space-between;
    cursor: pointer;
    list-style: none;
    font: 500 10px/1.3 'Inter', sans-serif;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--gh-muted);
    padding: 0 0 12px;
  }

  .gh-collection-grid-{{ section.id }} .gh-filter-group summary::-webkit-details-marker {
    display: none;
  }

  .gh-collection-grid-{{ section.id }} .gh-filter-group[open] .gh-filter-chevron {
    transform: rotate(180deg);
  }

  .gh-collection-grid-{{ section.id }} .gh-filter-chevron {
    flex-shrink: 0;
  }

  .gh-collection-grid-{{ section.id }} .gh-filter-option {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 10px;
    cursor: pointer;
    font-size: 13px;
    color: #000000;
  }

  .gh-collection-grid-{{ section.id }} .gh-filter-option input[type='checkbox'] {
    position: absolute;
    opacity: 0;
    width: 0;
    height: 0;
  }

  .gh-collection-grid-{{ section.id }} .gh-filter-checkbox-ui {
    width: 14px;
    height: 14px;
    border: 0.5px solid rgba(28, 43, 26, 0.3);
    border-radius: 2px;
    flex-shrink: 0;
    background: #fff;
  }

  .gh-collection-grid-{{ section.id }} .gh-filter-option input:checked ~ .gh-filter-checkbox-ui {
    background: #000000;
    border-color: #000000;
  }

  .gh-collection-grid-{{ section.id }} .gh-filter-option input:disabled ~ .gh-filter-checkbox-ui {
    opacity: 0.35;
  }

  .gh-collection-grid-{{ section.id }} .gh-filter-option input:disabled ~ .gh-filter-label {
    opacity: 0.4;
  }

  .gh-collection-grid-{{ section.id }} .gh-filter-count {
    margin-left: auto;
    font-size: 11px;
    color: var(--gh-muted);
  }

  .gh-collection-grid-{{ section.id }} .gh-price-range {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-top: 8px;
    flex-wrap: wrap;
  }

  .gh-collection-grid-{{ section.id }} .gh-price-input {
    width: 72px;
    padding: 6px 8px;
    border: 0.5px solid var(--gh-border);
    border-radius: 2px;
    font-size: 12px;
    background: #fff;
    color: #000000;
  }

  .gh-collection-grid-{{ section.id }} .gh-price-apply {
    padding: 6px 12px;
    background: #000000;
    color: #F5EFE3;
    border: none;
    border-radius: 2px;
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    cursor: pointer;
  }

  .gh-collection-grid-{{ section.id }} .gh-price-hint {
    font-size: 11px;
    color: #6B7668;
    margin-top: 8px;
  }

  .gh-collection-grid-{{ section.id }} .gh-filter-submit-btn {
    width: 100%;
    margin-top: 16px;
    padding: 10px 12px;
    border: 0.5px solid #000000;
    border-radius: 2px;
    background: transparent;
    color: #000000;
    font: 500 10px/1 'Inter', sans-serif;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    cursor: pointer;
  }

  .gh-collection-grid-{{ section.id }} .gh-filter-tag {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 4px 10px;
    background: #F5EFE3;
    border: 0.5px solid var(--gh-border);
    border-radius: 20px;
    font-size: 11px;
    color: #000000;
    margin: 0 6px 6px 0;
    text-decoration: none;
  }

  .gh-collection-grid-{{ section.id }} .gh-filter-clear-all {
    display: block;
    font-size: 11px;
    color: #B8913A;
    letter-spacing: 0.08em;
    margin-bottom: 16px;
    text-decoration: underline;
  }

  .gh-collection-grid-{{ section.id }} .gh-collection-toolbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 28px;
    padding-bottom: 16px;
    border-bottom: 0.5px solid var(--gh-border);
  }

  .gh-collection-grid-{{ section.id }} .gh-products-count {
    font-size: 12px;
    color: #6B7668;
    margin: 0;
  }

  .gh-collection-grid-{{ section.id }} .gh-sort-row {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 12px;
    color: #6B7668;
  }

  .gh-collection-grid-{{ section.id }} .gh-sort-select {
    padding: 7px 12px;
    border: 0.5px solid var(--gh-border);
    border-radius: 2px;
    font-size: 12px;
    font-family: 'Inter', sans-serif;
    background: #fff;
    color: #000000;
    cursor: pointer;
    outline: none;
  }

  .gh-collection-grid-{{ section.id }} .gh-sort-select:focus {
    border-color: #B8913A;
  }

  .gh-collection-grid-{{ section.id }} .gh-product-grid {
    display: grid;
    grid-template-columns: repeat(var(--gh-columns), minmax(0, 1fr));
    gap: 24px;
    align-items: stretch;
  }

  .gh-collection-grid-{{ section.id }} .gh-pagination {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    margin-top: 52px;
    padding-top: 32px;
    border-top: 0.5px solid var(--gh-border);
  }

  .gh-collection-grid-{{ section.id }} .gh-page-btn {
    width: 36px;
    height: 36px;
    border: 0.5px solid var(--gh-border);
    border-radius: 2px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 13px;
    color: #000000;
    background: #fff;
    text-decoration: none;
    flex-shrink: 0;
  }

  .gh-collection-grid-{{ section.id }} .gh-page-active {
    background: #000000;
    color: #F5EFE3;
    border-color: #000000;
    cursor: default;
  }

  .gh-collection-grid-{{ section.id }} .gh-page-disabled {
    opacity: 0.35;
    cursor: not-allowed;
    pointer-events: none;
  }

  .gh-collection-grid-{{ section.id }} .gh-page-ellipsis {
    border-color: transparent;
    background: transparent;
    cursor: default;
  }

  .gh-collection-grid-{{ section.id }} .gh-page-prev,
  .gh-collection-grid-{{ section.id }} .gh-page-next {
    color: #6B7668;
  }

  @media (prefers-reduced-motion: no-preference) {
    .gh-collection-grid-{{ section.id }} .gh-filter-chevron {
      transition: transform 0.2s;
    }

    .gh-collection-grid-{{ section.id }} .gh-page-btn {
      transition: all 0.2s;
    }

    .gh-collection-grid-{{ section.id }} .gh-page-btn:hover:not(.gh-page-active):not(.gh-page-disabled) {
      border-color: #000000;
      background: #F5EFE3;
    }
  }

  @media (max-width: 768px) {
    .gh-collection-grid-{{ section.id }} {
      padding: 56px 20px;
    }

    .gh-collection-grid-{{ section.id }} .gh-layout {
      grid-template-columns: 1fr;
      gap: 20px;
    }

    .gh-collection-grid-{{ section.id }} .gh-mobile-filter-trigger {
      display: inline-flex;
      align-items: center;
      justify-content: center;
    }

    .gh-collection-grid-{{ section.id }} .gh-filter-sidebar {
      position: fixed;
      top: 0;
      left: 0;
      bottom: 0;
      width: min(88vw, 360px);
      max-width: 100%;
      background: #fff;
      z-index: 120;
      overflow-y: auto;
      padding: 20px;
      transform: translateX(-102%);
      transition: transform 0.25s ease;
      box-shadow: 8px 0 30px rgb(0 0 0 / 0.2);
      white-space: normal;
    }

    .gh-collection-grid-{{ section.id }} .gh-filter-close {
      display: inline-flex;
      align-items: center;
      justify-content: center;
    }

    .gh-collection-grid-{{ section.id }} .gh-filter-backdrop {
      position: fixed;
      inset: 0;
      background: rgb(0 0 0 / 0.35);
      z-index: 110;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.2s ease;
    }

    .gh-collection-grid-{{ section.id }}[data-mobile-filter-open='true'] .gh-filter-sidebar {
      transform: translateX(0);
    }

    .gh-collection-grid-{{ section.id }}[data-mobile-filter-open='true'] .gh-filter-backdrop {
      opacity: 1;
      pointer-events: auto;
      display: block;
    }

    .gh-collection-grid-{{ section.id }} .gh-collection-toolbar {
      flex-direction: column;
      align-items: flex-start;
      gap: 10px;
    }

    .gh-collection-grid-{{ section.id }} .gh-product-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 14px;
    }
  }
</style>

<script>
  (function () {
    var root = document.getElementById('gh-collection-grid-{{ section.id }}');
    if (!root) return;
    var openBtn = root.querySelector('.js-gh-filter-open');
    var closeBtn = root.querySelector('.js-gh-filter-close');
    var backdrop = root.querySelector('.js-gh-filter-backdrop');
    if (!openBtn) return;

    function setOpen(next) {
      root.setAttribute('data-mobile-filter-open', next ? 'true' : 'false');
      document.documentElement.style.overflow = next ? 'hidden' : '';
    }

    openBtn.addEventListener('click', function () { setOpen(true); });
    if (closeBtn) closeBtn.addEventListener('click', function () { setOpen(false); });
    if (backdrop) backdrop.addEventListener('click', function () { setOpen(false); });

    root.querySelectorAll('.gh-filter-sidebar a').forEach(function (el) {
      el.addEventListener('click', function () { setOpen(false); });
    });
  })();
</script>

{% schema %}
{
  "name": "GH — Collection Grid",
  "settings": [
    { "type": "range", "id": "products_per_page", "label": "Products per page", "min": 6, "max": 24, "step": 3, "default": 9 },
    { "type": "checkbox", "id": "show_filters", "label": "Show filter sidebar", "default": true },
    {
      "type": "select",
      "id": "grid_columns",
      "label": "Grid columns",
      "default": "3",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" }
      ]
    },
    { "type": "color", "id": "bg_color", "label": "Page background", "default": "#FDF8F2" }
  ],
  "presets": [{ "name": "GH — Collection Grid" }]
}
{% endschema %}
