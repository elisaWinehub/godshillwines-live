{%- render 'gh-tokens' -%}

<section class="gh-collection-grid-{{ section.id }}" style="--gh-columns: {{ section.settings.grid_columns }};">
  <div class="gh-collection-grid-shell">
    <form method="get" action="{{ collection.url }}">
      <div class="gh-active-tags">
        {% if collection.filters %}
          {% for filter in collection.filters %}
            {% for value in filter.active_values %}
              <a class="gh-filter-tag" href="{{ value.url_to_remove }}">{{ value.label }} x</a>
            {% endfor %}
          {% endfor %}
        {% endif %}
      </div>

      <div class="gh-layout">
        {% if section.settings.show_filters %}
          <aside class="gh-sidebar">
            {% for filter in collection.filters %}
              <details class="gh-filter-group" open>
                <summary class="gh-filter-group-title">{{ filter.label }}</summary>
                <div class="gh-filter-body">
                  {% case filter.type %}
                    {% when 'boolean', 'list' %}
                      {% for value in filter.values %}
                        <label class="gh-filter-option">
                          <input
                            type="checkbox"
                            name="{{ value.param_name }}"
                            value="{{ value.value }}"
                            {% if value.active %}
                              checked
                            {% endif %}
                            onchange="this.closest('form').submit()"
                          >
                          <span class="gh-filter-label">{{ value.label }}</span>
                          <span class="gh-filter-count">{{ value.count }}</span>
                        </label>
                      {% endfor %}
                    {% when 'price_range' %}
                      <div class="gh-price-range">
                        <span>$</span>
                        <input
                          class="gh-price-input"
                          type="number"
                          name="{{ filter.min_value.param_name }}"
                          value="{{ filter.min_value.value | money_without_currency | remove: ',' }}"
                          placeholder="0"
                        >
                        <span>to</span>
                        <span>$</span>
                        <input
                          class="gh-price-input"
                          type="number"
                          name="{{ filter.max_value.param_name }}"
                          value="{{ filter.max_value.value | money_without_currency | remove: ',' }}"
                          placeholder="{{ collection.products.first.price_max | money_without_currency | remove: ',' }}"
                        >
                      </div>
                  {% endcase %}
                </div>
              </details>
            {% endfor %}
          </aside>
        {% endif %}

        <div class="gh-products-panel">
          {% paginate collection.products by section.settings.products_per_page %}
            <div class="gh-product-grid">
              {% for product in collection.products %}
                {%- render 'gh-product-card', product: product -%}
              {% else %}
                <p>No products found.</p>
              {% endfor %}
            </div>

            {% if paginate.pages > 1 %}
              <div class="gh-pagination">
                {{ paginate | default_pagination | replace: '<span class="deco">&hellip;</span>', '...' }}
              </div>
            {% endif %}
          {% endpaginate %}
        </div>
      </div>
    </form>
  </div>
</section>

<style>
  .gh-collection-grid-{{ section.id }} {
    padding: 32px 40px 80px;
    background: {{ section.settings.bg_color | default: '#FDF8F2' }};
  }

  .gh-collection-grid-{{ section.id }} .gh-collection-grid-shell {
    width: min(1280px, 100%);
    margin: 0 auto;
  }

  .gh-collection-grid-{{ section.id }} .gh-layout {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 48px;
  }

  .gh-collection-grid-{{ section.id }} .gh-active-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 16px;
  }

  .gh-collection-grid-{{ section.id }} .gh-filter-tag {
    border: 0.5px solid var(--gh-border);
    color: var(--gh-vine);
    font: 500 11px/1.3 'Inter', sans-serif;
    text-decoration: none;
    padding: 6px 10px;
    border-radius: 20px;
    background: #fff;
  }

  .gh-collection-grid-{{ section.id }} .gh-filter-group {
    border-bottom: 0.5px solid var(--gh-border);
    padding: 10px 0;
  }

  .gh-collection-grid-{{ section.id }} .gh-filter-group-title {
    font: 600 12px/1.4 'Inter', sans-serif;
    color: var(--gh-vine);
    cursor: pointer;
  }

  .gh-collection-grid-{{ section.id }} .gh-filter-option {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 8px;
    align-items: center;
    font: 400 12px/1.4 'Inter', sans-serif;
    color: var(--gh-muted);
    margin: 8px 0;
  }

  .gh-collection-grid-{{ section.id }} .gh-price-range {
    display: grid;
    grid-template-columns: auto 1fr auto auto 1fr;
    gap: 6px;
    align-items: center;
    margin-top: 8px;
  }

  .gh-collection-grid-{{ section.id }} .gh-price-input {
    border: 0.5px solid var(--gh-border);
    padding: 7px 8px;
    border-radius: 2px;
  }

  .gh-collection-grid-{{ section.id }} .gh-product-grid {
    display: grid;
    grid-template-columns: repeat(var(--gh-columns), minmax(0, 1fr));
    gap: 24px;
  }

  .gh-collection-grid-{{ section.id }} .gh-product-card {
    background: #fff;
    border: 0.5px solid var(--gh-border);
    border-radius: 4px;
    overflow: hidden;
  }

  .gh-collection-grid-{{ section.id }} .gh-product-card__image-wrap {
    position: relative;
    display: block;
    height: 280px;
    background: var(--gh-cream);
    overflow: hidden;
  }

  .gh-collection-grid-{{ section.id }} .gh-product-card__image {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 24px;
  }

  .gh-collection-grid-{{ section.id }} .gh-product-card__badge {
    position: absolute;
    top: 12px;
    left: 12px;
    z-index: 2;
    font: 700 9px/1 'Inter', sans-serif;
    letter-spacing: 0.08em;
    padding: 6px 8px;
    color: #fff;
    text-transform: uppercase;
    border-radius: 2px;
  }

  .gh-collection-grid-{{ section.id }} .gh-product-card__badge--sold {
    background: var(--gh-vine);
  }

  .gh-collection-grid-{{ section.id }} .gh-product-card__badge--sale {
    background: var(--gh-gold);
  }

  .gh-collection-grid-{{ section.id }} .gh-product-card__body {
    padding: 18px;
  }

  .gh-collection-grid-{{ section.id }} .gh-product-card__variety {
    margin: 0 0 6px;
    font: 600 10px/1.2 'Inter', sans-serif;
    color: var(--gh-muted);
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }

  .gh-collection-grid-{{ section.id }} .gh-product-card__title {
    margin: 0 0 10px;
    font: 400 19px/1.2 'EB Garamond', Georgia, serif;
  }

  .gh-collection-grid-{{ section.id }} .gh-product-card__title a {
    color: var(--gh-vine);
    text-decoration: none;
  }

  .gh-collection-grid-{{ section.id }} .gh-product-card__row {
    display: flex;
    align-items: baseline;
    gap: 8px;
    margin-bottom: 12px;
  }

  .gh-collection-grid-{{ section.id }} .gh-product-card__price {
    font: 400 20px/1 'EB Garamond', Georgia, serif;
    color: var(--gh-vine);
  }

  .gh-collection-grid-{{ section.id }} .gh-product-card__compare {
    color: var(--gh-muted);
    text-decoration: line-through;
    font-size: 12px;
  }

  .gh-collection-grid-{{ section.id }} .gh-product-card__actions {
    display: flex;
    gap: 8px;
  }

  .gh-collection-grid-{{ section.id }} .gh-product-card__qty {
    display: flex;
    border: 0.5px solid var(--gh-border);
  }

  .gh-collection-grid-{{ section.id }} .gh-product-card__qty button,
  .gh-collection-grid-{{ section.id }} .gh-product-card__qty input {
    width: 30px;
    height: 34px;
    border: none;
    background: #fff;
    text-align: center;
  }

  .gh-collection-grid-{{ section.id }} .gh-product-card__btn {
    flex: 1;
    border: 1px solid var(--gh-gold);
    color: var(--gh-gold);
    background: transparent;
    font: 600 12px/1 'Inter', sans-serif;
    cursor: pointer;
    padding: 9px 12px;
  }

  .gh-collection-grid-{{ section.id }} .gh-product-card__btn--sold {
    border-color: var(--gh-muted);
    color: var(--gh-muted);
    cursor: not-allowed;
  }

  .gh-collection-grid-{{ section.id }} .gh-pagination {
    margin-top: 28px;
  }

  @media (prefers-reduced-motion: no-preference) {
    .gh-collection-grid-{{ section.id }} .gh-product-card {
      transition: transform 0.25s ease, box-shadow 0.25s ease;
    }

    .gh-collection-grid-{{ section.id }} .gh-product-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 12px 40px rgba(28, 43, 26, 0.1);
    }

    .gh-collection-grid-{{ section.id }} .gh-product-card__btn {
      transition: background-color 0.2s ease, color 0.2s ease;
    }

    .gh-collection-grid-{{ section.id }} .gh-product-card__btn:hover:not(:disabled) {
      background: var(--gh-gold);
      color: #fff;
    }
  }

  @media (max-width: 768px) {
    .gh-collection-grid-{{ section.id }} {
      padding: 56px 20px;
    }

    .gh-collection-grid-{{ section.id }} .gh-layout {
      grid-template-columns: 1fr;
      gap: 20px;
    }

    .gh-collection-grid-{{ section.id }} .gh-sidebar {
      overflow-x: auto;
      white-space: nowrap;
      display: flex;
      gap: 10px;
      padding-bottom: 10px;
    }

    .gh-collection-grid-{{ section.id }} .gh-filter-group {
      min-width: 220px;
      border: 0.5px solid var(--gh-border);
      border-radius: 4px;
      padding: 8px;
      background: #fff;
    }

    .gh-collection-grid-{{ section.id }} .gh-product-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

{% schema %}
{
  "name": "GH — Collection Grid",
  "settings": [
    { "type": "range", "id": "products_per_page", "label": "Products per page", "min": 6, "max": 24, "step": 3, "default": 9 },
    { "type": "checkbox", "id": "show_filters", "label": "Show filter sidebar", "default": true },
    {
      "type": "select",
      "id": "grid_columns",
      "label": "Grid columns",
      "default": "3",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" }
      ]
    },
    { "type": "color", "id": "bg_color", "label": "Page background", "default": "#FDF8F2" }
  ],
  "presets": [{ "name": "GH — Collection Grid" }]
}
{% endschema %}
