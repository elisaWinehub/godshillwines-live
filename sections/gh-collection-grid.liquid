{% comment %}
{%- render 'gh-tokens' -%}
<section id="gh-collection-grid-{{ section.id }}" class="gh-collection-grid-{{ section.id }}" style="--gh-columns: {{ section.settings.grid_columns }};">
  <div class="gh-collection-grid-shell">
    {% paginate collection.products by section.settings.products_per_page %}
      <form id="gh-filter-form-{{ section.id }}" method="get" action="{{ collection.url }}">
        {% if collection.sort_by != blank %}
          <input type="hidden" name="sort_by" value="{{ collection.sort_by }}">
        {% endif %}

        <div class="gh-layout">
          {% if section.settings.show_filters %}
            <aside class="gh-filter-sidebar">
              <h2 class="gh-filter-title">Filters</h2>

              {% assign active_count = 0 %}
              {% for filter in collection.filters %}
                {% for value in filter.active_values %}
                  {% assign active_count = active_count | plus: 1 %}
                  <a href="{{ value.url_to_remove }}" class="gh-filter-tag">
                    {{ filter.label }}: {{ value.label }}
                    <span class="gh-filter-tag-remove" aria-hidden="true">
                      <svg width="10" height="10" viewBox="0 0 10 10" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M1 1L9 9M9 1L1 9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"></path>
                      </svg>
                    </span>
                  </a>
                {% endfor %}
                {% if filter.type == 'price_range' %}
                  {% if filter.min_value.value != nil or filter.max_value.value != nil %}
                    {% assign active_count = active_count | plus: 1 %}
                  {% endif %}
                {% endif %}
              {% endfor %}
              {% if active_count > 0 %}
                <a href="{{ collection.url }}" class="gh-filter-clear-all">Clear all</a>
              {% endif %}

              {% for filter in collection.filters %}
                <details class="gh-filter-group" open>
                  <summary class="gh-filter-group-title">
                    {{ filter.label }}
                    <svg class="gh-filter-chevron" width="12" height="12" viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <path d="M2 4L6 8L10 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
                    </svg>
                  </summary>
                  <div class="gh-filter-body">
                    {% case filter.type %}
                      {% when 'boolean', 'list' %}
                        {% for value in filter.values %}
                          <label class="gh-filter-option">
                            <input
                              type="checkbox"
                              name="{{ value.param_name }}"
                              value="{{ value.value }}"
                              {% if value.active %}checked{% endif %}
                              {% if value.count == 0 and value.active == false %}disabled{% endif %}
                              onchange="document.getElementById('gh-filter-form-{{ section.id }}').submit()">
                            <span class="gh-filter-checkbox-ui" aria-hidden="true"></span>
                            <span class="gh-filter-label">{{ value.label }}</span>
                            <span class="gh-filter-count">({{ value.count }})</span>
                          </label>
                        {% endfor %}
                      {% when 'price_range' %}
                        <div class="gh-price-range">
                          <span class="gh-price-symbol">$</span>
                          <input
                            type="number"
                            name="{{ filter.min_value.param_name }}"
                            value="{% if filter.min_value.value %}{{ filter.min_value.value | money_without_currency | remove: ',' }}{% endif %}"
                            placeholder="0"
                            class="gh-price-input"
                            min="0"
                            max="{{ filter.range_max | money_without_currency | remove: ',' }}">
                          <span class="gh-price-sep">to</span>
                          <span class="gh-price-symbol">$</span>
                          <input
                            type="number"
                            name="{{ filter.max_value.param_name }}"
                            value="{% if filter.max_value.value %}{{ filter.max_value.value | money_without_currency | remove: ',' }}{% endif %}"
                            placeholder="{{ filter.range_max | money_without_currency | remove: ',' }}"
                            class="gh-price-input"
                            min="0"
                            max="{{ filter.range_max | money_without_currency | remove: ',' }}">
                          <button type="submit" class="gh-price-apply">Apply</button>
                        </div>
                        <p class="gh-price-hint">Highest price: {{ filter.range_max | money }}</p>
                    {% endcase %}
                  </div>
                </details>
              {% endfor %}

              <button type="button" class="gh-filter-submit-btn" onclick="document.getElementById('gh-filter-form-{{ section.id }}').submit()">Apply filters</button>
            </aside>
          {% endif %}

          <div class="gh-collection-products">
            <div class="gh-collection-toolbar">
              <p class="gh-products-count"><strong>{{ collection.products_count }}</strong> products</p>
              <div class="gh-sort-row">
                <label for="gh-sort-select-{{ section.id }}" class="gh-sort-label">Sort by</label>
                <select id="gh-sort-select-{{ section.id }}" class="gh-sort-select" onchange="location='{{ collection.url }}?sort_by='+this.value+'{{ collection.filter_query }}'">
                  {% for option in collection.sort_options %}
                    <option value="{{ option.value }}" {% if collection.sort_by == option.value %}selected{% endif %}>{{ option.name }}</option>
                  {% endfor %}
                </select>
              </div>
            </div>

            <div class="gh-product-grid">
              {% for product in collection.products %}
                {%- render 'gh-product-card', product: product -%}
              {% else %}
                <p>No products found.</p>
              {% endfor %}
            </div>

            {% if paginate.pages > 1 %}
              <nav class="gh-pagination" aria-label="Pagination">
                {% if paginate.previous %}
                  <a href="{{ paginate.previous.url }}" class="gh-page-btn gh-page-prev" aria-label="Previous page">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <path d="M10 12L6 8L10 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
                    </svg>
                  </a>
                {% else %}
                  <span class="gh-page-btn gh-page-prev gh-page-disabled" aria-disabled="true">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M10 12L6 8L10 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path></svg>
                  </span>
                {% endif %}

                {% for part in paginate.parts %}
                  {% if part.is_link %}
                    <a href="{{ part.url }}" class="gh-page-btn">{{ part.title }}</a>
                  {% elsif part.title == paginate.current_page %}
                    <span class="gh-page-btn gh-page-active" aria-current="page">{{ part.title }}</span>
                  {% else %}
                    <span class="gh-page-btn gh-page-ellipsis">{{ part.title }}</span>
                  {% endif %}
                {% endfor %}

                {% if paginate.next %}
                  <a href="{{ paginate.next.url }}" class="gh-page-btn gh-page-next" aria-label="Next page">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <path d="M6 4L10 8L6 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
                    </svg>
                  </a>
                {% else %}
                  <span class="gh-page-btn gh-page-next gh-page-disabled" aria-disabled="true">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M6 4L10 8L6 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path></svg>
                  </span>
                {% endif %}
              </nav>
            {% endif %}
          </div>
        </div>
      </form>
    {% endpaginate %}
  </div>
</section>

<style>
  .gh-collection-grid-{{ section.id }} {
    padding: 32px 40px 80px;
    background: {{ section.settings.bg_color | default: '#FDF8F2' }};
  }

  .gh-collection-grid-{{ section.id }} .gh-collection-grid-shell {
    width: min(1280px, 100%);
    margin: 0 auto;
  }

  .gh-collection-grid-{{ section.id }} .gh-layout {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 48px;
  }

  .gh-collection-grid-{{ section.id }} .gh-filter-sidebar {
    padding-right: 4px;
  }

  .gh-collection-grid-{{ section.id }} .gh-filter-title {
    margin: 0 0 16px;
    font: 500 10px/1.3 'Inter', sans-serif;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--gh-muted);
  }

  .gh-collection-grid-{{ section.id }} .gh-filter-group {
    border-bottom: 0.5px solid var(--gh-border);
    padding-bottom: 20px;
    margin-bottom: 20px;
  }

  .gh-collection-grid-{{ section.id }} .gh-filter-group-title {
    display: flex;
    align-items: center;
    justify-content: space-between;
    cursor: pointer;
    list-style: none;
    font: 500 10px/1.3 'Inter', sans-serif;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--gh-muted);
    padding: 0 0 12px;
  }

  .gh-collection-grid-{{ section.id }} .gh-filter-group summary::-webkit-details-marker {
    display: none;
  }

  .gh-collection-grid-{{ section.id }} .gh-filter-group[open] .gh-filter-chevron {
    transform: rotate(180deg);
  }

  .gh-collection-grid-{{ section.id }} .gh-filter-chevron {
    flex-shrink: 0;
  }

  .gh-collection-grid-{{ section.id }} .gh-filter-option {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 10px;
    cursor: pointer;
    font-size: 13px;
    color: #000000;
  }

  .gh-collection-grid-{{ section.id }} .gh-filter-option input[type='checkbox'] {
    position: absolute;
    opacity: 0;
    width: 0;
    height: 0;
  }

  .gh-collection-grid-{{ section.id }} .gh-filter-checkbox-ui {
    width: 14px;
    height: 14px;
    border: 0.5px solid rgba(28, 43, 26, 0.3);
    border-radius: 2px;
    flex-shrink: 0;
    background: #fff;
  }

  .gh-collection-grid-{{ section.id }} .gh-filter-option input:checked ~ .gh-filter-checkbox-ui {
    background: #000000;
    border-color: #000000;
  }

  .gh-collection-grid-{{ section.id }} .gh-filter-option input:disabled ~ .gh-filter-checkbox-ui {
    opacity: 0.35;
  }

  .gh-collection-grid-{{ section.id }} .gh-filter-option input:disabled ~ .gh-filter-label {
    opacity: 0.4;
  }

  .gh-collection-grid-{{ section.id }} .gh-filter-count {
    margin-left: auto;
    font-size: 11px;
    color: var(--gh-muted);
  }

  .gh-collection-grid-{{ section.id }} .gh-price-range {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-top: 8px;
    flex-wrap: wrap;
  }

  .gh-collection-grid-{{ section.id }} .gh-price-input {
    width: 72px;
    padding: 6px 8px;
    border: 0.5px solid var(--gh-border);
    border-radius: 2px;
    font-size: 12px;
    background: #fff;
    color: #000000;
  }

  .gh-collection-grid-{{ section.id }} .gh-price-apply {
    padding: 6px 12px;
    background: #000000;
    color: #F5EFE3;
    border: none;
    border-radius: 2px;
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    cursor: pointer;
  }

  .gh-collection-grid-{{ section.id }} .gh-price-hint {
    font-size: 11px;
    color: #6B7668;
    margin-top: 8px;
  }

  .gh-collection-grid-{{ section.id }} .gh-filter-submit-btn {
    width: 100%;
    margin-top: 16px;
    padding: 10px 12px;
    border: 0.5px solid #000000;
    border-radius: 2px;
    background: transparent;
    color: #000000;
    font: 500 10px/1 'Inter', sans-serif;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    cursor: pointer;
  }

  .gh-collection-grid-{{ section.id }} .gh-filter-tag {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 4px 10px;
    background: #F5EFE3;
    border: 0.5px solid var(--gh-border);
    border-radius: 20px;
    font-size: 11px;
    color: #000000;
    margin: 0 6px 6px 0;
    text-decoration: none;
  }

  .gh-collection-grid-{{ section.id }} .gh-filter-clear-all {
    display: block;
    font-size: 11px;
    color: #B8913A;
    letter-spacing: 0.08em;
    margin-bottom: 16px;
    text-decoration: underline;
  }

  .gh-collection-grid-{{ section.id }} .gh-collection-toolbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 28px;
    padding-bottom: 16px;
    border-bottom: 0.5px solid var(--gh-border);
  }

  .gh-collection-grid-{{ section.id }} .gh-products-count {
    font-size: 12px;
    color: #6B7668;
    margin: 0;
  }

  .gh-collection-grid-{{ section.id }} .gh-sort-row {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 12px;
    color: #6B7668;
  }

  .gh-collection-grid-{{ section.id }} .gh-sort-select {
    padding: 7px 12px;
    border: 0.5px solid var(--gh-border);
    border-radius: 2px;
    font-size: 12px;
    font-family: 'Inter', sans-serif;
    background: #fff;
    color: #000000;
    cursor: pointer;
    outline: none;
  }

  .gh-collection-grid-{{ section.id }} .gh-sort-select:focus {
    border-color: #B8913A;
  }

  .gh-collection-grid-{{ section.id }} .gh-product-grid {
    display: grid;
    grid-template-columns: repeat(var(--gh-columns), minmax(0, 1fr));
    gap: 24px;
    align-items: stretch;
  }

  .gh-collection-grid-{{ section.id }} .gh-pagination {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    margin-top: 52px;
    padding-top: 32px;
    border-top: 0.5px solid var(--gh-border);
  }

  .gh-collection-grid-{{ section.id }} .gh-page-btn {
    width: 36px;
    height: 36px;
    border: 0.5px solid var(--gh-border);
    border-radius: 2px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 13px;
    color: #000000;
    background: #fff;
    text-decoration: none;
    flex-shrink: 0;
  }

  .gh-collection-grid-{{ section.id }} .gh-page-active {
    background: #000000;
    color: #F5EFE3;
    border-color: #000000;
    cursor: default;
  }

  .gh-collection-grid-{{ section.id }} .gh-page-disabled {
    opacity: 0.35;
    cursor: not-allowed;
    pointer-events: none;
  }

  .gh-collection-grid-{{ section.id }} .gh-page-ellipsis {
    border-color: transparent;
    background: transparent;
    cursor: default;
  }

  .gh-collection-grid-{{ section.id }} .gh-page-prev,
  .gh-collection-grid-{{ section.id }} .gh-page-next {
    color: #6B7668;
  }

  @media (prefers-reduced-motion: no-preference) {
    .gh-collection-grid-{{ section.id }} .gh-filter-chevron {
      transition: transform 0.2s;
    }

    .gh-collection-grid-{{ section.id }} .gh-page-btn {
      transition: all 0.2s;
    }

    .gh-collection-grid-{{ section.id }} .gh-page-btn:hover:not(.gh-page-active):not(.gh-page-disabled) {
      border-color: #000000;
      background: #F5EFE3;
    }
  }

  @media (max-width: 768px) {
    .gh-collection-grid-{{ section.id }} {
      padding: 56px 20px;
    }

    .gh-collection-grid-{{ section.id }} .gh-layout {
      grid-template-columns: 1fr;
      gap: 20px;
    }

    .gh-collection-grid-{{ section.id }} .gh-filter-sidebar {
      overflow-x: auto;
      white-space: nowrap;
      display: flex;
      align-items: flex-start;
      gap: 10px;
      padding-bottom: 10px;
    }

    .gh-collection-grid-{{ section.id }} .gh-filter-title,
    .gh-collection-grid-{{ section.id }} .gh-filter-clear-all {
      display: none;
    }

    .gh-collection-grid-{{ section.id }} .gh-filter-group {
      min-width: 220px;
      border: 0.5px solid var(--gh-border);
      border-radius: 4px;
      padding: 8px;
      background: #fff;
    }

    .gh-collection-grid-{{ section.id }} .gh-collection-toolbar {
      flex-direction: column;
      align-items: flex-start;
      gap: 10px;
    }

    .gh-collection-grid-{{ section.id }} .gh-product-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

{% schema %}
{
  "name": "GH — Collection Grid",
  "settings": [
    { "type": "range", "id": "products_per_page", "label": "Products per page", "min": 6, "max": 24, "step": 3, "default": 9 },
    { "type": "checkbox", "id": "show_filters", "label": "Show filter sidebar", "default": true },
    {
      "type": "select",
      "id": "grid_columns",
      "label": "Grid columns",
      "default": "3",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" }
      ]
    },
    { "type": "color", "id": "bg_color", "label": "Page background", "default": "#FDF8F2" }
  ],
  "presets": [{ "name": "GH — Collection Grid" }]
}
{% endschema %}
{% endcomment %}
{%- render 'gh-tokens' -%}
<section class="gh-collection-grid-{{ section.id }}" style="--gh-columns: {{ section.settings.grid_columns }};">
  <div class="gh-collection-grid-shell">
    {% paginate collection.products by section.settings.products_per_page %}
