{%- render 'gh-tokens' -%}
<style>
  .gh-wc-tiers-{{ section.id }} {
    --ruby: #8B1A2E;
    --pearl: #4A6888;
    background: {{ section.settings.bg_color | default: '#FDF8F2' }};
    padding: 96px 40px;
  }
  .gh-wc-tiers-{{ section.id }} .gh-wc-tiers-inner { width: min(1280px, 100%); margin: 0 auto; }
  .gh-wc-tiers-{{ section.id }} .gh-wc-tiers-head { text-align: center; max-width: 860px; margin: 0 auto 34px; }
  .gh-wc-tiers-{{ section.id }} .gh-wc-tiers-eyebrow { margin: 0 0 10px; font: 500 11px/1.4 'Inter', sans-serif; letter-spacing: .14em; text-transform: uppercase; color: #B8913A; }
  .gh-wc-tiers-{{ section.id }} .gh-wc-tiers-title { margin: 0 0 10px; font: 400 clamp(30px, 4vw, 50px)/1.1 'EB Garamond', Georgia, serif; color: #000000; }
  .gh-wc-tiers-{{ section.id }} .gh-wc-tiers-subtitle { margin: 0; font: 400 14px/1.75 'Inter', sans-serif; color: #6B7668; }
  .gh-wc-tiers-{{ section.id }} .gh-wc-tier-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 28px; }

  .gh-wc-tiers-{{ section.id }} .gh-wc-tier-card { background: #fff; border: 0.5px solid rgba(28,43,26,0.1); border-radius: 4px; overflow: hidden; }
  .gh-wc-tiers-{{ section.id }} .gh-wc-tier-header { color: #F5EFE3; padding: 20px 20px 18px; position: relative; }
  .gh-wc-tiers-{{ section.id }} .gh-wc-tier-label { margin: 0 0 4px; font: 500 10px/1.3 'Inter', sans-serif; letter-spacing: .14em; text-transform: uppercase; opacity: .9; }
  .gh-wc-tiers-{{ section.id }} .gh-wc-tier-name { margin: 0; font: 400 34px/1.05 'EB Garamond', Georgia, serif; }
  .gh-wc-tiers-{{ section.id }} .gh-wc-tier-tagline { margin: 6px 0 0; font: 400 13px/1.6 'Inter', sans-serif; opacity: .92; }
  .gh-wc-tiers-{{ section.id }} .gh-wc-tier-badge { position: absolute; top: 14px; right: 14px; border: 0.5px solid rgba(255,255,255,0.45); border-radius: 30px; padding: 3px 9px; font: 500 10px/1.3 'Inter', sans-serif; letter-spacing: .08em; text-transform: uppercase; }

  .gh-wc-tiers-{{ section.id }} .gh-wc-tier-body { padding: 18px 20px 20px; }
  .gh-wc-tiers-{{ section.id }} .gh-wc-tier-commitment { background: #FDF8F2; border: 0.5px solid rgba(28,43,26,0.08); border-radius: 3px; padding: 12px; margin-bottom: 14px; }
  .gh-wc-tiers-{{ section.id }} .gh-wc-tier-commitment strong { font: 600 13px/1.4 'Inter', sans-serif; color: #000000; display: block; margin-bottom: 6px; }
  .gh-wc-tiers-{{ section.id }} .gh-wc-tier-commitment p { margin: 0; font: 400 12px/1.7 'Inter', sans-serif; color: #6B7668; }

  .gh-wc-tiers-{{ section.id }} .gh-wc-perks { list-style: none; margin: 0 0 14px; padding: 0; display: grid; gap: 10px; }
  .gh-wc-tiers-{{ section.id }} .gh-wc-perk { display: grid; grid-template-columns: 14px 1fr; gap: 10px; align-items: start; }
  .gh-wc-tiers-{{ section.id }} .gh-wc-perk-title { margin: 0; font: 600 12px/1.5 'Inter', sans-serif; color: #000000; }
  .gh-wc-tiers-{{ section.id }} .gh-wc-perk-subtitle { margin: 0; font: 400 11px/1.6 'Inter', sans-serif; color: #6B7668; }

  .gh-wc-tiers-{{ section.id }} .gh-wc-tier-btn { display: inline-block; width: 100%; text-align: center; border-radius: 3px; text-decoration: none; padding: 12px 14px; font: 500 12px/1.4 'Inter', sans-serif; letter-spacing: .08em; text-transform: uppercase; color: #F5EFE3; }
  .gh-wc-tiers-{{ section.id }} .gh-wc-tier-btn--ruby { background: {{ section.settings.ruby_header_color | default: '#8B1A2E' }}; }
  .gh-wc-tiers-{{ section.id }} .gh-wc-tier-btn--pearl { background: {{ section.settings.pearl_header_color | default: '#4A6888' }}; }

  @media (prefers-reduced-motion: no-preference) {
    .gh-wc-tiers-{{ section.id }} .gh-wc-tier-card { transition: transform .22s ease, box-shadow .22s ease; }
    .gh-wc-tiers-{{ section.id }} .gh-wc-tier-card:hover { transform: translateY(-3px); box-shadow: 0 12px 24px rgba(0,0,0,0.08); }
  }

  @media (max-width: 1024px) {
    .gh-wc-tiers-{{ section.id }} { padding: 70px 20px; }
    .gh-wc-tiers-{{ section.id }} .gh-wc-tier-grid { grid-template-columns: 1fr; }
  }
</style>

<section class="gh-wc-tiers-{{ section.id }}">
  <div class="gh-wc-tiers-inner">
    <div class="gh-wc-tiers-head">
      <p class="gh-wc-tiers-eyebrow">{{ section.settings.eyebrow }}</p>
      <h2 class="gh-wc-tiers-title">{{ section.settings.heading }}</h2>
      <p class="gh-wc-tiers-subtitle">{{ section.settings.subtitle }}</p>
    </div>
    <div class="gh-wc-tier-grid">
      <article class="gh-wc-tier-card">
        <header class="gh-wc-tier-header" style="background: {{ section.settings.ruby_header_color | default: '#8B1A2E' }};">
          <p class="gh-wc-tier-label">{{ section.settings.ruby_tier_label }}</p>
          <h3 class="gh-wc-tier-name">{{ section.settings.ruby_name }}</h3>
          <p class="gh-wc-tier-tagline">{{ section.settings.ruby_tagline }}</p>
          {% if section.settings.ruby_badge != blank %}<span class="gh-wc-tier-badge">{{ section.settings.ruby_badge }}</span>{% endif %}
        </header>
        <div class="gh-wc-tier-body">
          <div class="gh-wc-tier-commitment">
            <strong>{{ section.settings.ruby_commitment }}</strong>
            {% if section.settings.ruby_option_1 != blank %}<p>{{ section.settings.ruby_option_1 }}</p>{% endif %}
            {% if section.settings.ruby_option_2 != blank %}<p>{{ section.settings.ruby_option_2 }}</p>{% endif %}
          </div>
          <ul class="gh-wc-perks">
            {% for block in section.blocks %}
              {% if block.type == 'perk' and block.settings.tier == 'ruby' %}
                <li class="gh-wc-perk" {{ block.shopify_attributes }}>
                  <svg width="14" height="14" fill="none" stroke="#8B1A2E" stroke-width="1.5" viewBox="0 0 24 24"><path d="M20 6L9 17l-5-5"/></svg>
                  <div><p class="gh-wc-perk-title">{{ block.settings.title }}</p>{% if block.settings.subtitle != blank %}<p class="gh-wc-perk-subtitle">{{ block.settings.subtitle }}</p>{% endif %}</div>
                </li>
              {% endif %}
            {% endfor %}
          </ul>
          {% if section.settings.ruby_cta_label != blank and section.settings.ruby_cta_url != blank %}
            <a class="gh-wc-tier-btn gh-wc-tier-btn--ruby" href="{{ section.settings.ruby_cta_url }}">{{ section.settings.ruby_cta_label }}</a>
          {% endif %}
        </div>
      </article>

      <article class="gh-wc-tier-card">
        <header class="gh-wc-tier-header" style="background: {{ section.settings.pearl_header_color | default: '#4A6888' }};">
          <p class="gh-wc-tier-label">{{ section.settings.pearl_tier_label }}</p>
          <h3 class="gh-wc-tier-name">{{ section.settings.pearl_name }}</h3>
          <p class="gh-wc-tier-tagline">{{ section.settings.pearl_tagline }}</p>
          {% if section.settings.pearl_badge != blank %}<span class="gh-wc-tier-badge">{{ section.settings.pearl_badge }}</span>{% endif %}
        </header>
        <div class="gh-wc-tier-body">
          <div class="gh-wc-tier-commitment">
            <strong>{{ section.settings.pearl_commitment }}</strong>
            {% if section.settings.pearl_option_1 != blank %}<p>{{ section.settings.pearl_option_1 }}</p>{% endif %}
            {% if section.settings.pearl_option_2 != blank %}<p>{{ section.settings.pearl_option_2 }}</p>{% endif %}
          </div>
          <ul class="gh-wc-perks">
            {% for block in section.blocks %}
              {% if block.type == 'perk' and block.settings.tier == 'pearl' %}
                <li class="gh-wc-perk" {{ block.shopify_attributes }}>
                  <svg width="14" height="14" fill="none" stroke="#4A6888" stroke-width="1.5" viewBox="0 0 24 24"><path d="M20 6L9 17l-5-5"/></svg>
                  <div><p class="gh-wc-perk-title">{{ block.settings.title }}</p>{% if block.settings.subtitle != blank %}<p class="gh-wc-perk-subtitle">{{ block.settings.subtitle }}</p>{% endif %}</div>
                </li>
              {% endif %}
            {% endfor %}
          </ul>
          {% if section.settings.pearl_cta_label != blank and section.settings.pearl_cta_url != blank %}
            <a class="gh-wc-tier-btn gh-wc-tier-btn--pearl" href="{{ section.settings.pearl_cta_url }}">{{ section.settings.pearl_cta_label }}</a>
          {% endif %}
        </div>
      </article>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "GH — Wine Club Tiers",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Choose your tier" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Two clubs. One family." },
    { "type": "textarea", "id": "subtitle", "label": "Subtitle", "default": "Select the commitment that suits your lifestyle — both give you access to God's Hill wines with the care and tradition they're made with." },
    { "type": "text", "id": "ruby_tier_label", "label": "Ruby tier label", "default": "Premium tier" },
    { "type": "text", "id": "ruby_name", "label": "Ruby club name", "default": "Ruby Club" },
    { "type": "text", "id": "ruby_tagline", "label": "Ruby tagline", "default": "For the dedicated wine lover" },
    { "type": "text", "id": "ruby_badge", "label": "Ruby badge", "default": "Most popular" },
    { "type": "color", "id": "ruby_header_color", "label": "Ruby header color", "default": "#8B1A2E" },
    { "type": "text", "id": "ruby_commitment", "label": "Ruby commitment", "default": "2 dozen wines per year" },
    { "type": "text", "id": "ruby_option_1", "label": "Ruby delivery option 1", "default": "A dozen wines delivered in June and December" },
    { "type": "text", "id": "ruby_option_2", "label": "Ruby delivery option 2", "default": "A 6-pack delivered in March, June, September and December" },
    { "type": "text", "id": "ruby_cta_label", "label": "Ruby CTA label", "default": "Join the Ruby Club →" },
    { "type": "url", "id": "ruby_cta_url", "label": "Ruby CTA URL" },
    { "type": "text", "id": "pearl_tier_label", "label": "Pearl tier label", "default": "Entry tier" },
    { "type": "text", "id": "pearl_name", "label": "Pearl club name", "default": "Pearl Club" },
    { "type": "text", "id": "pearl_tagline", "label": "Pearl tagline", "default": "A perfect introduction to the family" },
    { "type": "text", "id": "pearl_badge", "label": "Pearl badge", "default": "Great start" },
    { "type": "color", "id": "pearl_header_color", "label": "Pearl header color", "default": "#4A6888" },
    { "type": "text", "id": "pearl_commitment", "label": "Pearl commitment", "default": "1 dozen wines per year" },
    { "type": "text", "id": "pearl_option_1", "label": "Pearl delivery option 1", "default": "A 6-pack delivered in June and December" },
    { "type": "text", "id": "pearl_option_2", "label": "Pearl delivery option 2" },
    { "type": "text", "id": "pearl_cta_label", "label": "Pearl CTA label", "default": "Join the Pearl Club →" },
    { "type": "url", "id": "pearl_cta_url", "label": "Pearl CTA URL" },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#FDF8F2" }
  ],
  "blocks": [
    {
      "type": "perk",
      "name": "Perk",
      "settings": [
        {
          "type": "select",
          "id": "tier",
          "label": "Tier",
          "default": "ruby",
          "options": [
            { "value": "ruby", "label": "Ruby" },
            { "value": "pearl", "label": "Pearl" }
          ]
        },
        { "type": "text", "id": "title", "label": "Perk title" },
        { "type": "text", "id": "subtitle", "label": "Perk subtitle" }
      ]
    }
  ],
  "max_blocks": 20,
  "presets": [
    {
      "name": "GH — Wine Club Tiers",
      "blocks": [
        { "type": "perk", "settings": { "tier": "ruby", "title": "25% off all wine purchases", "subtitle": "Applied to all orders year-round" } },
        { "type": "perk", "settings": { "tier": "ruby", "title": "15% discount at Ennia Cucina", "subtitle": "Dine at the restaurant with member pricing" } },
        { "type": "perk", "settings": { "tier": "ruby", "title": "Free Australia-wide shipping", "subtitle": "On club deliveries and additional orders" } },
        { "type": "perk", "settings": { "tier": "ruby", "title": "First release & rare back vintages", "subtitle": "Priority access before general release" } },
        { "type": "perk", "settings": { "tier": "ruby", "title": "Exclusive member events", "subtitle": "Private tastings, winemaker dinners & more" } },
        { "type": "perk", "settings": { "tier": "pearl", "title": "15% off all wine purchases", "subtitle": "Applied to all orders year-round" } },
        { "type": "perk", "settings": { "tier": "pearl", "title": "10% discount at Ennia Cucina", "subtitle": "Dine at the restaurant with member pricing" } },
        { "type": "perk", "settings": { "tier": "pearl", "title": "Free Australia-wide shipping", "subtitle": "On club deliveries and additional orders" } },
        { "type": "perk", "settings": { "tier": "pearl", "title": "First release access", "subtitle": "Early access to new vintages" } },
        { "type": "perk", "settings": { "tier": "pearl", "title": "Member event invitations", "subtitle": "Access to cellar door events and tastings" } }
      ]
    }
  ]
}
{% endschema %}
