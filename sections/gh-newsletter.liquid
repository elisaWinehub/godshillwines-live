{% render 'gh-tokens' %}

<section class="gh-newsletter gh-newsletter-{{ section.id }}" {{ section.shopify_attributes }}>
  <div class="gh-newsletter__inner">
    <p class="gh-newsletter__eyebrow">{{ section.settings.eyebrow | default: 'Stay in the loop' }}</p>
    <div class="gh-newsletter__heading">{{ section.settings.heading | default: '<p>New releases,<br><em>events &amp; offers</em></p>' }}</div>
    <p class="gh-newsletter__subheading">{{ section.settings.subheading | default: 'Be the first to hear about new vintages, wine club news, cellar door events and exclusive member offers.' }}</p>
    {% form 'customer', id: 'gh-newsletter-form' %}
      <input type="hidden" name="contact[tags]" value="newsletter">
      <div class="gh-newsletter__form-row">
        <input type="email" name="contact[email]" required placeholder="{{ section.settings.placeholder | default: 'Your email address' }}">
        <button type="submit">{{ section.settings.btn_label | default: 'Subscribe' }}</button>
      </div>
    {% endform %}
    <p class="gh-newsletter__privacy">{{ section.settings.privacy_note | default: 'We respect your privacy. Unsubscribe any time.' }}</p>
  </div>
</section>

<style>
  .gh-newsletter-{{ section.id }} {
    background: {{ section.settings.bg_color | default: '#1C2B1A' }};
    color: {{ section.settings.text_color | default: '#F5EFE3' }};
    padding: 72px 40px;
  }
  .gh-newsletter-{{ section.id }} .gh-newsletter__inner {
    max-width: 680px;
    margin: 0 auto;
    text-align: center;
  }
  .gh-newsletter-{{ section.id }} .gh-newsletter__eyebrow {
    margin: 0 0 10px;
    color: var(--gh-dust);
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font: 500 10px/1.4 'Inter', sans-serif;
  }
  .gh-newsletter-{{ section.id }} .gh-newsletter__heading {
    font-family: 'EB Garamond', Georgia, serif;
    font-size: clamp(34px, 4vw, 52px);
    line-height: 1.08;
  }
  .gh-newsletter-{{ section.id }} .gh-newsletter__heading p {
    margin: 0;
  }
  .gh-newsletter-{{ section.id }} .gh-newsletter__heading em {
    color: var(--gh-gold-light);
  }
  .gh-newsletter-{{ section.id }} .gh-newsletter__subheading {
    margin: 16px 0 0;
    color: rgba(245, 239, 227, 0.8);
    font: 400 14px/1.7 'Inter', sans-serif;
  }
  .gh-newsletter-{{ section.id }} .gh-newsletter__form-row {
    margin-top: 24px;
    display: flex;
    gap: 10px;
  }
  .gh-newsletter-{{ section.id }} input[type='email'] {
    flex: 1;
    min-width: 0;
    border: 1px solid rgba(245, 239, 227, 0.3);
    background: transparent;
    color: var(--gh-cream);
    padding: 13px 14px;
    font: 400 13px/1 'Inter', sans-serif;
  }
  .gh-newsletter-{{ section.id }} input::placeholder {
    color: rgba(245, 239, 227, 0.55);
  }
  .gh-newsletter-{{ section.id }} button {
    border: 1px solid {{ section.settings.accent_color | default: '#B8913A' }};
    background: {{ section.settings.accent_color | default: '#B8913A' }};
    color: var(--gh-cream);
    padding: 13px 20px;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font: 600 10px/1 'Inter', sans-serif;
    cursor: pointer;
  }
  .gh-newsletter-{{ section.id }} .gh-newsletter__privacy {
    margin: 14px 0 0;
    color: rgba(245, 239, 227, 0.58);
    font: 400 11px/1.5 'Inter', sans-serif;
  }
  @media (max-width: 600px) {
    .gh-newsletter-{{ section.id }} {
      padding: 60px 20px;
    }
    .gh-newsletter-{{ section.id }} .gh-newsletter__form-row {
      flex-direction: column;
    }
    .gh-newsletter-{{ section.id }} button {
      width: 100%;
    }
  }
</style>

{% schema %}
{
  "name": "GH — Newsletter",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Stay in the loop" },
    { "type": "richtext", "id": "heading", "label": "Heading", "default": "<p>New releases,<br><em>events &amp; offers</em></p>" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Be the first to hear about new vintages, wine club news, cellar door events and exclusive member offers." },
    { "type": "text", "id": "btn_label", "label": "Button label", "default": "Subscribe" },
    { "type": "text", "id": "placeholder", "label": "Input placeholder", "default": "Your email address" },
    { "type": "text", "id": "privacy_note", "label": "Privacy note", "default": "We respect your privacy. Unsubscribe any time." },
    { "type": "color", "id": "bg_color", "label": "Background colour", "default": "#1C2B1A" },
    { "type": "color", "id": "accent_color", "label": "Button colour", "default": "#B8913A" },
    { "type": "color", "id": "text_color", "label": "Text colour", "default": "#F5EFE3" }
  ],
  "presets": [{ "name": "GH — Newsletter" }]
}
{% endschema %}
