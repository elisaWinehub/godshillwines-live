{%- render 'gh-tokens' -%}

<section class="gh-related-products-{{ section.id }}" style="background: {{ section.settings.bg_color | default: '#F5EFE3' }};">
  <div class="gh-related-shell">
    <h2>{{ section.settings.heading | default: 'You may also like' }}</h2>
    <span class="gh-underline"></span>
    {% assign related = product.collections.first.products %}
    <div class="gh-related-grid">
      {% for p in related limit: section.settings.products_limit %}
        {% unless p.id == product.id %}
          {%- render 'gh-product-card', product: p -%}
        {% endunless %}
      {% endfor %}
    </div>
  </div>
</section>

<style>
  .gh-related-products-{{ section.id }} {
    padding: 64px 40px;
  }
  .gh-related-products-{{ section.id }} .gh-related-shell {
    width: min(1280px, 100%);
    margin: 0 auto;
  }
  .gh-related-products-{{ section.id }} h2 {
    margin: 0;
    font: 400 32px/1.2 'EB Garamond', Georgia, serif;
    color: var(--gh-vine);
  }
  .gh-related-products-{{ section.id }} .gh-underline {
    display: block;
    width: 40px;
    height: 1px;
    background: {{ section.settings.accent_color | default: '#B8913A' }};
    margin: 16px 0 24px;
  }
  .gh-related-products-{{ section.id }} .gh-related-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 24px;
  }
  .gh-related-products-{{ section.id }} .gh-product-card {
    background: #fff;
    border: 0.5px solid var(--gh-border);
    border-radius: 4px;
    overflow: hidden;
  }
  .gh-related-products-{{ section.id }} .gh-product-card__image-wrap {
    display: block;
    height: 280px;
    background: var(--gh-cream);
  }
  .gh-related-products-{{ section.id }} .gh-product-card__image {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 24px;
  }
  .gh-related-products-{{ section.id }} .gh-product-card__body {
    padding: 18px;
  }
  .gh-related-products-{{ section.id }} .gh-product-card__title {
    margin: 6px 0 10px;
    font: 400 19px/1.2 'EB Garamond', Georgia, serif;
  }
  .gh-related-products-{{ section.id }} .gh-product-card__row {
    display: flex;
    gap: 8px;
    align-items: baseline;
  }
  .gh-related-products-{{ section.id }} .gh-product-card__price {
    font: 400 20px/1 'EB Garamond', Georgia, serif;
  }
  .gh-related-products-{{ section.id }} .gh-product-card__btn {
    width: 100%;
    border: 1px solid var(--gh-gold);
    color: var(--gh-gold);
    background: transparent;
    padding: 9px 12px;
  }
  @media (max-width: 768px) {
    .gh-related-products-{{ section.id }} {
      padding: 56px 20px;
    }
    .gh-related-products-{{ section.id }} .gh-related-grid {
      display: grid;
      grid-auto-flow: column;
      grid-auto-columns: 100%;
      grid-template-columns: none;
      overflow-x: auto;
      gap: 12px;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      padding-bottom: 4px;
    }
    .gh-related-products-{{ section.id }} .gh-related-grid::-webkit-scrollbar {
      display: none;
    }
    .gh-related-products-{{ section.id }} .gh-related-grid > * {
      scroll-snap-align: start;
    }
  }
</style>

{% schema %}
{
  "name": "GH — Related Products",
  "settings": [
    { "type": "text", "id": "heading", "label": "Section heading", "default": "You may also like" },
    { "type": "color", "id": "bg_color", "label": "Background colour", "default": "#F5EFE3" },
    { "type": "color", "id": "accent_color", "label": "Underline accent", "default": "#B8913A" },
    { "type": "range", "id": "products_limit", "label": "Max products shown", "min": 2, "max": 8, "step": 1, "default": 4 }
  ],
  "presets": [{ "name": "GH — Related Products" }]
}
{% endschema %}
