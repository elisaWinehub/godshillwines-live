{%- render 'gh-tokens' -%}
<section class="gh-team-grid-{{ section.id }}" style="background: {{ section.settings.bg_color | default: '#FDF8F2' }};">
  <div class="gh-team-shell">
    <h2>{{ section.settings.heading | default: 'Our Team' }}</h2>
    <span class="gh-divider" style="background: {{ section.settings.accent_color | default: '#B8913A' }};"></span>
    <div class="gh-team-cards">
      {% for block in section.blocks %}
        {% if block.type == 'member' %}
          <article class="gh-team-card" {{ block.shopify_attributes }} style="background: {{ section.settings.card_bg | default: '#FFFFFF' }};">
            <p class="gh-dept" style="color: {{ section.settings.accent_color | default: '#B8913A' }};">{{ block.settings.dept }}</p>
            <p class="gh-name">{{ block.settings.name }}</p>
            {% if block.settings.name_2 != blank %}<p class="gh-name">{{ block.settings.name_2 }}</p>{% endif %}
            {% if block.settings.email != blank %}<p><a href="mailto:{{ block.settings.email }}">{{ block.settings.email }}</a></p>{% endif %}
            {% if block.settings.mobile != blank %}<p class="gh-mobile">{{ block.settings.mobile }}</p>{% endif %}
            {% if block.settings.extra != blank %}<p class="gh-extra">{{ block.settings.extra }}</p>{% endif %}
          </article>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>
<style>
  .gh-team-grid-{{ section.id }} { padding: 80px 40px; }
  .gh-team-grid-{{ section.id }} .gh-team-shell { width: min(1280px, 100%); margin: 0 auto; }
  .gh-team-grid-{{ section.id }} h2 { margin: 0; text-align: center; font: 400 36px/1.15 'EB Garamond', Georgia, serif; color: var(--gh-vine); }
  .gh-team-grid-{{ section.id }} .gh-divider { display: block; width: 40px; height: 1px; margin: 14px auto 22px; }
  .gh-team-grid-{{ section.id }} .gh-team-cards { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
  .gh-team-grid-{{ section.id }} .gh-team-card { border: 0.5px solid var(--gh-border); border-radius: 4px; padding: 24px 28px; }
  .gh-team-grid-{{ section.id }} .gh-dept { margin: 0 0 8px; font: 600 9px/1.2 'Inter', sans-serif; text-transform: uppercase; letter-spacing: 0.12em; }
  .gh-team-grid-{{ section.id }} .gh-name { margin: 0; font: 400 18px/1.2 'EB Garamond', Georgia, serif; color: var(--gh-vine); }
  .gh-team-grid-{{ section.id }} a { color: var(--gh-gold); text-decoration: none; }
  .gh-team-grid-{{ section.id }} .gh-mobile { margin: 4px 0 0; color: var(--gh-muted); font-size: 12.5px; }
  .gh-team-grid-{{ section.id }} .gh-extra { margin: 4px 0 0; color: var(--gh-muted); font-size: 12px; }
  @media (max-width: 768px) {
    .gh-team-grid-{{ section.id }} { padding: 56px 20px; }
    .gh-team-grid-{{ section.id }} .gh-team-cards { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 480px) {
    .gh-team-grid-{{ section.id }} .gh-team-cards { grid-template-columns: 1fr; }
  }
</style>
{% schema %}
{
  "name": "GH — Team Grid",
  "settings": [
    { "type": "text", "id": "heading", "label": "Section heading", "default": "Our Team" },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#FDF8F2" },
    { "type": "color", "id": "card_bg", "label": "Card background", "default": "#FFFFFF" },
    { "type": "color", "id": "accent_color", "label": "Accent", "default": "#B8913A" }
  ],
  "blocks": [
    {
      "type": "member",
      "name": "Team member",
      "settings": [
        { "type": "text", "id": "dept", "label": "Department" },
        { "type": "text", "id": "name", "label": "Name" },
        { "type": "text", "id": "name_2", "label": "Second name (optional \"OR\" row)" },
        { "type": "text", "id": "email", "label": "Email address" },
        { "type": "text", "id": "mobile", "label": "Mobile number" },
        { "type": "textarea", "id": "extra", "label": "Extra info (WeChat, international exports, etc.)" }
      ]
    }
  ],
  "presets": [{ "name": "GH — Team Grid" }]
}
{% endschema %}
