{% comment %} Featured review · two-column editorial with read more {% endcomment %}
{% liquid
  assign show = section.settings.section_enabled | default: true
  assign review_html = section.settings.review
  assign review_plain = review_html | strip_html | strip
  assign char_limit = section.settings.read_more_limit | default: 280
  assign use_readmore = false
  if section.settings.enable_read_more and review_plain.size > char_limit
    assign use_readmore = true
  endif

  assign content_first_desktop = true
  if section.settings.column_order_desktop == 'image_left'
    assign content_first_desktop = false
  endif

  assign content_first_mobile = true
  if section.settings.column_order_mobile == 'image_first'
    assign content_first_mobile = false
  endif

  assign aspect_ratio_css = '4 / 5'
  case section.settings.image_aspect_ratio
    when 'square'
      assign aspect_ratio_css = '1 / 1'
    when 'landscape'
      assign aspect_ratio_css = '4 / 3'
    when 'wide'
      assign aspect_ratio_css = '16 / 9'
    when 'portrait'
      assign aspect_ratio_css = '4 / 5'
  endcase

  assign root_class = 'gh-fr'
  if section.settings.custom_css_class != blank
    assign root_class = root_class | append: ' ' | append: section.settings.custom_css_class | strip
  endif
%}
{% unless show %}
  <div {{ section.shopify_attributes }} hidden></div>
{% else %}
  <section
    id="GHFR-{{ section.id }}"
    class="{{ root_class }}"
    {{ section.shopify_attributes }}
    style="
      --gh-fr-bg: {{ section.settings.section_background }};
      --gh-fr-pt: {{ section.settings.padding_top }}px;
      --gh-fr-pb: {{ section.settings.padding_bottom }}px;
      --gh-fr-cw: {{ section.settings.container_width }}px;
      --gh-fr-gap: {{ section.settings.column_gap }}px;
      --gh-fr-eyebrow: {{ section.settings.eyebrow_color }};
      --gh-fr-heading: {{ section.settings.heading_color }};
      --gh-fr-heading-m: {{ section.settings.heading_size_mobile }}px;
      --gh-fr-heading-d: {{ section.settings.heading_size_desktop }}px;
      --gh-fr-star: {{ section.settings.star_color }};
      --gh-fr-text: {{ section.settings.text_color }};
      --gh-fr-aspect: {{ aspect_ratio_css }};
      --gh-fr-img-pos: {{ section.settings.image_object_position }};
      --gh-fr-readmore: {{ section.settings.read_more_link_color }};
    "
    data-content-first-desktop="{% if content_first_desktop %}true{% else %}false{% endif %}"
    data-content-first-mobile="{% if content_first_mobile %}true{% else %}false{% endif %}"
  >
    <div class="gh-fr__inner">
      <div class="gh-fr__grid">
        <div class="gh-fr__content">
          {% if section.settings.eyebrow != blank %}
            <p class="gh-fr__eyebrow">{{ section.settings.eyebrow }}</p>
          {% endif %}
          {% if section.settings.heading != blank %}
            <h2 class="gh-fr__heading">{{ section.settings.heading | escape | newline_to_br }}</h2>
          {% endif %}

          {% assign rating = section.settings.star_rating | default: 5 %}
          {% if rating > 0 %}
            <div class="gh-fr__stars" role="img" aria-label="{{ rating }} out of 5 stars">
              {% for i in (1..5) %}
                <span class="gh-fr__star{% if i > rating %} gh-fr__star--empty{% endif %}" aria-hidden="true">&#9733;</span>
              {% endfor %}
            </div>
          {% endif %}

          {% if review_html != blank %}
            <div
              class="gh-fr__review-wrap{% if use_readmore %} gh-fr__review-wrap--truncated{% endif %}"
              data-fr-readmore
              data-limit="{{ char_limit }}"
              data-more="{{ section.settings.read_more_text | escape }}"
              data-less="{{ section.settings.read_less_text | escape }}"
              data-enabled="{% if use_readmore %}true{% else %}false{% endif %}"
            >
              {% if use_readmore %}
                <div class="gh-fr__review gh-fr__review--excerpt rte">{{ review_plain | truncate: char_limit, '…' }}</div>
                <div class="gh-fr__review gh-fr__review--full rte" hidden>{{ review_html }}</div>
                <button type="button" class="gh-fr__readmore-btn" data-fr-readmore-toggle>
                  {{ section.settings.read_more_text }}
                </button>
              {% else %}
                <div class="gh-fr__review rte">{{ review_html }}</div>
              {% endif %}
            </div>
          {% endif %}

          {% if section.settings.button_style == 'secondary' %}
            {% render 'godshill-cta-btn',
              label: section.settings.button_label,
              url: section.settings.button_link,
              style: 'secondary',
              bg: section.settings.secondary_bg,
              fg: section.settings.secondary_text,
              border_c: section.settings.secondary_border,
              h_bg: section.settings.secondary_hover_bg,
              h_fg: section.settings.secondary_hover_text,
              h_border: section.settings.secondary_hover_border
            %}
          {% else %}
            {% render 'godshill-cta-btn',
              label: section.settings.button_label,
              url: section.settings.button_link,
              style: 'primary',
              bg: section.settings.primary_bg,
              fg: section.settings.primary_text,
              border_c: section.settings.primary_border,
              h_bg: section.settings.primary_hover_bg,
              h_fg: section.settings.primary_hover_text,
              h_border: section.settings.primary_hover_border
            %}
          {% endif %}
        </div>

        <div class="gh-fr__media">
          {% if section.settings.image != blank %}
            {{
              section.settings.image
              | image_url: width: 1200
              | image_tag: loading: 'lazy', class: 'gh-fr__img', widths: '400,600,900,1200', alt: section.settings.heading | default: 'Featured review'
            }}
          {% else %}
            <div class="gh-fr__img gh-fr__img--placeholder" role="presentation" aria-hidden="true"></div>
          {% endif %}
        </div>
      </div>
    </div>
  </section>

  <style>
    #GHFR-{{ section.id }}.gh-fr {
      background: var(--gh-fr-bg);
      padding-block: var(--gh-fr-pt) var(--gh-fr-pb);
      color: var(--gh-fr-text);
    }
    #GHFR-{{ section.id }} .gh-fr__inner {
      width: min(100%, var(--gh-fr-cw));
      margin-inline: auto;
      padding-inline: clamp(16px, 3vw, 32px);
    }
    #GHFR-{{ section.id }} .gh-fr__grid {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
      gap: var(--gh-fr-gap);
      align-items: center;
    }
    #GHFR-{{ section.id }}[data-content-first-desktop='false'] .gh-fr__content {
      order: 2;
    }
    #GHFR-{{ section.id }}[data-content-first-desktop='false'] .gh-fr__media {
      order: 1;
    }
    #GHFR-{{ section.id }} .gh-fr__eyebrow {
      margin: 0 0 10px;
      text-transform: uppercase;
      letter-spacing: 0.14em;
      font-size: 11px;
      font-weight: 700;
      color: var(--gh-fr-eyebrow);
    }
    #GHFR-{{ section.id }} .gh-fr__eyebrow::after {
      content: '';
      display: block;
      width: 40px;
      height: 2px;
      background: var(--gh-fr-eyebrow);
      margin-top: 10px;
      opacity: 0.85;
    }
    #GHFR-{{ section.id }} .gh-fr__heading {
      margin: 0 0 14px;
      font-family: Georgia, 'Times New Roman', serif;
      font-size: clamp(var(--gh-fr-heading-m), 3vw, var(--gh-fr-heading-d));
      font-weight: 500;
      color: var(--gh-fr-heading);
      line-height: 1.12;
    }
    #GHFR-{{ section.id }} .gh-fr__stars {
      display: flex;
      gap: 4px;
      margin-bottom: 16px;
      color: var(--gh-fr-star);
      font-size: 18px;
      line-height: 1;
    }
    #GHFR-{{ section.id }} .gh-fr__star--empty {
      opacity: 0.22;
    }
    #GHFR-{{ section.id }} .gh-fr__review {
      margin: 0 0 14px;
      font-family: Georgia, 'Times New Roman', serif;
      font-size: clamp(15px, 1.8vw, 17px);
      line-height: 1.65;
      color: inherit;
    }
    #GHFR-{{ section.id }} .gh-fr__review :is(p, ul, ol) {
      margin: 0;
    }
    #GHFR-{{ section.id }} .gh-fr__readmore-btn {
      display: inline;
      padding: 0;
      border: none;
      background: none;
      font: inherit;
      font-family: Georgia, 'Times New Roman', serif;
      font-size: inherit;
      color: var(--gh-fr-readmore);
      text-decoration: underline;
      cursor: pointer;
      margin-bottom: 18px;
    }
    #GHFR-{{ section.id }} .gh-fr__readmore-btn:hover {
      opacity: 0.8;
    }
    #GHFR-{{ section.id }} .gh-cta {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      padding: 12px 22px;
      text-transform: uppercase;
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 0.05em;
      text-decoration: none;
      transition: 0.22s ease;
      margin-top: 8px;
    }
    #GHFR-{{ section.id }} .gh-cta::after {
      content: '\2192';
    }
    #GHFR-{{ section.id }} .gh-cta:hover {
      transform: translateY(-1px);
      background-color: var(--gh-h-bg) !important;
      color: var(--gh-h-fg) !important;
      border-color: var(--gh-h-bd) !important;
    }
    #GHFR-{{ section.id }} .gh-fr__media {
      border-radius: 2px;
      overflow: hidden;
    }
    #GHFR-{{ section.id }} .gh-fr__img {
      width: 100%;
      aspect-ratio: var(--gh-fr-aspect);
      object-fit: cover;
      object-position: var(--gh-fr-img-pos);
      display: block;
    }
    #GHFR-{{ section.id }} .gh-fr__img--placeholder {
      background: linear-gradient(145deg, #e8e2d8 0%, #c9bfb0 100%);
    }
    @media screen and (max-width: 989px) {
      #GHFR-{{ section.id }} .gh-fr__grid {
        grid-template-columns: 1fr;
      }
      #GHFR-{{ section.id }} .gh-fr__content,
      #GHFR-{{ section.id }} .gh-fr__media {
        order: unset;
      }
      #GHFR-{{ section.id }}[data-content-first-mobile='false'] .gh-fr__content {
        order: 2;
      }
      #GHFR-{{ section.id }}[data-content-first-mobile='false'] .gh-fr__media {
        order: 1;
      }
    }
  </style>

  <script>
    (function () {
      var root = document.getElementById('GHFR-{{ section.id }}');
      if (!root) return;
      root.querySelectorAll('[data-fr-readmore-toggle]').forEach(function (btn) {
        btn.addEventListener('click', function () {
          var wrap = btn.closest('[data-fr-readmore]');
          if (!wrap) return;
          var expanded = wrap.classList.toggle('gh-fr__review-wrap--expanded');
          var excerpt = wrap.querySelector('.gh-fr__review--excerpt');
          var full = wrap.querySelector('.gh-fr__review--full');
          if (excerpt) excerpt.hidden = expanded;
          if (full) full.hidden = !expanded;
          btn.textContent = expanded ? wrap.dataset.less : wrap.dataset.more;
        });
      });
    })();
  </script>
{% endunless %}

{% schema %}
{
  "name": "Featured review",
  "tag": "section",
  "class": "gh-featured-review",
  "settings": [
    { "type": "checkbox", "id": "section_enabled", "label": "Show section", "default": true },
    { "type": "header", "content": "Layout" },
    { "type": "color", "id": "section_background", "label": "Section background", "default": "#F3EDE3" },
    {
      "type": "range",
      "id": "container_width",
      "label": "Container max width",
      "min": 960,
      "max": 1440,
      "step": 20,
      "unit": "px",
      "default": 1200
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 72
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 72
    },
    {
      "type": "range",
      "id": "column_gap",
      "label": "Column gap",
      "min": 24,
      "max": 96,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "select",
      "id": "column_order_desktop",
      "label": "Desktop column order",
      "options": [
        { "value": "content_left", "label": "Content left, image right" },
        { "value": "image_left", "label": "Image left, content right" }
      ],
      "default": "content_left"
    },
    {
      "type": "select",
      "id": "column_order_mobile",
      "label": "Mobile column order",
      "options": [
        { "value": "content_first", "label": "Content first" },
        { "value": "image_first", "label": "Image first" }
      ],
      "default": "content_first"
    },
    { "type": "text", "id": "custom_css_class", "label": "Custom CSS class" },
    { "type": "header", "content": "Content" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "FEATURED REVIEW" },
    { "type": "color", "id": "eyebrow_color", "label": "Eyebrow colour", "default": "#B29B33" },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Walkabout 2012 –\nGod's Hill, Lyndoch."
    },
    { "type": "color", "id": "heading_color", "label": "Heading colour", "default": "#1F1A14" },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "label": "Heading size mobile",
      "min": 24,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 28
    },
    {
      "type": "range",
      "id": "heading_size_desktop",
      "label": "Heading size desktop",
      "min": 28,
      "max": 56,
      "step": 2,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "star_rating",
      "label": "Star rating",
      "min": 0,
      "max": 5,
      "step": 1,
      "default": 5
    },
    { "type": "color", "id": "star_color", "label": "Star colour", "default": "#B29B33" },
    {
      "type": "richtext",
      "id": "review",
      "label": "Review text",
      "default": "<p>Koala's first face to face meeting with Charlie was arranged when calling for an appointment to visit the Cellar Door of God's Hill Wines. Charlie asked where Koala was calling from and discovering they were only a couple miles apart...</p>"
    },
    { "type": "color", "id": "text_color", "label": "Text colour", "default": "#333333" },
    { "type": "checkbox", "id": "enable_read_more", "label": "Enable read more / read less", "default": true },
    {
      "type": "range",
      "id": "read_more_limit",
      "label": "Read more character limit",
      "min": 80,
      "max": 600,
      "step": 20,
      "default": 200
    },
    { "type": "text", "id": "read_more_text", "label": "Read more label", "default": "Read more" },
    { "type": "text", "id": "read_less_text", "label": "Read less label", "default": "Read less" },
    { "type": "color", "id": "read_more_link_color", "label": "Read more link colour", "default": "#B29B33" },
    { "type": "header", "content": "Button" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "READ THE FULL REVIEW" },
    { "type": "url", "id": "button_link", "label": "Button link" },
    {
      "type": "select",
      "id": "button_style",
      "label": "Button style",
      "options": [
        { "value": "primary", "label": "Primary" },
        { "value": "secondary", "label": "Secondary" }
      ],
      "default": "primary"
    },
    { "type": "color", "id": "primary_bg", "label": "Primary background", "default": "#B29B33" },
    { "type": "color", "id": "primary_text", "label": "Primary text", "default": "#FFFFFF" },
    { "type": "color", "id": "primary_border", "label": "Primary border", "default": "#B29B33" },
    { "type": "color", "id": "primary_hover_bg", "label": "Primary hover background", "default": "#96782A" },
    { "type": "color", "id": "primary_hover_text", "label": "Primary hover text", "default": "#FFFFFF" },
    { "type": "color", "id": "primary_hover_border", "label": "Primary hover border", "default": "#96782A" },
    { "type": "color", "id": "secondary_bg", "label": "Secondary fill accent", "default": "#B29B33" },
    { "type": "color", "id": "secondary_text", "label": "Secondary text", "default": "#1A2414" },
    { "type": "color", "id": "secondary_border", "label": "Secondary border", "default": "#1A2414" },
    { "type": "color", "id": "secondary_hover_bg", "label": "Secondary hover background", "default": "#1A2414" },
    { "type": "color", "id": "secondary_hover_text", "label": "Secondary hover text", "default": "#FFFFFF" },
    { "type": "color", "id": "secondary_hover_border", "label": "Secondary hover border", "default": "#1A2414" },
    { "type": "header", "content": "Image" },
    { "type": "image_picker", "id": "image", "label": "Image" },
    {
      "type": "select",
      "id": "image_aspect_ratio",
      "label": "Image aspect ratio",
      "options": [
        { "value": "portrait", "label": "4:5 portrait" },
        { "value": "square", "label": "1:1 square" },
        { "value": "landscape", "label": "4:3 landscape" },
        { "value": "wide", "label": "16:9 wide" }
      ],
      "default": "portrait"
    },
    {
      "type": "select",
      "id": "image_object_position",
      "label": "Image object position",
      "options": [
        { "value": "center", "label": "Center" },
        { "value": "top", "label": "Top" },
        { "value": "bottom", "label": "Bottom" },
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    }
  ],
  "presets": [{ "name": "Featured review", "category": "God's Hill" }]
}
{% endschema %}
