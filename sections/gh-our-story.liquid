{% render 'gh-tokens' %}

<section class="gh-our-story gh-our-story-{{ section.id }}" {{ section.shopify_attributes }}>
  <div class="gh-our-story__inner">
    <div class="gh-our-story__media">
      {% if section.settings.image %}
        {{ section.settings.image | image_url: width: 1400 | image_tag: class: 'gh-our-story__image', loading: 'lazy', alt: section.settings.image_alt }}
      {% endif %}
      {% if section.settings.show_corner_accent %}
        <span class="gh-our-story__corner" aria-hidden="true"></span>
      {% endif %}
    </div>
    <div class="gh-our-story__content">
      <p class="gh-our-story__eyebrow">{{ section.settings.eyebrow | default: 'Our story' }}</p>
      <h2>{{ section.settings.heading | default: 'Godshill Winery' }}</h2>
      <blockquote>{{ section.settings.quote | default: '"Bringing an ancient Italian tradition to a new land — one small batch at a time."' }}</blockquote>
      <p>{{ section.settings.body_1 | default: "God's Hill is a proudly family-owned vineyard and winery in the famous Barossa Valley. For generations our focus has been on premium reds and whites that express both the richness of our soils and the care we take from vine to bottle." }}</p>
      <p>{{ section.settings.body_2 | default: "Our grapes are made from a careful selection grown from Charlie's God's Hill vineyard, daily tended by the vigneron, Charlie's son. The vineyard is set in the famous Southern Barossa wine region, only 55 minutes from Adelaide CBD." }}</p>
      <a href="{{ section.settings.btn_url | default: '/pages/about' }}">{{ section.settings.btn_label | default: 'Read our full story →' }}</a>
    </div>
  </div>
</section>

<style>
  .gh-our-story-{{ section.id }} {
    background: {{ section.settings.bg_color | default: '#F5EFE3' }};
    padding: 100px 40px;
  }
  .gh-our-story-{{ section.id }} .gh-our-story__inner {
    max-width: 1280px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
  }
  .gh-our-story-{{ section.id }} .gh-our-story__media {
    position: relative;
    background: #ddd6c6;
    border-radius: 3px;
    min-height: 520px;
  }
  .gh-our-story-{{ section.id }} .gh-our-story__image {
    width: 100%;
    height: 520px;
    object-fit: cover;
    border-radius: 3px;
  }
  .gh-our-story-{{ section.id }} .gh-our-story__corner {
    position: absolute;
    width: 160px;
    height: 160px;
    right: -20px;
    bottom: -20px;
    border: 1px solid {{ section.settings.accent_color | default: '#B8913A' }};
    opacity: 0.4;
    border-radius: 3px;
  }
  .gh-our-story-{{ section.id }} .gh-our-story__eyebrow {
    margin: 0 0 10px;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--gh-dust);
    font: 500 10px/1.5 'Inter', sans-serif;
  }
  .gh-our-story-{{ section.id }} h2 {
    margin: 0;
    color: var(--gh-vine);
    font: 400 clamp(36px, 4vw, 56px)/1.08 'EB Garamond', Georgia, serif;
  }
  .gh-our-story-{{ section.id }} blockquote {
    margin: 20px 0;
    padding-left: 18px;
    border-left: 2px solid {{ section.settings.accent_color | default: '#B8913A' }};
    color: var(--gh-vine);
    font: italic 400 22px/1.4 'EB Garamond', Georgia, serif;
  }
  .gh-our-story-{{ section.id }} .gh-our-story__content p {
    margin: 0 0 14px;
    color: rgba(28, 43, 26, 0.78);
    font: 400 14px/1.8 'Inter', sans-serif;
  }
  .gh-our-story-{{ section.id }} .gh-our-story__content a {
    display: inline-block;
    margin-top: 8px;
    color: var(--gh-vine);
    text-decoration: none;
    border-bottom: 1px solid rgba(28, 43, 26, 0.35);
    font: 600 11px/1.4 'Inter', sans-serif;
    text-transform: uppercase;
    letter-spacing: 0.13em;
  }
  @media (max-width: 768px) {
    .gh-our-story-{{ section.id }} {
      padding: 60px 20px;
    }
    .gh-our-story-{{ section.id }} .gh-our-story__inner {
      grid-template-columns: 1fr;
      gap: 30px;
    }
    .gh-our-story-{{ section.id }} .gh-our-story__media,
    .gh-our-story-{{ section.id }} .gh-our-story__image {
      min-height: 360px;
      height: 360px;
    }
  }
</style>

{% schema %}
{
  "name": "GH — Our story",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Story image" },
    { "type": "text", "id": "image_alt", "label": "Image alt text", "default": "Charlie Scalzi in the vineyard at God's Hill" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Our story" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Godshill Winery" },
    { "type": "textarea", "id": "quote", "label": "Pull quote", "default": "\"Bringing an ancient Italian tradition to a new land — one small batch at a time.\"" },
    { "type": "textarea", "id": "body_1", "label": "First paragraph", "default": "God's Hill is a proudly family-owned vineyard and winery in the famous Barossa Valley. For generations our focus has been on premium reds and whites that express both the richness of our soils and the care we take from vine to bottle." },
    { "type": "textarea", "id": "body_2", "label": "Second paragraph", "default": "Our grapes are made from a careful selection grown from Charlie's God's Hill vineyard, daily tended by the vigneron, Charlie's son. The vineyard is set in the famous Southern Barossa wine region, only 55 minutes from Adelaide CBD." },
    { "type": "text", "id": "btn_label", "label": "CTA label", "default": "Read our full story →" },
    { "type": "url", "id": "btn_url", "label": "CTA URL" },
    { "type": "color", "id": "bg_color", "label": "Background colour", "default": "#F5EFE3" },
    { "type": "color", "id": "accent_color", "label": "Gold accent colour", "default": "#B8913A" },
    { "type": "checkbox", "id": "show_corner_accent", "label": "Show decorative corner accent", "default": true }
  ],
  "presets": [{ "name": "GH — Our story" }]
}
{% endschema %}
