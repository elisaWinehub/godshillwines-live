{% comment %} Contact · Our Team card grid with alternating backgrounds {% endcomment %}
{% liquid
  assign show = section.settings.section_enabled | default: true
  assign root_class = 'gh-ctg'
  if section.settings.custom_css_class != blank
    assign root_class = root_class | append: ' ' | append: section.settings.custom_css_class | strip
  endif
%}
{% unless show %}
  <div {{ section.shopify_attributes }} hidden></div>
{% else %}
  <section
    id="GHCTG-{{ section.id }}"
    class="{{ root_class }}"
    {{ section.shopify_attributes }}
    style="
      --gh-ctg-bg: {{ section.settings.section_background }};
      --gh-ctg-pt: {{ section.settings.padding_top }}px;
      --gh-ctg-pb: {{ section.settings.padding_bottom }}px;
      --gh-ctg-cw: {{ section.settings.container_width }}px;
      --gh-ctg-heading: {{ section.settings.heading_color }};
      --gh-ctg-heading-m: {{ section.settings.heading_size_mobile }}px;
      --gh-ctg-heading-d: {{ section.settings.heading_size_desktop }}px;
      --gh-ctg-div: {{ section.settings.divider_color }};
      --gh-ctg-card-1: {{ section.settings.card_background_1 }};
      --gh-ctg-card-2: {{ section.settings.card_background_2 }};
      --gh-ctg-border: {{ section.settings.card_border_color }};
      --gh-ctg-border-h: {{ section.settings.card_hover_border_color }};
      --gh-ctg-pad: {{ section.settings.card_padding }}px;
      --gh-ctg-title: {{ section.settings.card_title_color }};
      --gh-ctg-text: {{ section.settings.text_color }};
      --gh-ctg-link: {{ section.settings.link_color }};
      --gh-ctg-d: {{ section.settings.columns_desktop }};
      --gh-ctg-t: {{ section.settings.columns_tablet }};
      --gh-ctg-m: {{ section.settings.columns_mobile }};
      --gh-ctg-gap: {{ section.settings.grid_gap }}px;
    "
    data-hover="{% if section.settings.enable_hover_effect %}true{% else %}false{% endif %}"
  >
    <div class="gh-ctg__inner">
      {% if section.settings.heading != blank %}
        <header class="gh-ctg__header">
          <h2 class="gh-ctg__heading">{{ section.settings.heading }}</h2>
          <div class="gh-ctg__divider" role="presentation" aria-hidden="true"></div>
        </header>
      {% endif %}

      {% if section.blocks.size == 0 %}
        <p class="gh-ctg__empty">Add team card blocks in the theme editor.</p>
      {% else %}
        <ul class="gh-ctg__grid" role="list">
          {% for block in section.blocks %}
            {% case block.type %}
              {% when 'team_card' %}
                {% assign alt_bg = forloop.index | modulo: 2 %}
                <li
                  class="gh-ctg__card{% if alt_bg == 0 %} gh-ctg__card--alt{% endif %}"
                  {{ block.shopify_attributes }}
                >
                  {% if block.settings.title != blank %}
                    <h3 class="gh-ctg__card-title">{{ block.settings.title }}</h3>
                  {% endif %}
                  {% if block.settings.content != blank %}
                    <div class="gh-ctg__card-body rte">{{ block.settings.content }}</div>
                  {% endif %}
                </li>
            {% endcase %}
          {% endfor %}
        </ul>
      {% endif %}
    </div>
  </section>

  <style>
    #GHCTG-{{ section.id }}.gh-ctg {
      background: var(--gh-ctg-bg);
      padding-block: var(--gh-ctg-pt) var(--gh-ctg-pb);
      color: var(--gh-ctg-text);
    }
    #GHCTG-{{ section.id }} .gh-ctg__inner {
      width: min(100%, var(--gh-ctg-cw));
      margin-inline: auto;
      padding-inline: clamp(16px, 3vw, 32px);
    }
    #GHCTG-{{ section.id }} .gh-ctg__header {
      text-align: center;
      margin-bottom: clamp(32px, 5vw, 48px);
    }
    #GHCTG-{{ section.id }} .gh-ctg__heading {
      margin: 0 0 12px;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      font-family: Georgia, 'Times New Roman', serif;
      font-size: clamp(var(--gh-ctg-heading-m), 3vw, var(--gh-ctg-heading-d));
      font-weight: 500;
      color: var(--gh-ctg-heading);
    }
    #GHCTG-{{ section.id }} .gh-ctg__divider {
      width: 48px;
      height: 2px;
      background: var(--gh-ctg-div);
      margin-inline: auto;
    }
    #GHCTG-{{ section.id }} .gh-ctg__empty {
      text-align: center;
      opacity: 0.7;
    }
    #GHCTG-{{ section.id }} .gh-ctg__grid {
      list-style: none;
      margin: 0;
      padding: 0;
      display: grid;
      grid-template-columns: repeat(var(--gh-ctg-m), minmax(0, 1fr));
      gap: var(--gh-ctg-gap);
      align-items: stretch;
    }
    @media screen and (min-width: 750px) {
      #GHCTG-{{ section.id }} .gh-ctg__grid {
        grid-template-columns: repeat(var(--gh-ctg-t), minmax(0, 1fr));
      }
    }
    @media screen and (min-width: 990px) {
      #GHCTG-{{ section.id }} .gh-ctg__grid {
        grid-template-columns: repeat(var(--gh-ctg-d), minmax(0, 1fr));
      }
    }
    #GHCTG-{{ section.id }} .gh-ctg__card {
      background: var(--gh-ctg-card-1);
      border: 1px solid var(--gh-ctg-border);
      padding: var(--gh-ctg-pad);
      text-align: center;
      min-height: 100%;
      display: flex;
      flex-direction: column;
      justify-content: center;
      box-shadow: 0 4px 18px rgb(0 0 0 / 0.04);
      transition: transform 0.22s ease, border-color 0.22s ease, box-shadow 0.22s ease;
    }
    #GHCTG-{{ section.id }} .gh-ctg__card--alt {
      background: var(--gh-ctg-card-2);
    }
    #GHCTG-{{ section.id }}[data-hover='true'] .gh-ctg__card:hover {
      transform: translateY(-3px);
      border-color: var(--gh-ctg-border-h);
      box-shadow: 0 10px 28px rgb(0 0 0 / 0.08);
    }
    #GHCTG-{{ section.id }} .gh-ctg__card-title {
      margin: 0 0 14px;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--gh-ctg-title);
      line-height: 1.4;
    }
    #GHCTG-{{ section.id }} .gh-ctg__card-body {
      font-family: Georgia, 'Times New Roman', serif;
      font-size: 15px;
      line-height: 1.55;
      color: var(--gh-ctg-text);
    }
    #GHCTG-{{ section.id }} .gh-ctg__card-body :is(p, ul, ol) { margin: 0; }
    #GHCTG-{{ section.id }} .gh-ctg__card-body :is(p + p) { margin-top: 0.65em; }
    #GHCTG-{{ section.id }} .gh-ctg__card-body a {
      color: var(--gh-ctg-link);
      text-decoration: none;
    }
    #GHCTG-{{ section.id }} .gh-ctg__card-body a:hover {
      text-decoration: underline;
    }
  </style>
{% endunless %}

