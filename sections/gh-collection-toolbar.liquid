{%- render 'gh-tokens' -%}

<section class="gh-collection-toolbar-{{ section.id }}">
  <div class="gh-collection-toolbar-inner">
    {% if section.settings.show_breadcrumb %}
      <div class="breadcrumb">
        <a href="{{ routes.root_url }}">Home</a>
        <span class="breadcrumb-sep">/</span>
        <span>{{ collection.title | default: 'Buy Wines' }}</span>
      </div>
    {% endif %}

    {% assign gh_showing_end = collection.products_count %}
    {% if gh_showing_end > 9 %}
      {% assign gh_showing_end = 9 %}
    {% endif %}

    <div class="products-header">
      <p class="products-count"><strong>{{ collection.products_count }} products</strong> · showing 1–{{ gh_showing_end }}</p>
      <div class="sort-row">
        <span>Sort by</span>
        <select
          class="sort-select"
          onchange="location='{{ collection.url }}?sort_by='+this.value+'{{ collection.filter_query }}'"
        >
          <option value="manual" {% if collection.sort_by == blank or collection.sort_by == 'manual' %}selected{% endif %}>Featured</option>
          <option value="price-ascending" {% if collection.sort_by == 'price-ascending' %}selected{% endif %}>Price: low to high</option>
          <option value="price-descending" {% if collection.sort_by == 'price-descending' %}selected{% endif %}>Price: high to low</option>
          <option value="created-descending" {% if collection.sort_by == 'created-descending' %}selected{% endif %}>Newest first</option>
        </select>
      </div>
    </div>
  </div>
</section>

<style>
  .gh-collection-toolbar-{{ section.id }} {
    padding: 16px 40px 0;
  }

  .gh-collection-toolbar-{{ section.id }} .gh-collection-toolbar-inner {
    width: min(1280px, 100%);
    margin: 0 auto;
    display: grid;
    gap: 14px;
  }

  .gh-collection-toolbar-{{ section.id }} .breadcrumb {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 11px;
    color: var(--gh-muted);
    letter-spacing: 0.04em;
  }

  .gh-collection-toolbar-{{ section.id }} .breadcrumb a {
    color: #B8913A;
    text-decoration: none;
  }

  .gh-collection-toolbar-{{ section.id }} .breadcrumb-sep {
    opacity: 0.55;
  }

  .gh-collection-toolbar-{{ section.id }} .products-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding-bottom: 16px;
    border-bottom: 0.5px solid var(--gh-border);
  }

  .gh-collection-toolbar-{{ section.id }} .products-count {
    margin: 0;
    font: 400 12px/1.4 'Inter', sans-serif;
    color: var(--gh-muted);
  }

  .gh-collection-toolbar-{{ section.id }} .sort-row {
    display: flex;
    align-items: center;
    gap: 12px;
    font: 400 12px/1.4 'Inter', sans-serif;
    color: var(--gh-muted);
  }

  .gh-collection-toolbar-{{ section.id }} .sort-select {
    border: 0.5px solid var(--gh-border);
    border-radius: 2px;
    background: #fff;
    color: var(--gh-vine);
    font: 400 12px/1.4 'Inter', sans-serif;
    padding: 7px 12px;
  }

  @media (max-width: 768px) {
    .gh-collection-toolbar-{{ section.id }} {
      padding: 16px 20px 0;
    }

    .gh-collection-toolbar-{{ section.id }} .products-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 10px;
    }
  }
</style>

{% schema %}
{
  "name": "GH — Collection Toolbar",
  "settings": [
    { "type": "checkbox", "id": "show_breadcrumb", "label": "Show breadcrumb", "default": true }
  ],
  "presets": [{ "name": "GH — Collection Toolbar" }]
}
{% endschema %}
