        { "type": "text", "id": "home_label", "label": "Home label", "default": "Home" },
        { "type": "checkbox", "id": "show_all_products", "label": "Show all products collection", "default": false },
        { "type": "collection", "id": "all_products_collection", "label": "All products collection" },
        { "type": "text", "id": "all_products_label", "label": "All products label", "default": "All products" },
        { "type": "checkbox", "id": "show_collection", "label": "Show current collection", "default": true }
      ]
    },
    {
      "type": "vendor",
      "name": "Vendor",
      "settings": [
        { "type": "checkbox", "id": "show_block", "label": "Show block", "default": true },
        { "type": "text", "id": "text", "label": "Vendor text override" }
      ]
    },
    {
      "type": "title",
      "name": "Title",
      "settings": [
        { "type": "checkbox", "id": "show_block", "label": "Show block", "default": true }
      ]
    },
    {
      "type": "rating",
      "name": "Rating",
      "settings": [
        { "type": "checkbox", "id": "show_block", "label": "Show block", "default": true }
      ]
    },
    {
      "type": "price",
      "name": "Price",
      "settings": [
        { "type": "checkbox", "id": "show_block", "label": "Show block", "default": true }
      ]
    },
    {
