        { "type": "checkbox", "id": "use_first_paragraph", "label": "Use first paragraph only", "default": true }
      ]
    },
    {
      "type": "purchase_options",
      "name": "Purchase options",
      "settings": [
        { "type": "checkbox", "id": "show_block", "label": "Show block", "default": true },
        { "type": "text", "id": "title", "label": "Heading", "default": "CHOOSE YOUR PURCHASE OPTION" },
        { "type": "text", "id": "one_time_label", "label": "One-time label", "default": "One-time purchase" },
        { "type": "text", "id": "one_time_price", "label": "One-time price", "default": "$85.00" },
        { "type": "checkbox", "id": "show_subscribe", "label": "Show subscribe option", "default": true },
        { "type": "text", "id": "subscribe_label", "label": "Subscribe label", "default": "Subscribe & Save" },
