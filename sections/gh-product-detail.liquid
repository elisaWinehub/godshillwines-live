<script>
  function ghToggleAccordion(btn) {
    var container = btn.closest('.gh-accordion');
    if (!container) return;
    var isOpen = btn.getAttribute('aria-expanded') === 'true';
    var target = document.getElementById(btn.getAttribute('aria-controls'));

    container.querySelectorAll('.gh-accordion-header').forEach(function (header) {
      header.setAttribute('aria-expanded', 'false');
      var body = document.getElementById(header.getAttribute('aria-controls'));
      if (body) body.hidden = true;
    });

    if (!isOpen) {
      btn.setAttribute('aria-expanded', 'true');
      if (target) target.hidden = false;
    }
  }

  document.addEventListener('DOMContentLoaded', function () {
    var sectionRoot = document.querySelector('.gh-product-detail-{{ section.id }}');
    if (!sectionRoot) return;

    sectionRoot.querySelectorAll('[data-mpc-purchase]').forEach(function (wrapper) {
      var radios = wrapper.querySelectorAll('[data-mpc-purchase-radio]');
      var plans = wrapper.querySelector('[data-mpc-purchase-plans]');
      var options = wrapper.querySelectorAll('[data-mpc-purchase-option]');

      function refreshPurchaseState() {
        options.forEach(function (option) { option.classList.remove('is-selected'); });
        radios.forEach(function (radio) {
          if (radio.checked) {
            var selected = radio.closest('[data-mpc-purchase-option]');
            if (selected) selected.classList.add('is-selected');
          }
        });
        var subscribe = wrapper.querySelector('[data-mpc-purchase-radio][value="subscribe"]');
        if (plans) plans.hidden = !(subscribe && subscribe.checked);
      }

      radios.forEach(function (radio) {
        radio.addEventListener('change', refreshPurchaseState);
      });
      refreshPurchaseState();
    });

    var zoomBtn = sectionRoot.querySelector('.gh-product-zoom-btn');
    if (!zoomBtn) return;

    var overlay = document.createElement('div');
    overlay.className = 'gh-lightbox';
    overlay.innerHTML =
      '<div class="gh-lightbox-inner">' +
      '<button class="gh-lightbox-close" aria-label="Close zoom">' +
      '<svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M2 2L18 18M18 2L2 18" stroke="white" stroke-width="2" stroke-linecap="round"></path></svg>' +
      '</button>' +
      '<img class="gh-lightbox-img" src="" alt="">' +
      '</div>';

    sectionRoot.appendChild(overlay);

    var lightboxImg = overlay.querySelector('.gh-lightbox-img');
    var closeBtn = overlay.querySelector('.gh-lightbox-close');

    function openLightbox() {
      var mainImg = document.getElementById('{{ main_img_id }}') || sectionRoot.querySelector('.gh-product-main-img img');
      if (!mainImg || !lightboxImg) return;
      lightboxImg.src = mainImg.src;
      lightboxImg.alt = mainImg.alt || '';
      overlay.classList.add('gh-lightbox-open');
      document.body.style.overflow = 'hidden';
    }

    function closeLightbox() {
      overlay.classList.remove('gh-lightbox-open');
      document.body.style.overflow = '';
    }

    zoomBtn.addEventListener('click', openLightbox);
    if (closeBtn) closeBtn.addEventListener('click', closeLightbox);
    overlay.addEventListener('click', function (event) {
      if (event.target === overlay) closeLightbox();
    });
    document.addEventListener('keydown', function (event) {
      if (event.key === 'Escape') closeLightbox();
    });
  });
</script>

