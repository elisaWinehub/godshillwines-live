  .gh-product-detail-{{ section.id }} [class*="selling-plan"] {
    margin: 0 !important;
  }

  .gh-product-detail-{{ section.id }} .gh-purchase-box-title,
  .gh-product-detail-{{ section.id }} .purchase-box-title,
  .gh-product-detail-{{ section.id }} [class*="purchase_option"] {
    margin-top: 0 !important;
    padding-top: 4px !important;
  }
</style>

<script>
  function ghToggleAccordion(btn) {
    var container = btn.closest('.gh-accordion');
    if (!container) return;
    var isOpen = btn.getAttribute('aria-expanded') === 'true';
    var target = document.getElementById(btn.getAttribute('aria-controls'));

    container.querySelectorAll('.gh-accordion-header').forEach(function (header) {
      header.setAttribute('aria-expanded', 'false');
      var body = document.getElementById(header.getAttribute('aria-controls'));
      if (body) body.hidden = true;
    });

    if (!isOpen) {
      btn.setAttribute('aria-expanded', 'true');
      if (target) target.hidden = false;
    }
  }

  document.addEventListener('DOMContentLoaded', function () {
    var sectionRoot = document.querySelector('.gh-product-detail-{{ section.id }}');
    if (!sectionRoot) return;

    sectionRoot.querySelectorAll('[data-mpc-purchase]').forEach(function (wrapper) {
      var radios = wrapper.querySelectorAll('[data-mpc-purchase-radio]');
      var plans = wrapper.querySelector('[data-mpc-purchase-plans]');
      var options = wrapper.querySelectorAll('[data-mpc-purchase-option]');

      function refreshPurchaseState() {
        options.forEach(function (option) { option.classList.remove('is-selected'); });
        radios.forEach(function (radio) {
          if (radio.checked) {
            var selected = radio.closest('[data-mpc-purchase-option]');
            if (selected) selected.classList.add('is-selected');
          }
        });
        var subscribe = wrapper.querySelector('[data-mpc-purchase-radio][value="subscribe"]');
        if (plans) plans.hidden = !(subscribe && subscribe.checked);
      }

      radios.forEach(function (radio) {
        radio.addEventListener('change', refreshPurchaseState);
      });
      refreshPurchaseState();
    });

    (function () {
      var mainImg = sectionRoot.querySelector('#gh-main-img-tag');
      var thumbWrap = sectionRoot.querySelector('#gh-product-thumbs');
      if (!mainImg || !thumbWrap) return;

      var thumbs = Array.from(thumbWrap.querySelectorAll('.gh-product-thumb'));
      var currentIndex = 0;
      var prevBtn = sectionRoot.querySelector('#gh-img-prev');
      var nextBtn = sectionRoot.querySelector('#gh-img-next');
      var counter = sectionRoot.querySelector('#gh-img-counter');

      function normalizeIndex(index) {
        if (!thumbs.length) return 0;
        return (index % thumbs.length + thumbs.length) % thumbs.length;
      }

      function updateNavButtons() {
        if (!prevBtn || !nextBtn) return;
        var hasMultiple = thumbs.length > 1;
        prevBtn.disabled = !hasMultiple;
        nextBtn.disabled = !hasMultiple;
        prevBtn.style.opacity = hasMultiple ? '1' : '0.3';
        nextBtn.style.opacity = hasMultiple ? '1' : '0.3';
      }

      function getCurrentItem() {
        if (!thumbs.length) return null;
        var thumb = thumbs[currentIndex];
        if (!thumb) return null;
        var thumbImg = thumb.querySelector('img');
        return {
          index: currentIndex,
          src: thumb.getAttribute('data-src') || '',
          alt: thumbImg ? thumbImg.alt : '',
          total: thumbs.length
        };
      }

      function goToIndex(index) {
        if (!thumbs.length) return;
        currentIndex = normalizeIndex(index);

        var thumb = thumbs[currentIndex];
        var newSrc = thumb.getAttribute('data-src');
        if (!newSrc) return;
        var nextAlt = thumb.querySelector('img') ? thumb.querySelector('img').alt : '';

        mainImg.classList.add('is-fading');
        var tempImg = new Image();
        tempImg.onload = function () {
          window.requestAnimationFrame(function () {
            mainImg.src = newSrc;
            mainImg.alt = nextAlt;
            window.requestAnimationFrame(function () {
              mainImg.classList.remove('is-fading');
            });
          });
        };
        tempImg.onerror = function () {
          window.requestAnimationFrame(function () {
            mainImg.src = newSrc;
            window.requestAnimationFrame(function () {
              mainImg.classList.remove('is-fading');
            });
          });
        };
        tempImg.src = newSrc;

        thumbs.forEach(function (t, i) {
          t.classList.toggle('active', i === currentIndex);
          t.setAttribute('aria-pressed', i === currentIndex ? 'true' : 'false');
        });

        if (counter) {
          counter.textContent = (currentIndex + 1) + ' / ' + thumbs.length;
        }

        updateNavButtons();
      }

      sectionRoot.__ghGalleryApi = {
        goToIndex: goToIndex,
        getCurrentIndex: function () { return currentIndex; },
        getLength: function () { return thumbs.length; },
        getCurrentItem: getCurrentItem
      };

      thumbWrap.addEventListener('click', function (e) {
        var btn = e.target.closest('.gh-product-thumb');
        if (!btn) return;
        var idx = parseInt(btn.getAttribute('data-index'), 10);
        if (!isNaN(idx)) goToIndex(idx);
      });

      if (prevBtn) {
        prevBtn.addEventListener('click', function () {
          goToIndex(currentIndex - 1);
        });
      }

      if (nextBtn) {
        nextBtn.addEventListener('click', function () {
          goToIndex(currentIndex + 1);
        });
      }

      var mainWrap = sectionRoot.querySelector('#gh-product-main-img-wrap');
      if (mainWrap) {
        mainWrap.setAttribute('tabindex', '0');
        mainWrap.addEventListener('keydown', function (e) {
          if (e.key === 'ArrowLeft') { e.preventDefault(); goToIndex(currentIndex - 1); }
          if (e.key === 'ArrowRight') { e.preventDefault(); goToIndex(currentIndex + 1); }
        });

        var touchStartX = 0;
        mainWrap.addEventListener('touchstart', function (e) {
          touchStartX = e.touches[0].clientX;
        }, { passive: true });
        mainWrap.addEventListener('touchend', function (e) {
          var diff = touchStartX - e.changedTouches[0].clientX;
          if (Math.abs(diff) > 40) {
            if (diff > 0) goToIndex(currentIndex + 1);
            else goToIndex(currentIndex - 1);
          }
        }, { passive: true });
      }

      updateNavButtons();
    })();

    var zoomBtn = sectionRoot.querySelector('.gh-product-zoom-btn');
    if (!zoomBtn) return;

    var overlay = document.createElement('div');
    overlay.className = 'gh-lightbox';
    overlay.innerHTML =
      '<div class="gh-lightbox-inner">' +
      '<button class="gh-lightbox-nav gh-lightbox-nav--prev" aria-label="Previous image" type="button">' +
      '<svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24" aria-hidden="true"><path d="M15 18l-6-6 6-6" stroke-linecap="round" stroke-linejoin="round"></path></svg>' +
      '</button>' +
      '<button class="gh-lightbox-nav gh-lightbox-nav--next" aria-label="Next image" type="button">' +
      '<svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24" aria-hidden="true"><path d="M9 18l6-6-6-6" stroke-linecap="round" stroke-linejoin="round"></path></svg>' +
      '</button>' +
      '<button class="gh-lightbox-close" aria-label="Close zoom">' +
      '<svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M2 2L18 18M18 2L2 18" stroke="white" stroke-width="2" stroke-linecap="round"></path></svg>' +
      '</button>' +
      '<img class="gh-lightbox-img" src="" alt="">' +
      '</div>';

    sectionRoot.appendChild(overlay);

    var lightboxImg = overlay.querySelector('.gh-lightbox-img');
    var closeBtn = overlay.querySelector('.gh-lightbox-close');
    var lightboxPrev = overlay.querySelector('.gh-lightbox-nav--prev');
    var lightboxNext = overlay.querySelector('.gh-lightbox-nav--next');

    function getGalleryApi() {
      return sectionRoot.__ghGalleryApi || null;
    }

    function updateLightboxNav() {
      var api = getGalleryApi();
      var hasMultiple = !!(api && api.getLength() > 1);
      if (lightboxPrev) {
        lightboxPrev.hidden = !hasMultiple;
        lightboxPrev.disabled = !hasMultiple;
      }
      if (lightboxNext) {
        lightboxNext.hidden = !hasMultiple;
        lightboxNext.disabled = !hasMultiple;
      }
    }

    function syncLightboxImage() {
      var api = getGalleryApi();
      var current = api && api.getCurrentItem ? api.getCurrentItem() : null;
      if (current && lightboxImg) {
        lightboxImg.src = current.src;
        lightboxImg.alt = current.alt || '';
        return;
      }
      var mainImage = sectionRoot.querySelector('#gh-main-img-tag') || sectionRoot.querySelector('.gh-product-main-img img');
      if (!mainImage || !lightboxImg) return;
      lightboxImg.src = mainImage.src;
      lightboxImg.alt = mainImage.alt || '';
    }

    function navigateLightbox(step) {
      var api = getGalleryApi();
      if (!api || api.getLength() <= 1) return;
      api.goToIndex(api.getCurrentIndex() + step);
      syncLightboxImage();
    }

    function openLightbox() {
      if (!lightboxImg) return;
      syncLightboxImage();
      updateLightboxNav();
      overlay.classList.add('gh-lightbox-open');
      document.body.style.overflow = 'hidden';
    }

    function closeLightbox() {
      overlay.classList.remove('gh-lightbox-open');
      document.body.style.overflow = '';
    }

    zoomBtn.addEventListener('click', openLightbox);
    if (closeBtn) closeBtn.addEventListener('click', closeLightbox);
    if (lightboxPrev) lightboxPrev.addEventListener('click', function () { navigateLightbox(-1); });
    if (lightboxNext) lightboxNext.addEventListener('click', function () { navigateLightbox(1); });
    overlay.addEventListener('click', function (event) {
      if (event.target === overlay) closeLightbox();
    });
    document.addEventListener('keydown', function (event) {
      if (!overlay.classList.contains('gh-lightbox-open')) return;
      if (event.key === 'Escape') closeLightbox();
      if (event.key === 'ArrowLeft') { event.preventDefault(); navigateLightbox(-1); }
      if (event.key === 'ArrowRight') { event.preventDefault(); navigateLightbox(1); }
    });
  });
</script>

