{%- render 'gh-tokens' -%}
<section class="gh-awards-timeline-{{ section.id }}" style="background: {{ section.settings.bg_color | default: '#FDF8F2' }};">
  <div class="gh-awards-title-wrap">
    <h1>{{ section.settings.page_title | default: 'Awards & Achievements' }}</h1>
    <span class="gh-underline"></span>
  </div>
  <div class="gh-awards-timeline-shell">
    {% for block in section.blocks %}
      {% if block.type == 'year_group' %}
        <article class="gh-year-group" {{ block.shopify_attributes }}>
          <div class="gh-year">{{ block.settings.year | default: '2022' }}</div>
          <div class="gh-entries">{{ block.settings.entries }}</div>
        </article>
      {% endif %}
    {% endfor %}
  </div>
</section>
<style>
  .gh-awards-timeline-{{ section.id }} .gh-awards-title-wrap { text-align: center; padding: 64px 40px 48px; }
  .gh-awards-timeline-{{ section.id }} h1 { margin: 0; font: 400 48px/1.1 'EB Garamond', Georgia, serif; color: var(--gh-vine); }
  .gh-awards-timeline-{{ section.id }} .gh-underline { display: block; width: 40px; height: 1px; margin: 16px auto 0; background: {{ section.settings.accent_color | default: '#B8913A' }}; }
  .gh-awards-timeline-{{ section.id }} .gh-awards-timeline-shell { width: min(900px, 100%); margin: 0 auto; padding: 0 40px 80px; position: relative; }
  .gh-awards-timeline-{{ section.id }} .gh-awards-timeline-shell::before { content: ''; position: absolute; left: 140px; top: 0; bottom: 0; width: 1px; background: var(--gh-border); }
  .gh-awards-timeline-{{ section.id }} .gh-year-group { display: grid; grid-template-columns: 100px 1fr; gap: 32px; margin-bottom: 10px; }
  .gh-awards-timeline-{{ section.id }} .gh-year { text-align: right; padding-right: 28px; position: relative; font: 400 28px/1.2 'EB Garamond', Georgia, serif; color: {{ section.settings.accent_color | default: '#B8913A' }}; }
  .gh-awards-timeline-{{ section.id }} .gh-year::after { content: ''; position: absolute; right: -5px; top: 22px; width: 9px; height: 9px; border-radius: 50%; background: {{ section.settings.accent_color | default: '#B8913A' }}; }
  .gh-awards-timeline-{{ section.id }} .gh-entries { padding: 12px 0 24px 32px; }
  .gh-awards-timeline-{{ section.id }} .gh-entries p { margin: 0; font-size: 14px; padding: 12px 0; border-bottom: 0.5px solid var(--gh-border); color: var(--gh-muted); }
  @media (max-width: 768px) {
    .gh-awards-timeline-{{ section.id }} .gh-awards-title-wrap { padding: 56px 20px 32px; }
    .gh-awards-timeline-{{ section.id }} .gh-awards-timeline-shell { padding: 0 20px 56px; }
    .gh-awards-timeline-{{ section.id }} .gh-awards-timeline-shell::before { left: 20px; }
    .gh-awards-timeline-{{ section.id }} .gh-year-group { grid-template-columns: 1fr; gap: 8px; }
    .gh-awards-timeline-{{ section.id }} .gh-year { text-align: left; padding-right: 0; padding-left: 20px; }
    .gh-awards-timeline-{{ section.id }} .gh-year::after { left: -4px; right: auto; }
    .gh-awards-timeline-{{ section.id }} .gh-entries { padding: 0 0 16px 20px; }
  }
</style>
{% schema %}
{
  "name": "GH — Awards Timeline",
  "settings": [
    { "type": "text", "id": "page_title", "label": "Page heading", "default": "Awards & Achievements" },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#FDF8F2" },
    { "type": "color", "id": "accent_color", "label": "Year colour + dot", "default": "#B8913A" }
  ],
  "blocks": [
    {
      "type": "year_group",
      "name": "Year group",
      "settings": [
        { "type": "text", "id": "year", "label": "Year", "default": "2022" },
        { "type": "richtext", "id": "entries", "label": "Awards for this year (use <p> per award)", "default": "<p>Challenge – Silver Medal (94/100) 2021 Single Vineyard 3 Generation Shiraz</p>" }
      ]
    }
  ],
  "presets": [{ "name": "GH — Awards Timeline" }]
}
{% endschema %}
