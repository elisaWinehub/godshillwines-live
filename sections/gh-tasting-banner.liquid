{% render 'gh-tokens' %}

<section class="gh-tasting-banner gh-tasting-banner-{{ section.id }}" {{ section.shopify_attributes }}>
  <div class="gh-tasting-banner__inner">
    <div class="gh-tasting-banner__media">
      {% if section.settings.image %}
        {{ section.settings.image | image_url: width: 1600 | image_tag: class: 'gh-tasting-banner__image', loading: 'lazy' }}
      {% endif %}
    </div>
    <div class="gh-tasting-banner__content">
      <p class="gh-tasting-banner__eyebrow">{{ section.settings.eyebrow | default: 'Experience · Book ahead' }}</p>
      <div class="gh-tasting-banner__heading">{{ section.settings.heading | default: '<p>Wine Tasting<br><em>in the heart of Barossa</em></p>' }}</div>
      <p class="gh-tasting-banner__body">{{ section.settings.body | default: 'Our cellar door tastings are our labour of love. Groups of six or more are welcome — we simply ask you to book ahead so we can look after you properly.' }}</p>
      <div class="gh-tasting-banner__stats">
        {% for block in section.blocks %}
          <div class="gh-tasting-banner__stat" {{ block.shopify_attributes }}>
            <p class="gh-tasting-banner__value">{{ block.settings.value }}</p>
            <p class="gh-tasting-banner__label">{{ block.settings.label }}</p>
          </div>
        {% endfor %}
      </div>
      <div class="gh-tasting-banner__actions">
        <a href="{{ section.settings.btn_primary_url | default: '/pages/book-tasting' }}" class="gh-tasting-banner__btn gh-tasting-banner__btn--primary">
          {{ section.settings.btn_primary_label | default: 'Book a tasting' }}
        </a>
        <a href="{{ section.settings.btn_secondary_url | default: '/pages/visit' }}" class="gh-tasting-banner__btn gh-tasting-banner__btn--secondary">
          {{ section.settings.btn_secondary_label | default: 'Plan your visit' }}
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .gh-tasting-banner-{{ section.id }} {
    background: {{ section.settings.bg_color | default: '#000000' }};
    color: {{ section.settings.text_color | default: '#F5EFE3' }};
  }
  .gh-tasting-banner-{{ section.id }} .gh-tasting-banner__inner {
    max-width: 1280px;
    margin: 0 auto;
    min-height: 420px;
    display: grid;
    grid-template-columns: 1fr 1fr;
  }
  .gh-tasting-banner-{{ section.id }} .gh-tasting-banner__media {
    position: relative;
    min-height: 320px;
    background: #243324;
  }
  .gh-tasting-banner-{{ section.id }} .gh-tasting-banner__image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .gh-tasting-banner-{{ section.id }} .gh-tasting-banner__content {
    padding: 72px 64px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .gh-tasting-banner-{{ section.id }} .gh-tasting-banner__eyebrow {
    margin: 0 0 10px;
    color: var(--gh-dust);
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font: 500 10px/1.4 'Inter', sans-serif;
  }
  .gh-tasting-banner-{{ section.id }} .gh-tasting-banner__heading {
    font-family: 'EB Garamond', Georgia, serif;
    font-size: clamp(34px, 4vw, 54px);
    line-height: 1.06;
  }
  .gh-tasting-banner-{{ section.id }} .gh-tasting-banner__heading p {
    margin: 0;
  }
  .gh-tasting-banner-{{ section.id }} .gh-tasting-banner__heading em {
    color: var(--gh-gold-light);
  }
  .gh-tasting-banner-{{ section.id }} .gh-tasting-banner__body {
    margin: 16px 0 0;
    color: rgba(245, 239, 227, 0.75);
    font: 400 14px/1.7 'Inter', sans-serif;
  }
  .gh-tasting-banner-{{ section.id }} .gh-tasting-banner__stats {
    margin-top: 22px;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 12px;
  }
  .gh-tasting-banner-{{ section.id }} .gh-tasting-banner__value {
    margin: 0;
    color: var(--gh-gold-light);
    font: 400 32px/1.1 'EB Garamond', Georgia, serif;
  }
  .gh-tasting-banner-{{ section.id }} .gh-tasting-banner__label {
    margin: 6px 0 0;
    color: rgba(245, 239, 227, 0.68);
    text-transform: uppercase;
    letter-spacing: 0.13em;
    font: 500 10px/1.4 'Inter', sans-serif;
  }
  .gh-tasting-banner-{{ section.id }} .gh-tasting-banner__actions {
    margin-top: 28px;
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }
  .gh-tasting-banner-{{ section.id }} .gh-tasting-banner__btn {
    text-decoration: none;
    padding: 13px 20px;
    border-radius: 2px;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font: 600 10px/1 'Inter', sans-serif;
  }
  .gh-tasting-banner-{{ section.id }} .gh-tasting-banner__btn--primary {
    background: var(--gh-gold);
    border: 1px solid var(--gh-gold);
    color: var(--gh-cream);
  }
  .gh-tasting-banner-{{ section.id }} .gh-tasting-banner__btn--secondary {
    border: 1px solid rgba(245, 239, 227, 0.4);
    color: var(--gh-cream);
  }
  @media (max-width: 768px) {
    .gh-tasting-banner-{{ section.id }} .gh-tasting-banner__inner {
      grid-template-columns: 1fr;
    }
    .gh-tasting-banner-{{ section.id }} .gh-tasting-banner__content {
      padding: 60px 20px;
    }
  }
</style>

{% schema %}
{
  "name": "GH — Tasting banner",
  "max_blocks": 3,
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Left image" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Experience · Book ahead" },
    { "type": "richtext", "id": "heading", "label": "Heading", "default": "<p>Wine Tasting<br><em>in the heart of Barossa</em></p>" },
    { "type": "textarea", "id": "body", "label": "Body text", "default": "Our cellar door tastings are our labour of love. Groups of six or more are welcome — we simply ask you to book ahead so we can look after you properly." },
    { "type": "text", "id": "btn_primary_label", "label": "Primary CTA label", "default": "Book a tasting" },
    { "type": "url", "id": "btn_primary_url", "label": "Primary CTA URL" },
    { "type": "text", "id": "btn_secondary_label", "label": "Secondary CTA label", "default": "Plan your visit" },
    { "type": "url", "id": "btn_secondary_url", "label": "Secondary CTA URL" },
    { "type": "color", "id": "bg_color", "label": "Background colour", "default": "#000000" },
    { "type": "color", "id": "text_color", "label": "Text colour", "default": "#F5EFE3" }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Stat",
      "settings": [
        { "type": "text", "id": "value", "label": "Stat value", "default": "Thu–Sun" },
        { "type": "text", "id": "label", "label": "Stat label", "default": "Open days" }
      ]
    }
  ],
  "presets": [
    {
      "name": "GH — Tasting banner",
      "blocks": [
        { "type": "stat", "settings": { "value": "Thu–Sun", "label": "Open days" } },
        { "type": "stat", "settings": { "value": "11–5pm", "label": "Tasting hours" } },
        { "type": "stat", "settings": { "value": "6+", "label": "Groups book ahead" } }
      ]
    }
  ]
}
{% endschema %}
