      "max": 5,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "row_height",
      "label": "Row height (px)",
      "min": 140,
      "max": 400,
      "step": 10,
      "default": 200
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Gap between photos (px)",
      "min": 0,
      "max": 24,
      "step": 2,
      "default": 8
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top (px)",
      "min": 0,
      "max": 120,
      "step": 8,
      "default": 56
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom (px)",
      "min": 0,
      "max": 120,
      "step": 8,
      "default": 80
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background colour",
      "default": "#FDF8F2"
    },
    {
      "type": "header",
      "content": "Filters"
    },
    {
      "type": "checkbox",
      "id": "show_filters",
      "label": "Show category filter tabs",
      "default": true
    },
    {
      "type": "text",
      "id": "filter_all_label",
      "label": "\"All\" tab label",
      "default": "All"
    },
    {
      "type": "checkbox",
      "id": "show_category_chips",
      "label": "Show category chip on each photo",
      "default": false
    },
    {
      "type": "header",
      "content": "Load more"
    },
    {
      "type": "checkbox",
      "id": "show_load_more",
      "label": "Show load more button",
      "default": true
    },
    {
      "type": "range",
      "id": "items_per_page",
      "label": "Photos shown initially (and per load more)",
      "min": 4,
      "max": 48,
      "step": 4,
      "default": 12
    },
    {
      "type": "text",
      "id": "load_more_label",
      "label": "Load more button label",
