            { "value": "restaurant", "label": "Restaurant" },
            { "value": "events", "label": "Events" },
            { "value": "wines", "label": "Wines" },
            { "value": "accommodation", "label": "Accommodation" },
            { "value": "team", "label": "Team" }
          ],
          "default": "vineyard"
        },
        {
