          "id": "is_tall",
          "label": "Tall (spans 2 rows)",
          "default": false,
          "info": "Makes this photo twice as tall in the grid."
        },
        {
          "type": "checkbox",
          "id": "is_wide",
          "label": "Wide (spans 2 columns)",
          "default": false,
          "info": "Makes this photo twice as wide in the grid."
        }
      ]
