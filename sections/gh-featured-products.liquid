{% render 'gh-tokens' %}
{% assign featured = section.settings.collection %}

<section class="gh-featured-products gh-featured-products-{{ section.id }}" {{ section.shopify_attributes }}>
  <div class="gh-featured-products__wrap">
    <div class="gh-featured-products__header">
      <div>
        <p class="gh-featured-products__eyebrow">{{ section.settings.eyebrow | default: 'From the cellar' }}</p>
        <h2>{{ section.settings.heading | default: 'Featured Wines' }}</h2>
      </div>
      <a href="{{ section.settings.view_all_url | default: '/collections/all' }}" class="gh-featured-products__all">
        {{ section.settings.view_all_label | default: 'View all wines →' }}
      </a>
    </div>

    <div class="gh-featured-products__grid">
      {% if featured %}
        {% for product in featured.products limit: 3 %}
          {%- render 'gh-product-card', product: product, section: section, show_badge: section.settings.show_product_badge, badge_label: section.settings.badge_label -%}
        {% endfor %}
      {% endif %}

      <article class="gh-featured-products__promo">
        <p class="gh-featured-products__promo-eyebrow">{{ section.settings.promo_eyebrow | default: 'Limited offer' }}</p>
        <div class="gh-featured-products__promo-heading">
          {{ section.settings.promo_heading | default: '<p>Winter Wine <em>Specials Bundle</em></p>' }}
        </div>
        <p class="gh-featured-products__promo-body">{{ section.settings.promo_body | default: 'Order 12 bottles of your favourites and receive a complimentary bottle of Ennia by Tio, free delivery anywhere in Australia or NT.' }}</p>
        <p class="gh-featured-products__promo-price">{{ section.settings.promo_price | default: 'From $420' }}</p>
        <a href="{{ section.settings.promo_btn_url | default: '/collections/winter-specials' }}" class="gh-featured-products__promo-btn">
          {{ section.settings.promo_btn_label | default: 'Shop now' }}
        </a>
      </article>
    </div>
  </div>
</section>

<style>
  .gh-featured-products-{{ section.id }} {
    background: var(--gh-parchment);
    padding: 96px 40px;
  }
  .gh-featured-products-{{ section.id }} .gh-featured-products__wrap {
    max-width: 1280px;
    margin: 0 auto;
  }
  .gh-featured-products-{{ section.id }} .gh-featured-products__header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 20px;
    margin-bottom: 30px;
  }
  .gh-featured-products-{{ section.id }} .gh-featured-products__eyebrow {
    margin: 0 0 8px;
    font: 500 10px/1.4 'Inter', sans-serif;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--gh-dust);
  }
  .gh-featured-products-{{ section.id }} h2 {
    margin: 0;
    font: 400 clamp(32px, 4vw, 50px)/1.1 'EB Garamond', Georgia, serif;
    color: var(--gh-vine);
  }
  .gh-featured-products-{{ section.id }} .gh-featured-products__all {
    color: var(--gh-vine);
    text-decoration: none;
    font: 600 11px/1.2 'Inter', sans-serif;
    text-transform: uppercase;
    letter-spacing: 0.14em;
  }
  .gh-featured-products-{{ section.id }} .gh-featured-products__grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 24px;
  }
  .gh-featured-products-{{ section.id }} .gh-product-card {
    background: #fff;
    border: 1px solid rgba(0, 0, 0, 0.04);
    border-radius: 4px;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  .gh-featured-products-{{ section.id }} .gh-product-card__image-wrap {
    display: block;
    position: relative;
    height: 260px;
    overflow: hidden;
    border-radius: 4px 4px 0 0;
  }
  .gh-featured-products-{{ section.id }} .gh-product-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .gh-featured-products-{{ section.id }} .gh-product-card__badge {
    position: absolute;
    top: 12px;
    left: 12px;
    background: var(--gh-gold);
    color: var(--gh-cream);
    font: 600 10px/1 'Inter', sans-serif;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 6px 8px;
    border-radius: 2px;
    z-index: 1;
  }
  .gh-featured-products-{{ section.id }} .gh-product-card__body {
    padding: 14px 14px 16px;
  }
  .gh-featured-products-{{ section.id }} .gh-product-card__variety {
    margin: 0 0 8px;
    font: 500 12px/1.3 'Inter', sans-serif;
    letter-spacing: 0.11em;
    text-transform: uppercase;
    color: var(--gh-muted);
  }
  .gh-featured-products-{{ section.id }} .gh-product-card__title {
    margin: 0;
    font: 400 20px/1.2 'EB Garamond', Georgia, serif;
  }
  .gh-featured-products-{{ section.id }} .gh-product-card__title a {
    text-decoration: none;
    color: var(--gh-vine);
  }
  .gh-featured-products-{{ section.id }} .gh-product-card__meta {
    margin: 8px 0 0;
    font: 400 12px/1.3 'Inter', sans-serif;
    color: var(--gh-muted);
  }
  .gh-featured-products-{{ section.id }} .gh-product-card__row {
    margin-top: 14px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
  }
  .gh-featured-products-{{ section.id }} .gh-product-card__price {
    color: var(--gh-vine);
    font: 600 13px/1 'Inter', sans-serif;
  }
  .gh-featured-products-{{ section.id }} .gh-product-card__btn {
    font: 600 10px/1 'Inter', sans-serif;
    text-transform: uppercase;
    letter-spacing: 0.13em;
    text-decoration: none;
    color: var(--gh-vine);
    border: 1px solid rgba(28, 43, 26, 0.35);
    padding: 10px 12px;
    border-radius: 2px;
  }
  .gh-featured-products-{{ section.id }} .gh-featured-products__promo {
    background: {{ section.settings.promo_bg_color | default: '#1C2B1A' }};
    color: var(--gh-cream);
    border-radius: 4px;
    padding: 28px 24px;
    display: flex;
    flex-direction: column;
  }
  .gh-featured-products-{{ section.id }} .gh-featured-products__promo-eyebrow {
    margin: 0 0 10px;
    color: var(--gh-dust);
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font: 500 10px/1.4 'Inter', sans-serif;
  }
  .gh-featured-products-{{ section.id }} .gh-featured-products__promo-heading {
    font-family: 'EB Garamond', Georgia, serif;
    font-size: clamp(28px, 2vw, 36px);
    line-height: 1.1;
  }
  .gh-featured-products-{{ section.id }} .gh-featured-products__promo-heading p {
    margin: 0;
  }
  .gh-featured-products-{{ section.id }} .gh-featured-products__promo-heading em {
    color: var(--gh-gold-light);
  }
  .gh-featured-products-{{ section.id }} .gh-featured-products__promo-body {
    margin: 14px 0 0;
    color: rgba(245, 239, 227, 0.78);
    font: 400 13px/1.7 'Inter', sans-serif;
  }
  .gh-featured-products-{{ section.id }} .gh-featured-products__promo-price {
    margin: 20px 0 0;
    font: 500 20px/1.2 'EB Garamond', Georgia, serif;
  }
  .gh-featured-products-{{ section.id }} .gh-featured-products__promo-btn {
    margin-top: 14px;
    align-self: flex-start;
    text-decoration: none;
    background: var(--gh-gold);
    color: var(--gh-cream);
    border: 1px solid var(--gh-gold);
    padding: 12px 18px;
    font: 600 10px/1 'Inter', sans-serif;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    border-radius: 2px;
  }
  @media (prefers-reduced-motion: no-preference) {
    .gh-featured-products-{{ section.id }} .gh-product-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 10px 30px rgba(16, 21, 16, 0.13);
    }
  }
  @media (max-width: 1024px) {
    .gh-featured-products-{{ section.id }} .gh-featured-products__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
  @media (max-width: 600px) {
    .gh-featured-products-{{ section.id }} {
      padding: 60px 20px;
    }
    .gh-featured-products-{{ section.id }} .gh-featured-products__grid {
      grid-template-columns: 1fr;
    }
  }
</style>

{% schema %}
{
  "name": "GH — Featured products",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "From the cellar" },
    { "type": "text", "id": "heading", "label": "Section heading", "default": "Featured Wines" },
    { "type": "collection", "id": "collection", "label": "Product collection" },
    { "type": "text", "id": "view_all_label", "label": "View all button label", "default": "View all wines →" },
    { "type": "url", "id": "view_all_url", "label": "View all URL" },
    { "type": "text", "id": "promo_eyebrow", "label": "Promo card eyebrow", "default": "Limited offer" },
    { "type": "richtext", "id": "promo_heading", "label": "Promo card heading", "default": "<p>Winter Wine <em>Specials Bundle</em></p>" },
    { "type": "textarea", "id": "promo_body", "label": "Promo card body", "default": "Order 12 bottles of your favourites and receive a complimentary bottle of Ennia by Tio, free delivery anywhere in Australia or NT." },
    { "type": "text", "id": "promo_price", "label": "Promo price", "default": "From $420" },
    { "type": "text", "id": "promo_btn_label", "label": "Promo CTA label", "default": "Shop now" },
    { "type": "url", "id": "promo_btn_url", "label": "Promo CTA URL" },
    { "type": "color", "id": "promo_bg_color", "label": "Promo card background", "default": "#1C2B1A" },
    { "type": "checkbox", "id": "show_product_badge", "label": "Show \"Winter Special\" badge", "default": true },
    { "type": "text", "id": "badge_label", "label": "Badge label", "default": "Winter Special" }
  ],
  "presets": [{ "name": "GH — Featured products" }]
}
{% endschema %}
