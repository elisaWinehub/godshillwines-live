{%- render 'gh-tokens' -%}

<section class="gh-page-hero-block-{{ section.id }}">
  {%- render 'gh-page-hero',
    eyebrow: section.settings.hero_eyebrow,
    title: section.settings.hero_title,
    subheading: section.settings.hero_subheading,
    image: section.settings.hero_image,
    height: section.settings.hero_height,
    overlay_opacity: section.settings.overlay_opacity,
    content_alignment: section.settings.content_alignment
  -%}
</section>

{% schema %}
{
  "name": "GH — Page Hero",
  "settings": [
    { "type": "image_picker", "id": "hero_image", "label": "Background image" },
    { "type": "text", "id": "hero_eyebrow", "label": "Eyebrow text", "default": "God's Hill Wines" },
    { "type": "richtext", "id": "hero_title", "label": "Page title", "default": "<p>Page <em>Title</em></p>" },
    { "type": "text", "id": "hero_subheading", "label": "Subheading", "default": "" },
    { "type": "range", "id": "hero_height", "label": "Hero height (px)", "min": 240, "max": 600, "step": 20, "unit": "px", "default": 380 },
    { "type": "range", "id": "overlay_opacity", "label": "Overlay darkness %", "min": 0, "max": 90, "step": 5, "default": 55 },
    {
      "type": "select",
      "id": "content_alignment",
      "label": "Content alignment",
      "default": "left",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ]
    }
  ],
  "presets": [{ "name": "GH — Page Hero" }]
}
{% endschema %}
