{% liquid
  assign heading_weight = 400
  case section.settings.heading_font_weight
    when 'medium'
      assign heading_weight = 500
    when 'bold'
      assign heading_weight = 700
  endcase

  assign text_lh = section.settings.text_line_height | times: 1.0 | divided_by: 100.0

  assign text_font_style_css = 'normal'
  if section.settings.text_font_style == 'italic'
    assign text_font_style_css = 'italic'
  endif

  assign align_items = 'flex-start'
  assign text_align = 'start'
  case section.settings.text_alignment
    when 'center'
      assign align_items = 'center'
      assign text_align = 'center'
    when 'right'
      assign align_items = 'flex-end'
      assign text_align = 'end'
  endcase

  assign show_button = false
  if section.settings.button_label != blank and section.settings.button_link != blank
    assign show_button = true
  endif

  assign root_class = 'fullwidth-cta fullwidth-cta--scoped fullwidth-cta--' | append: section.id
-%}

<div
  class="{{ root_class }}"
  {{ section.shopify_attributes }}
  style="
    --fw-pad-top: {{ section.settings.section_padding_top }}px;
    --fw-pad-bottom: {{ section.settings.section_padding_bottom }}px;
    --fw-content-max: {{ section.settings.content_max_width }}px;
    --fw-bg: {{ section.settings.section_background_color }};
    --fw-align: {{ align_items }};
    --fw-text-align: {{ text_align }};
    --fw-heading-size: {{ section.settings.heading_font_size }}px;
    --fw-heading-weight: {{ heading_weight }};
    --fw-heading-color: {{ section.settings.heading_color }};
    --fw-text-size: {{ section.settings.text_font_size }}px;
    --fw-text-color: {{ section.settings.text_color }};
    --fw-text-style: {{ text_font_style_css }};
    --fw-text-lh: {{ text_lh }};
    --fw-btn-bg: {{ section.settings.button_background_color }};
    --fw-btn-text: {{ section.settings.button_text_color }};
    --fw-btn-bg-hover: {{ section.settings.button_hover_background_color }};
    --fw-btn-text-hover: {{ section.settings.button_hover_text_color }};
  "
>
  {% style %}
    .fullwidth-cta--{{ section.id }} .fullwidth-cta__band {
      width: 100vw;
      max-width: 100vw;
      margin-inline-start: calc(50% - 50vw);
      margin-inline-end: calc(50% - 50vw);
      background-color: var(--fw-bg);
      padding-block-start: var(--fw-pad-top);
      padding-block-end: var(--fw-pad-bottom);
      padding-inline: var(--page-margin, 1.25rem);
    }

    .fullwidth-cta--{{ section.id }} .fullwidth-cta__inner {
      width: 100%;
      max-width: var(--fw-content-max);
      margin-inline: auto;
      display: flex;
      flex-direction: column;
      align-items: var(--fw-align);
      text-align: var(--fw-text-align);
      gap: 1rem;
    }

    .fullwidth-cta--{{ section.id }} .fullwidth-cta__heading {
      margin: 0;
      font-family: var(--font-heading--family);
      font-weight: var(--fw-heading-weight);
      font-size: clamp(calc(var(--fw-heading-size) * 0.78), 4vw, var(--fw-heading-size));
      line-height: 1.12;
      color: var(--fw-heading-color);
      letter-spacing: 0.02em;
    }

    .fullwidth-cta--{{ section.id }} .fullwidth-cta__rte {
      margin: 0;
      font-size: clamp(calc(var(--fw-text-size) * 0.92), 2.4vw, var(--fw-text-size));
      line-height: var(--fw-text-lh);
      color: var(--fw-text-color);
      font-style: var(--fw-text-style);
      max-width: 62ch;
    }

    .fullwidth-cta--{{ section.id }} .fullwidth-cta__rte p:first-child {
      margin-block-start: 0;
    }

    .fullwidth-cta--{{ section.id }} .fullwidth-cta__rte p:last-child {
      margin-block-end: 0;
    }

    .fullwidth-cta--{{ section.id }} .fullwidth-cta__button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      margin-block-start: 0.25rem;
      padding: 0.65rem 1.5rem;
      text-decoration: none;
      font-size: 0.8125rem;
      font-weight: 500;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      border-radius: var(--style-border-radius-buttons-primary, 5px);
      background-color: var(--fw-btn-bg);
      color: var(--fw-btn-text);
      border: 2px solid var(--fw-btn-bg);
      transition: background-color var(--animation-speed, 0.2s) var(--animation-easing, ease),
        color var(--animation-speed, 0.2s) var(--animation-easing, ease),
        border-color var(--animation-speed, 0.2s) var(--animation-easing, ease);
    }

    .fullwidth-cta--{{ section.id }} .fullwidth-cta__button:hover {
      background-color: var(--fw-btn-bg-hover);
      color: var(--fw-btn-text-hover);
      border-color: var(--fw-btn-bg-hover);
    }
  {% endstyle %}

  <div class="fullwidth-cta__band">
    <div class="fullwidth-cta__inner">
      {% if section.settings.heading != blank %}
        <h2 class="fullwidth-cta__heading">{{ section.settings.heading | escape }}</h2>
      {% endif %}
      {% if section.settings.text_copy != blank %}
        <div class="fullwidth-cta__rte rte">{{ section.settings.text_copy }}</div>
      {% endif %}
      {% if show_button %}
        <a href="{{ section.settings.button_link }}" class="fullwidth-cta__button">
          {{- section.settings.button_label | escape -}}
        </a>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Fullwidth CTA",
  "class": "section-wrapper",
  "disabled_on": { "groups": ["header"] },
  "settings": [
    { "type": "header", "content": "General" },
    {
      "type": "color",
      "id": "section_background_color",
      "label": "Background color",
      "default": "#AA932D"
    },
    {
      "type": "range",
      "id": "section_padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "default": 36
    },
    {
      "type": "range",
      "id": "section_padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "default": 36
    },
    {
      "type": "range",
      "id": "content_max_width",
      "label": "Content max width",
      "min": 480,
      "max": 1200,
      "step": 20,
      "unit": "px",
      "default": 920
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    { "type": "header", "content": "Content" },
    { "type": "text", "id": "heading", "label": "Heading" },
    { "type": "richtext", "id": "text_copy", "label": "Text" },
    { "type": "text", "id": "button_label", "label": "Button label" },
    { "type": "url", "id": "button_link", "label": "Button link" },
    { "type": "header", "content": "Typography" },
    {
      "type": "range",
      "id": "heading_font_size",
      "label": "Heading font size",
      "min": 22,
      "max": 52,
      "step": 1,
      "unit": "px",
      "default": 34
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#ffffff"
    },
    {
      "type": "select",
      "id": "heading_font_weight",
      "label": "Heading weight",
      "options": [
        { "value": "regular", "label": "Regular" },
        { "value": "medium", "label": "Medium" },
        { "value": "bold", "label": "Bold" }
      ],
      "default": "medium"
    },
    {
      "type": "range",
      "id": "text_font_size",
      "label": "Text font size",
      "min": 14,
      "max": 22,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#F7F3E8"
    },
    {
      "type": "select",
      "id": "text_font_style",
      "label": "Text style",
      "options": [
        { "value": "regular", "label": "Regular" },
        { "value": "italic", "label": "Italic" }
      ],
      "default": "regular"
    },
    {
      "type": "range",
      "id": "text_line_height",
      "label": "Text line height (×0.01)",
      "min": 140,
      "max": 200,
      "step": 5,
      "default": 165
    },
    { "type": "header", "content": "Button" },
    {
      "type": "color",
      "id": "button_background_color",
      "label": "Background",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Text",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_hover_background_color",
      "label": "Hover background",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "button_hover_text_color",
      "label": "Hover text",
      "default": "#ffffff"
    }
  ],
  "presets": [{ "name": "Fullwidth CTA", "category": "t:categories.banners" }]
}
{% endschema %}
