{%- assign rel_count = 0 -%}
<section class="gh-art-related-{{ section.id }}">
  <div class="gh-art-related-inner-{{ section.id }}">
    <div class="gh-art-related-head-{{ section.id }}">
      <h2 class="gh-art-related-heading-{{ section.id }}">
        {{ section.settings.heading | default: 'More from News & Events' }}
      </h2>
      <a href="{{ blog.url }}" class="gh-art-related-link-{{ section.id }}">
        {{ section.settings.view_all_label | default: 'View all →' }}
      </a>
    </div>

    <div class="gh-art-related-grid-{{ section.id }}">
      {% for a in blog.articles %}
        {% if a.id != article.id and rel_count < 3 %}
          {%- assign rel_count = rel_count | plus: 1 -%}
          {%- assign a_category = '' -%}
          {%- for tag in a.tags -%}
            {%- unless tag == 'featured' -%}
              {%- assign a_category = tag -%}
              {%- break -%}
            {%- endunless -%}
          {%- endfor -%}

          <a href="{{ a.url }}" class="gh-art-rel-card-{{ section.id }}">
            <div class="gh-art-rel-card-img-{{ section.id }}">
              {% if a.image %}
                {{ a.image | image_url: width: 600 | image_tag: loading: 'lazy', alt: a.image.alt | default: a.title }}
              {% else %}
                <div class="gh-art-rel-card-placeholder-{{ section.id }}">
                  <svg width="36" height="36" fill="none" stroke="currentColor" stroke-width="1" viewBox="0 0 24 24" aria-hidden="true">
                    <rect x="3" y="3" width="18" height="18" rx="2"/>
                    <circle cx="8.5" cy="8.5" r="1.5"/>
                    <polyline points="21 15 16 10 5 21"/>
                  </svg>
                </div>
              {% endif %}
              <div class="gh-art-rel-badge-{{ section.id }}">
                {%- render 'gh-blog-tag-pill', tag: a_category -%}
              </div>
            </div>
            <div class="gh-art-rel-body-{{ section.id }}">
              <p class="gh-art-rel-meta-{{ section.id }}">{{ a.published_at | date: '%d %B %Y' }}</p>
              <h3 class="gh-art-rel-title-{{ section.id }}">{{ a.title }}</h3>
              <div class="gh-art-rel-footer-{{ section.id }}">
                <span class="gh-art-rel-read-{{ section.id }}">Read more →</span>
              </div>
            </div>
          </a>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

<style>
  .gh-art-related-{{ section.id }} {
    --vine: #1C2B1A;
    --cream: #F5EFE3;
    --gold: #B8913A;
    --border: rgba(28,43,26,0.1);
    background: {{ section.settings.bg_color | default: '#F5EFE3' }};
    padding: 72px 40px;
  }
  .gh-art-related-inner-{{ section.id }} { max-width: 1280px; margin: 0 auto; }
  .gh-art-related-head-{{ section.id }} {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 36px;
    padding-bottom: 16px;
    border-bottom: 0.5px solid rgba(28,43,26,0.12);
  }
  .gh-art-related-heading-{{ section.id }} {
    font-family: 'EB Garamond', Georgia, serif;
    font-size: 28px;
    font-weight: 400;
    color: var(--vine);
    margin: 0;
  }
  .gh-art-related-link-{{ section.id }} {
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--gold);
    text-decoration: none;
  }
  .gh-art-related-grid-{{ section.id }} {
    display: grid;
    grid-template-columns: repeat(3,1fr);
    gap: 24px;
  }
  .gh-art-rel-card-{{ section.id }} {
    background: white;
    border: 0.5px solid var(--border);
    border-radius: 5px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: transform 0.25s, box-shadow 0.25s;
    text-decoration: none;
    color: inherit;
  }
  @media (prefers-reduced-motion: no-preference) {
    .gh-art-rel-card-{{ section.id }}:hover {
      transform: translateY(-4px);
      box-shadow: 0 12px 40px rgba(28,43,26,0.09);
    }
  }
  .gh-art-rel-card-img-{{ section.id }} {
    height: 200px;
    overflow: hidden;
    position: relative;
    background: var(--cream);
    flex-shrink: 0;
  }
  .gh-art-rel-card-img-{{ section.id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s;
    display: block;
  }
  @media (prefers-reduced-motion: no-preference) {
    .gh-art-rel-card-{{ section.id }}:hover .gh-art-rel-card-img-{{ section.id }} img {
      transform: scale(1.05);
    }
  }
  .gh-art-rel-card-placeholder-{{ section.id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #F0EAE0 0%, #E2D9CC 100%);
    color: rgba(28,43,26,0.25);
  }
  .gh-art-rel-badge-{{ section.id }} { position: absolute; top: 12px; left: 12px; }
  .gh-art-rel-body-{{ section.id }} {
    padding: 20px 20px 22px;
    display: flex;
    flex-direction: column;
    flex: 1;
  }
  .gh-art-rel-meta-{{ section.id }} {
    font-size: 10px;
    color: #6B7668;
    letter-spacing: 0.04em;
    margin: 6px 0 8px;
  }
  .gh-art-rel-title-{{ section.id }} {
    font-family: 'EB Garamond', Georgia, serif;
    font-size: 19px;
    font-weight: 400;
    color: var(--vine);
    line-height: 1.28;
    margin-bottom: 8px;
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    transition: color 0.2s;
  }
  .gh-art-rel-card-{{ section.id }}:hover .gh-art-rel-title-{{ section.id }} { color: var(--gold); }
  .gh-art-rel-footer-{{ section.id }} {
    margin-top: auto;
    padding-top: 12px;
    border-top: 0.5px solid var(--border);
  }
  .gh-art-rel-read-{{ section.id }} {
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--gold);
  }
  @media (max-width: 900px) {
    .gh-art-related-grid-{{ section.id }} { grid-template-columns: repeat(2,1fr); }
    .gh-art-related-{{ section.id }} { padding: 52px 20px; }
  }
  @media (max-width: 540px) {
    .gh-art-related-grid-{{ section.id }} { grid-template-columns: 1fr; }
  }
</style>

{% schema %}
{
  "name": "GH — Article Related",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "More from News & Events"
    },
    {
      "type": "text",
      "id": "view_all_label",
      "label": "View all link label",
      "default": "View all →"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background colour",
      "default": "#F5EFE3"
    }
  ],
  "presets": [
    { "name": "GH — Article Related" }
  ]
}
{% endschema %}
