{% comment %} Standalone storefront header tuned for God's Hill Wines mockup {% endcomment %}
{% liquid
  assign menu_obj = section.settings.menu
  assign gh_overlay = false
  if section.settings.overlay_hero
    if template.name == 'index' and section.settings.overlay_on_home
      assign gh_overlay = true
    elsif template.name == 'collection' and section.settings.overlay_on_collection
      assign gh_overlay = true
    elsif section.settings.overlay_on_page_hero
      unless template.name == 'index' or template.name == 'collection' or template.name == 'product'
        assign gh_overlay = true
      endunless
    endif
  endif
%}
<div
  data-gh-custom-header="{{ section.id }}"
  {% if gh_overlay %}data-gh-overlay="true"{% endif %}
  {% if gh_overlay %}data-scrolled="false"{% endif %}
  class="gh-ch-wrap {{ section.settings.custom_css }} {% if section.settings.sticky %}gh-ch-wrap--sticky{% endif %}"
  {{ section.shopify_attributes }}
>
  <div
    id="GhHdr-{{ section.id }}"
    style="
      --hdr-h-mobile: {{ section.settings.height_mobile }}px;
      --hdr-h-desktop: {{ section.settings.header_height_desktop }}px;
      --hdr-icon: {{ section.settings.icon_colour }};
      --hdr-icon-overlay: {{ section.settings.overlay_icon_color }};
      --gh-nav-active: {{ section.settings.nav_color }};
      --gh-nav-overlay: {{ section.settings.overlay_nav_color }};
      --gh-header-bg-scrolled: {{ section.settings.scrolled_bg_color | default: '#000000f7' }};
      --nav-fw: {{ section.settings.nav_font_weight }};
      --nav-size: {{ section.settings.nav_font_size }}px;
      --bp: {{ section.settings.mobile_breakpoint }}px;
      --gh-scroll-threshold: {{ section.settings.overlay_scroll_threshold }}px;
    "
    class="gh-hdr-shell"
    role="banner"
  >
    <div class="gh-hdr-bar">
      {%- assign gh_default_logo = section.settings.logo_fallback_image | default: settings.logo -%}
      {%- assign gh_scrolled_logo = section.settings.logo_scrolled_image | default: gh_default_logo -%}
      {% if gh_default_logo != blank %}
        <a href="{{ routes.root_url }}" class="gh-hdr-logo" aria-label="{{ shop.name }}">
          {{
            gh_default_logo
            | image_url: width: section.settings.logo_image_width_px
            | image_tag:
              loading: 'eager',
              fetchpriority: 'high',
              class: 'gh-hdr-logo-img gh-hdr-logo-img--default',
              widths: '120,180,240,320',
              alt: shop.name
          }}
          {{
            gh_scrolled_logo
            | image_url: width: section.settings.logo_image_width_px
            | image_tag:
              loading: 'eager',
              fetchpriority: 'high',
              class: 'gh-hdr-logo-img gh-hdr-logo-img--scrolled',
              widths: '120,180,240,320',
              alt: shop.name
          }}
        </a>
      {% else %}
        <a href="{{ routes.root_url }}" class="gh-hdr-wordmark">{{ section.settings.logo_text_line_one | escape }}<small>{{ section.settings.logo_text_line_two }}</small></a>
      {% endif %}

      {% if menu_obj != blank %}
        <nav class="gh-hdr-nav" aria-label="Primary navigation">
          <ul role="menu" class="gh-hdr-ul">
            {% for link in menu_obj.links %}
              <li role="presentation" class="{% if link.links.size > 0 %}gh-has-drop{% endif %}">
                {% if link.links.size > 0 %}
                  <div class="gh-drop">
                    <a href="{{ link.url }}" aria-haspopup="true" aria-expanded="false">{{ link.title }}</a>
                    <ul role="menu" class="gh-sub">
                      {% for child in link.links %}
                        <li role="presentation">
                          <a role="menuitem" href="{{ child.url }}">{{ child.title }}</a>
                        </li>
                      {% endfor %}
                    </ul>
                  </div>
                {% else %}
                  <a href="{{ link.url }}">{{ link.title }}</a>
                {% endif %}
              </li>
            {% endfor %}
          </ul>
        </nav>
      {% endif %}

      <div class="gh-util">
        {% if section.settings.book_btn_enabled and section.settings.book_btn_label != blank %}
          <a class="gh-book-btn" href="{{ section.settings.book_btn_url | default: '/pages/book' }}">
            {{ section.settings.book_btn_label }}
          </a>
        {% endif %}

        {% if shop.customer_accounts_enabled %}
          <a class="gh-icon gh-icon--account" href="{{ routes.account_url }}" aria-label="{{ 'content.account_title' | t | default: 'Account' }}">
            <span class="gh-icon__svg" aria-hidden="true">{{ 'icon-account.svg' | inline_asset_content }}</span>
          </a>
        {% endif %}

        {% if template != 'cart' %}
          {% if settings.cart_type == 'drawer' %}
            <button
              type="button"
              class="gh-icon gh-icon--cart button-unstyled"
              data-gh-open-cart-drawer
              aria-label="{{ 'content.cart_title' | t | default: 'Cart' }}"
            >
              <span class="gh-icon__svg" aria-hidden="true">{{ 'icon-cart.svg' | inline_asset_content }}</span>
            </button>
          {% else %}
            <a href="{{ routes.cart_url }}" class="gh-icon gh-icon--cart" aria-label="{{ 'content.cart_title' | t | default: 'Cart' }}">
              <span class="gh-icon__svg" aria-hidden="true">{{ 'icon-cart.svg' | inline_asset_content }}</span>
            </a>
          {% endif %}
        {% endif %}

        {% if section.settings.social_instagram != blank %}
          <a href="{{ section.settings.social_instagram }}" class="gh-icon" aria-label="Instagram" target="_blank" rel="noopener">⌾</a>
        {% endif %}
        {% if section.settings.social_facebook != blank %}
          <a href="{{ section.settings.social_facebook }}" class="gh-icon" aria-label="Facebook" target="_blank" rel="noopener">ƒ</a>
        {% endif %}

        {% if section.settings.social_email != blank %}
          <a class="gh-icon" href="mailto:{{ section.settings.social_email }}" aria-label="Email correspondence">✉</a>
        {% endif %}

        {% if menu_obj != blank and menu_obj.links.size > 0 %}
          <button class="gh-burger js-ghburger" type="button" aria-expanded="false" aria-controls="GhHdrDrawer-{{ section.id }}"><span aria-hidden="true">☰</span></button>
        {% endif %}
      </div>
    </div>
  </div>

  {% if menu_obj != blank %}
    <div id="GhHdrDrawer-{{ section.id }}" class="gh-drawer" aria-hidden="true">
      <div class="gh-drawer-head">
        <button class="gh-drawer-close js-ghdrawer-close" type="button" aria-label="Close menu">✕</button>
      </div>
      {% for link in menu_obj.links %}
        <div class="gh-drawer-entry">
          <div class="gh-drawer-parent">
            <a href="{{ link.url }}" class="gh-draw-main">{{ link.title }}</a>
            {% if link.links.size > 0 %}
              <button class="js-accordion" type="button" aria-expanded="false" aria-label="Toggle submenu">
                ›
              </button>
            {% endif %}
          </div>
          {% if link.links.size %}
            <ul class="gh-draw-sub" hidden>
              {% for child in link.links %}
                <li><a href="{{ child.url }}">{{ child.title }}</a></li>
              {% endfor %}
            </ul>
          {% endif %}
        </div>
      {% endfor %}

      {% if shop.customer_accounts_enabled %}
        <a class="gh-draw-link" href="{{ routes.account_url }}">Account centre</a>
      {% endif %}
      {% if section.settings.book_btn_enabled and section.settings.book_btn_label != blank %}
        <a class="gh-draw-link gh-draw-link--book" href="{{ section.settings.book_btn_url | default: '/pages/book' }}">
          {{ section.settings.book_btn_label }}
        </a>
      {% endif %}
      {% if settings.cart_type %}
        <a class="gh-draw-link" href="{{ routes.cart_url }}">{{ 'Checkout cart' }}</a>
      {% endif %}
    </div>
  {% endif %}
</div>

<style>
  body:has(div[data-gh-custom-header="{{ section.id }}"]) {
    --header-height: max({{ section.settings.header_height_desktop }}px, 100px);
    --top-row-height: max({{ section.settings.header_height_desktop }}px, 100px);
    --gh-header-overlay-nudge: 26px;
  }
  @media screen and (max-width: {{ section.settings.mobile_breakpoint }}px) {
    body:has(div[data-gh-custom-header="{{ section.id }}"]) {
      --header-height: max({{ section.settings.height_mobile }}px, 76px);
      --top-row-height: max({{ section.settings.height_mobile }}px, 76px);
      --gh-header-overlay-nudge: 12px;
    }
  }
  div[data-gh-custom-header="{{ section.id }}"] {
    contain: none;
    min-height: max(var(--hdr-h-desktop), 100px);
  }
  .shopify-section.gh-custom-store-header[data-gh-section-header="{{ section.id }}"] {
    transition: background-color 0.28s ease, box-shadow 0.28s ease;
  }
  .shopify-section.gh-custom-store-header[data-gh-section-header="{{ section.id }}"][data-gh-overlay='true'][data-scrolled='true'] {
    background-color: {{ section.settings.scrolled_bg_color | default: '#000000f7' }};
    box-shadow: 0 {{ section.settings.border_width_below }}px 16px rgb(0 0 0 / {{ section.settings.shadow_strength | divided_by: 100.0 }});
  }
  .shopify-section.gh-custom-store-header[data-gh-section-header="{{ section.id }}"][data-gh-overlay='false'],
  .shopify-section.gh-custom-store-header[data-gh-section-header="{{ section.id }}"]:not([data-gh-overlay]) {
    background-color: {{ section.settings.header_bg_color | default: '#ffffff' }};
    box-shadow: 0 {{ section.settings.border_width_below }}px 16px rgb(0 0 0 / {{ section.settings.shadow_strength | divided_by: 100.0 }});
  }
  .shopify-section.gh-custom-store-header[data-gh-section-header="{{ section.id }}"][data-gh-overlay='true'][data-scrolled='false'] {
    background: transparent;
    box-shadow: none;
  }
  .shopify-section.gh-custom-store-header[data-gh-section-header="{{ section.id }}"][data-gh-sticky='true'][data-scroll-armed='true'] {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    width: 100%;
    z-index: 80;
    box-shadow: none;
    transform: translateY(calc(-100% - 8px));
    opacity: 0;
    pointer-events: none;
    transition: transform 0.28s ease, opacity 0.22s ease, background-color 0.28s ease, box-shadow 0.28s ease;
  }
  .shopify-section.gh-custom-store-header[data-gh-section-header="{{ section.id }}"][data-gh-sticky='true'][data-scroll-armed='true'][data-scroll-reveal='true'] {
    transform: translateY(0);
    opacity: 1;
    pointer-events: auto;
  }
  #GhHdr-{{ section.id }}.gh-hdr-shell {
    background: transparent;
    box-shadow: none;
    transition: background-color 0.28s ease, box-shadow 0.28s ease;
    overflow: visible;
    height: max(var(--hdr-h-desktop), 100px);
    box-sizing: border-box;
  }
  div[data-gh-custom-header="{{ section.id }}"][data-gh-overlay='true']:not([data-scrolled='true']) #GhHdr-{{ section.id }}.gh-hdr-shell {
    background: transparent;
    box-shadow: none;
  }
  div[data-gh-custom-header="{{ section.id }}"][data-gh-overlay='true']:not([data-scrolled='true']) #GhHdr-{{ section.id }} .gh-hdr-ul > li > a,
  div[data-gh-custom-header="{{ section.id }}"][data-gh-overlay='true']:not([data-scrolled='true']) #GhHdr-{{ section.id }} .gh-hdr-ul > li > .gh-drop > a {
    color: var(--gh-nav-overlay);
  }
  div[data-gh-custom-header="{{ section.id }}"][data-gh-overlay='true']:not([data-scrolled='true']) #GhHdr-{{ section.id }} .gh-hdr-wordmark {
    color: var(--gh-nav-overlay);
  }
  div[data-gh-custom-header="{{ section.id }}"][data-gh-overlay='true'][data-scrolled='true'] #GhHdr-{{ section.id }} .gh-hdr-ul > li > a,
  div[data-gh-custom-header="{{ section.id }}"][data-gh-overlay='true'][data-scrolled='true'] #GhHdr-{{ section.id }} .gh-hdr-ul > li > .gh-drop > a,
  div[data-gh-custom-header="{{ section.id }}"][data-gh-overlay='true'][data-scrolled='true'] #GhHdr-{{ section.id }} .gh-hdr-wordmark {
    color: {{ section.settings.nav_color | default: '#000000' }};
  }
  div[data-gh-custom-header="{{ section.id }}"][data-gh-overlay='true'][data-scrolled='true'] #GhHdr-{{ section.id }} .gh-icon--account,
  div[data-gh-custom-header="{{ section.id }}"][data-gh-overlay='true'][data-scrolled='true'] #GhHdr-{{ section.id }} .gh-icon--cart {
    color: {{ section.settings.nav_color | default: '#000000' }};
  }
  div[data-gh-custom-header="{{ section.id }}"][data-gh-overlay='true']:not([data-scrolled='true']) #GhHdr-{{ section.id }} .gh-icon,
  div[data-gh-custom-header="{{ section.id }}"][data-gh-overlay='true']:not([data-scrolled='true']) #GhHdr-{{ section.id }} .gh-burger {
    color: var(--hdr-icon-overlay);
  }
  #GhHdr-{{ section.id }} .gh-hdr-bar {
    margin: 0 auto;
    max-width: {{ section.settings.maximum_width_px }}px;
    height: 100%;
    box-sizing: border-box;
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    align-items: center;
    gap: clamp(14px, 3vw, 34px);
    padding-block: clamp(12px, 2vw, 18px);
    padding-inline: {{ section.settings.inner_gutter }};
    overflow: visible;
  }
  #GhHdr-{{ section.id }} .gh-hdr-logo img {
    max-width: {{ section.settings.logo_image_width_px }}px;
    width: 100%;
    max-height: 85px;
    height: auto;
    object-fit: contain;
    display: block;
  }
  #GhHdr-{{ section.id }} .gh-hdr-logo {
    display: inline-flex;
    align-items: center;
    padding-bottom: 6px;
  }
  #GhHdr-{{ section.id }} .gh-hdr-logo .gh-hdr-logo-img--scrolled {
    display: none;
  }
  #GhHdr-{{ section.id }} .gh-hdr-logo .gh-hdr-logo-img--default {
    display: block;
  }
  div[data-gh-custom-header="{{ section.id }}"][data-gh-overlay='true'][data-scrolled='true'] #GhHdr-{{ section.id }} .gh-hdr-logo-img--default,
  div[data-gh-custom-header="{{ section.id }}"]:not([data-gh-overlay='true']) #GhHdr-{{ section.id }} .gh-hdr-logo-img--default {
    display: none;
  }
  div[data-gh-custom-header="{{ section.id }}"][data-gh-overlay='true'][data-scrolled='true'] #GhHdr-{{ section.id }} .gh-hdr-logo-img--scrolled,
  div[data-gh-custom-header="{{ section.id }}"]:not([data-gh-overlay='true']) #GhHdr-{{ section.id }} .gh-hdr-logo-img--scrolled {
    display: block;
  }
  #GhHdr-{{ section.id }} .gh-hdr-wordmark {
    text-decoration: none;
    font-family: Georgia, serif;
    font-weight: 600;
    color: {{ section.settings.nav_color | default: '#000000' }};
    letter-spacing: 0.04em;
  }
  #GhHdr-{{ section.id }} .gh-hdr-wordmark small {
    display: block;
    font-size: 10px;
    letter-spacing: 0.32em;
    text-align: center;
    color: {{ section.settings.secondary_brand_colour }};
  }

  #GhHdr-{{ section.id }} .gh-hdr-nav {
    justify-self: center;
    width: 100%;
    max-width: 920px;
    padding-inline: clamp(12px, 2vw, 40px);
    box-sizing: border-box;
    overflow: visible;
  }
  #GhHdr-{{ section.id }} .gh-hdr-ul {
    list-style: none;
    padding: 0;
    margin: 0 auto;
    display: flex;
    justify-content: center;
    gap: clamp(16px,{{ section.settings.nav_gap_px }}px,54px);
    overflow: visible;
  }
  #GhHdr-{{ section.id }} .gh-hdr-ul > li {
    position: relative;
    overflow: visible;
  }
  #GhHdr-{{ section.id }} .gh-hdr-ul > li > a,
  #GhHdr-{{ section.id }} .gh-hdr-ul > li > .gh-drop > a {
    text-decoration: none;
    text-transform: uppercase;
    font-family: 'Inter', sans-serif;
    color: {{ section.settings.nav_color | default: '#000000' }};
    font-size: 12px;
    font-weight: 400;
    letter-spacing: 0.08em;
  }
  #GhHdr-{{ section.id }} .gh-drop {
    position: relative;
  }
  #GhHdr-{{ section.id }} .gh-has-drop > .gh-drop::after {
    content: '';
    position: absolute;
    left: -20px;
    right: -20px;
    top: 100%;
    height: 20px;
  }
  #GhHdr-{{ section.id }} .gh-has-drop > .gh-drop > a::after {
    content: '';
    display: inline-block;
    width: 5px;
    height: 5px;
    margin-left: 0.48em;
    vertical-align: 0.18em;
    border-right: 1.5px solid currentColor;
    border-bottom: 1.5px solid currentColor;
    transform: rotate(45deg);
    opacity: 0.78;
  }
  #GhHdr-{{ section.id }} .gh-sub {
    opacity: 0;
    pointer-events: none;
    visibility: hidden;
    position: absolute;
    top: 100%;
    left: -12px;
    min-width: 220px;
    margin: 0;
    background: {{ section.settings.dropdown_bg_color | default: '#ffffff' }};
    box-shadow: 0 20px 50px rgb(8 43 62 / {{ section.settings.dropdown_shadow_pct | divided_by: 120.0 }});
    list-style: none;
    padding: 8px 0;
    border-top: {{ section.settings.dropdown_accent_thickness_px }}px solid {{ section.settings.dropdown_accent_color }};
    transition: opacity 0.18s ease, visibility 0.18s ease;
    z-index: 20;
  }
  #GhHdr-{{ section.id }} .gh-drop:hover > .gh-sub,
  #GhHdr-{{ section.id }} .gh-drop:focus-within > .gh-sub {
    opacity: 1;
    pointer-events: auto;
    visibility: visible;
  }
  #GhHdr-{{ section.id }} .gh-sub li {
    transition: background-color 0.15s ease;
  }
  #GhHdr-{{ section.id }} .gh-sub li:hover,
  #GhHdr-{{ section.id }} .gh-sub li:focus-within {
    background: {{ section.settings.dropdown_accent_color | default: '#a67b22' }};
  }
  #GhHdr-{{ section.id }} .gh-sub a {
    display: block;
    padding: 8px 20px;
    color: {{ section.settings.dropdown_link_color | default: '#000000' }};
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: none;
    transition: color 0.15s ease, background-color 0.15s ease;
  }
  div[data-gh-custom-header="{{ section.id }}"][data-gh-overlay='true']:not([data-scrolled='true']) #GhHdr-{{ section.id }} .gh-sub a,
  div[data-gh-custom-header="{{ section.id }}"][data-gh-overlay='true'][data-scrolled='true'] #GhHdr-{{ section.id }} .gh-sub a {
    color: {{ section.settings.dropdown_link_color | default: '#000000' }};
  }
  #GhHdr-{{ section.id }} .gh-sub li:hover a,
  #GhHdr-{{ section.id }} .gh-sub li:focus-within a {
    color: #ffffff;
  }

  #GhHdr-{{ section.id }} .gh-util {
    justify-self: end;
    display: inline-flex;
    align-items: center;
    gap: clamp(10px,{{ section.settings.utilities_gap_px }}px,20px);
  }
  #GhHdr-{{ section.id }} .gh-icon {
    color: var(--hdr-icon);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  #GhHdr-{{ section.id }} .gh-icon--account,
  #GhHdr-{{ section.id }} .gh-icon--cart {
    color: {{ section.settings.nav_color | default: '#000000' }};
  }
  div[data-gh-custom-header="{{ section.id }}"][data-gh-overlay='true']:not([data-scrolled='true']) #GhHdr-{{ section.id }} .gh-icon--account,
  div[data-gh-custom-header="{{ section.id }}"][data-gh-overlay='true']:not([data-scrolled='true']) #GhHdr-{{ section.id }} .gh-icon--cart {
    color: var(--hdr-icon-overlay);
  }
  #GhHdr-{{ section.id }} .gh-icon__svg {
    display: flex;
    width: clamp(18px, {{ section.settings.icon_scale_pct | divided_by: 5.5 }}px, 22px);
    height: clamp(18px, {{ section.settings.icon_scale_pct | divided_by: 5.5 }}px, 22px);
  }
  #GhHdr-{{ section.id }} .gh-icon__svg svg {
    width: 100%;
    height: 100%;
  }
  #GhHdr-{{ section.id }} .gh-book-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 9px 18px;
    border-radius: 2px;
    background: {{ section.settings.book_btn_bg | default: '#B8913A' }};
    color: {{ section.settings.book_btn_text | default: '#FDF8F2' }};
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 11px;
    font-weight: 500;
    white-space: nowrap;
    transition: background-color 0.2s ease;
  }
  #GhHdr-{{ section.id }} .gh-book-btn:hover {
    background: {{ section.settings.book_btn_bg_hover | default: '#9A7A30' }};
  }
  #GhHdr-{{ section.id }} .gh-burger {
    display: none;
    background: transparent;
    border: 0;
    font-size: 28px;
    padding: 0 4px;
    color: var(--hdr-icon);
  }
  #GhHdr-{{ section.id }} .gh-icon--cart.button-unstyled {
    cursor: pointer;
    font: inherit;
    padding: 0;
  }

  @media screen and (max-width: 1180px) and (min-width: {{ section.settings.mobile_breakpoint | plus: 1 }}px) {
    #GhHdr-{{ section.id }} .gh-hdr-bar {
      grid-template-columns: auto minmax(0, 1fr) auto;
      gap: clamp(10px, 2vw, 22px);
      padding-inline: clamp(18px, 3vw, 40px);
    }
    #GhHdr-{{ section.id }} .gh-hdr-logo img {
      max-width: min({{ section.settings.logo_image_width_px }}px, 120px);
    }
    #GhHdr-{{ section.id }} .gh-hdr-ul {
      gap: clamp(12px, 1.6vw, 24px);
    }
    #GhHdr-{{ section.id }} .gh-hdr-ul > li > a,
    #GhHdr-{{ section.id }} .gh-hdr-ul > li > .gh-drop > a {
      font-size: 11px;
      letter-spacing: 0.06em;
    }
    #GhHdr-{{ section.id }} .gh-util {
      gap: 10px;
    }
    #GhHdr-{{ section.id }} .gh-book-btn {
      padding: 8px 14px;
      font-size: 10px;
    }
  }

  @media screen and (max-width: {{ section.settings.mobile_breakpoint }}px) {
    div[data-gh-custom-header="{{ section.id }}"] {
      min-height: max(var(--hdr-h-mobile), 76px);
    }
    #GhHdr-{{ section.id }}.gh-hdr-shell {
      height: max(var(--hdr-h-mobile), 76px);
    }
    #GhHdr-{{ section.id }} .gh-hdr-bar {
      display: flex !important;
      flex-direction: row !important;
      align-items: center !important;
      justify-content: space-between !important;
      grid-template-columns: unset !important;
      gap: 12px;
      height: 64px;
      padding: 0 16px;
      flex-wrap: nowrap;
    }
    #GhHdr-{{ section.id }} .gh-hdr-logo img {
      max-height: calc(var(--hdr-h-mobile) - 12px);
    }
    #GhHdr-{{ section.id }} .gh-hdr-logo {
      padding-bottom: 3px;
      flex: 0 0 auto;
    }
    #GhHdr-{{ section.id }} .gh-hdr-nav {
      display: none !important;
    }
    #GhHdr-{{ section.id }} .gh-hdr-ul {
      display: none !important;
    }
    #GhHdr-{{ section.id }} .gh-util {
      display: flex !important;
      flex-direction: row !important;
      align-items: center !important;
      gap: 4px;
      flex: 0 0 auto;
      margin-left: auto;
      justify-self: auto;
    }
    #GhHdr-{{ section.id }} .gh-book-btn {
      display: none !important;
    }
    #GhHdr-{{ section.id }} .gh-burger {
      display: block;
    }
  }

  #GhHdrDrawer-{{ section.id }}.gh-drawer {
    position: fixed;
    top: 0;
    left: 0;
    height: 100vh;
    width: min(420px, {{ section.settings.mobile_draw_width_pct }}vw);
    max-width: 100%;
    background: {{ section.settings.drawer_bg_color }};
    box-shadow: 8px 0 30px rgb(0 0 0 / {{ section.settings.drawer_shadow_pct | divided_by: 100.0 }});
    padding: calc(var(--hdr-h-desktop) + 12px) 0 24px;
    overflow-y: auto;
    z-index: 90;
    transform: translateX(-102%);
    transition: transform 0.28s ease;
    visibility: hidden;
    pointer-events: none;
  }
  div[data-gh-custom-header="{{ section.id }}"][data-drawer-open='true'] #GhHdrDrawer-{{ section.id }} {
    transform: translateX(0);
    visibility: visible;
    pointer-events: auto;
  }
  #GhHdrDrawer-{{ section.id }} .gh-drawer-parent {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    border-bottom: 1px solid rgb(255 255 255 / 0.12);
    padding: 16px 24px;
  }
  #GhHdrDrawer-{{ section.id }} .gh-draw-main {
    flex: 1;
    text-decoration: none;
    text-transform: uppercase;
    font-weight: 600;
    font-size: 13px;
    color: {{ section.settings.drawer_link_color }};
  }
  #GhHdrDrawer-{{ section.id }} .gh-draw-sub {
    list-style: none;
    margin: 0;
    padding: 0 24px 12px 40px;
  }
  #GhHdrDrawer-{{ section.id }} .gh-draw-sub a {
    display: block;
    padding: 12px 0;
    color: {{ section.settings.drawer_link_color }};
    text-decoration: none;
  }
  #GhHdrDrawer-{{ section.id }} .js-accordion {
    border: 0;
    background: transparent;
    font-size: 18px;
    cursor: pointer;
    color: {{ section.settings.drawer_link_color }};
  }
  #GhHdrDrawer-{{ section.id }} .gh-draw-link {
    display: block;
    margin-top: 0;
    padding: 12px 24px;
    color: {{ section.settings.drawer_link_color }};
    text-decoration: none;
    font-size: 13px;
    line-height: 1.4;
  }
  #GhHdrDrawer-{{ section.id }} .gh-draw-link--book {
    padding: 10px 12px;
    border-radius: 2px;
    background: {{ section.settings.book_btn_bg | default: '#B8913A' }};
    color: {{ section.settings.book_btn_text | default: '#FDF8F2' }};
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 11px;
    font-weight: 500;
    display: block;
    width: calc(100% - 48px);
    margin: 8px 24px 16px;
    text-align: center;
  }
  #GhHdrDrawer-{{ section.id }} .gh-drawer-head {
    display: flex;
    justify-content: flex-end;
    margin-bottom: 0;
    padding: 20px 24px;
    border-bottom: 0.5px solid rgb(245 239 227 / 0.1);
  }
  #GhHdrDrawer-{{ section.id }} .gh-drawer-close {
    border: 0;
    background: transparent;
    color: {{ section.settings.drawer_link_color }};
    font-size: 28px;
    line-height: 1;
    cursor: pointer;
    padding: 2px 4px;
  }
  @media screen and (max-width: {{ section.settings.mobile_breakpoint }}px) {
    #GhHdrDrawer-{{ section.id }}.gh-drawer {
      width: 100vw;
      max-width: 100vw;
      padding: calc(var(--hdr-h-mobile) + 8px) 0 20px;
    }
    #GhHdrDrawer-{{ section.id }} .gh-drawer-parent {
      padding: 16px 24px;
    }
    #GhHdrDrawer-{{ section.id }} .gh-draw-link:first-of-type {
      margin-top: 8px;
      padding-top: 20px;
      border-top: 0.5px solid rgb(245 239 227 / 0.08);
    }
  }
</style>

<script>
  (function () {
    var rootWrapper = document.querySelector('[data-gh-custom-header="{{ section.id }}"]');
    if (!rootWrapper) return;
    var shell = rootWrapper.querySelector('#GhHdr-{{ section.id }}');
    if (!shell) return;
    var sectionRoot = rootWrapper.closest('.shopify-section.gh-custom-store-header');

    var scrollThreshold = parseInt(getComputedStyle(shell).getPropertyValue('--gh-scroll-threshold'), 10) || 24;

    var lastScrolledState = null;
    var scrollRaf = null;
    var lastY = window.scrollY || 0;
    var lastRevealState = null;

    function setRevealState(nextState) {
      if (!sectionRoot || lastRevealState === nextState) return;
      lastRevealState = nextState;
      sectionRoot.setAttribute('data-scroll-reveal', nextState ? 'true' : 'false');
    }

    function syncScrollState() {
      var currentY = window.scrollY || 0;
      var scrolled = currentY > scrollThreshold;
      if (scrolled === lastScrolledState) return;
      lastScrolledState = scrolled;
      rootWrapper.setAttribute('data-scrolled', scrolled ? 'true' : 'false');
      if (sectionRoot) {
        sectionRoot.setAttribute('data-scrolled', scrolled ? 'true' : 'false');
      }
    }

    function syncRevealState() {
      if (!sectionRoot) return;
      if (sectionRoot.getAttribute('data-gh-sticky') !== 'true') return;

      var currentY = window.scrollY || 0;
      var armThreshold = scrollThreshold + 24;
      var delta = currentY - lastY;

      if (currentY <= armThreshold) {
        sectionRoot.setAttribute('data-scroll-armed', 'false');
        setRevealState(false);
      } else {
        sectionRoot.setAttribute('data-scroll-armed', 'true');
        if (delta <= -8) {
          setRevealState(true);
        } else if (delta >= 4) {
          setRevealState(false);
        }
      }

      lastY = currentY;
    }

    function requestScrollSync() {
      if (scrollRaf) return;
      scrollRaf = window.requestAnimationFrame(function () {
        scrollRaf = null;
        syncScrollState();
        syncRevealState();
      });
    }

    if (sectionRoot) {
      sectionRoot.setAttribute('data-gh-section-header', '{{ section.id }}');
      sectionRoot.setAttribute('data-gh-overlay', rootWrapper.getAttribute('data-gh-overlay') === 'true' ? 'true' : 'false');
      sectionRoot.setAttribute('data-gh-sticky', rootWrapper.classList.contains('gh-ch-wrap--sticky') ? 'true' : 'false');
      sectionRoot.setAttribute('data-scroll-armed', 'false');
      sectionRoot.setAttribute('data-scroll-reveal', 'false');
    }

    if (rootWrapper.getAttribute('data-gh-overlay') === 'true') {
      syncScrollState();
    } else {
      rootWrapper.setAttribute('data-scrolled', 'true');
      if (sectionRoot) {
        sectionRoot.setAttribute('data-scrolled', 'true');
      }
    }

    syncRevealState();
    window.addEventListener('scroll', requestScrollSync, { passive: true });

    var burger = shell.querySelector('.js-ghburger');
    var drawer = document.getElementById('GhHdrDrawer-{{ section.id }}');
    var closeBtn = drawer ? drawer.querySelector('.js-ghdrawer-close') : null;

    function setDrawerState(next) {
      rootWrapper.setAttribute('data-drawer-open', next ? 'true' : 'false');
      if (drawer) drawer.setAttribute('aria-hidden', next ? 'false' : 'true');
      if (burger) burger.setAttribute('aria-expanded', next ? 'true' : 'false');
      document.documentElement.style.overflow = next ? 'hidden' : '';
    }

    if (burger && drawer) {
      burger.addEventListener('click', function () {
        var open = rootWrapper.getAttribute('data-drawer-open') === 'true';
        setDrawerState(!open);
      });
    }

    if (closeBtn) {
      closeBtn.addEventListener('click', function () {
        setDrawerState(false);
      });
    }

    if (drawer) {
      drawer.querySelectorAll('a').forEach(function (link) {
        link.addEventListener('click', function () {
          setDrawerState(false);
        });
      });
    }

    if (drawer) {
      drawer.querySelectorAll('.js-accordion').forEach(function (btn) {
        btn.addEventListener('click', function () {
          var parent = btn.closest('.gh-drawer-entry');
          var pane = parent && parent.querySelector('.gh-draw-sub');
          if (!pane) return;
          var expanded = pane.getAttribute('hidden') == null;
          pane.hidden = expanded;
          btn.setAttribute('aria-expanded', expanded ? 'false' : 'true');
        });
      });
    }
  })();
</script>

