{% schema %}
{
  "name": "God's Hill custom header",
  "tag": "section",
  "class": "gh-custom-store-header",
  "settings": [
    { "type": "paragraph", "content": "Used as the storefront header via Header group settings. Matches theme logo when configured in Theme settings." },
    { "type": "checkbox", "id": "sticky", "label": "Sticky anchored header behaviour", "default": true },
    {
      "type": "header",
      "content": "Hero overlay"
    },
    {
      "type": "checkbox",
      "id": "overlay_hero",
      "label": "Overlay header on hero banner",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "overlay_on_home",
      "label": "Homepage (hero slider)",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "overlay_on_collection",
      "label": "Collection pages (hero banner)",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "overlay_on_page_hero",
      "label": "Other pages (page hero)",
      "default": true
    },
    {
      "type": "range",
      "id": "overlay_scroll_threshold",
