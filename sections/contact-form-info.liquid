{% comment %} Contact · static form placeholder + contact details blocks {% endcomment %}
{% liquid
  assign show = section.settings.section_enabled | default: true
  assign use_embed = false
  if section.settings.form_mode == 'embed' and section.settings.custom_form_embed != blank
    assign use_embed = true
  endif
  assign show_static = false
  if section.settings.form_mode == 'static' and section.settings.enable_static_form
    assign show_static = true
  endif

  assign root_class = 'gh-cfi'
  if section.settings.custom_css_class != blank
    assign root_class = root_class | append: ' ' | append: section.settings.custom_css_class | strip
  endif
%}
{% unless show %}
  <div {{ section.shopify_attributes }} hidden></div>
{% else %}
  <section
    id="GHCFI-{{ section.id }}"
    class="{{ root_class }}"
    {{ section.shopify_attributes }}
    style="
      --gh-cfi-bg: {{ section.settings.section_background }};
      --gh-cfi-pt: {{ section.settings.padding_top }}px;
      --gh-cfi-pb: {{ section.settings.padding_bottom }}px;
      --gh-cfi-cw: {{ section.settings.container_width }}px;
      --gh-cfi-gap: {{ section.settings.column_gap }}px;
      --gh-cfi-left-bg: {{ section.settings.left_panel_background }};
      --gh-cfi-right-bg: {{ section.settings.right_panel_background }};
      --gh-cfi-pad: {{ section.settings.panel_padding }}px;
      --gh-cfi-heading: {{ section.settings.heading_color }};
      --gh-cfi-text: {{ section.settings.text_color }};
      --gh-cfi-muted: {{ section.settings.muted_text_color }};
      --gh-cfi-div: {{ section.settings.divider_color }};
      --gh-cfi-btn-bg: {{ section.settings.button_background }};
      --gh-cfi-btn-text: {{ section.settings.button_text_color }};
      --gh-cfi-btn-h-bg: {{ section.settings.button_hover_background }};
      --gh-cfi-btn-h-text: {{ section.settings.button_hover_text_color }};
      --gh-cfi-input-border: {{ section.settings.input_border_color }};
    "
  >
    <div class="gh-cfi__inner">
      <div class="gh-cfi__grid">
        <div class="gh-cfi__panel gh-cfi__panel--form">
          {% if section.settings.form_heading != blank %}
            <h2 class="gh-cfi__panel-heading">{{ section.settings.form_heading }}</h2>
            <div class="gh-cfi__panel-divider" role="presentation" aria-hidden="true"></div>
          {% endif %}

          {% if use_embed %}
            <div class="gh-cfi__embed" data-cfi-form-embed>
              {{ section.settings.custom_form_embed }}
            </div>
          {% elsif show_static %}
            <form class="gh-cfi__form" data-cfi-static-form novalidate>
              <div class="gh-cfi__field">
                <label class="gh-cfi__label" for="GHCFI-name-{{ section.id }}">Your Name (required)</label>
                <input class="gh-cfi__input" type="text" id="GHCFI-name-{{ section.id }}" name="name" required autocomplete="name">
              </div>
              <div class="gh-cfi__field">
                <label class="gh-cfi__label" for="GHCFI-email-{{ section.id }}">Your Email (required)</label>
                <input class="gh-cfi__input" type="email" id="GHCFI-email-{{ section.id }}" name="email" required autocomplete="email">
              </div>
              <div class="gh-cfi__field">
                <label class="gh-cfi__label" for="GHCFI-subject-{{ section.id }}">Subject</label>
                <input class="gh-cfi__input" type="text" id="GHCFI-subject-{{ section.id }}" name="subject">
              </div>
              <div class="gh-cfi__field">
                <label class="gh-cfi__label" for="GHCFI-message-{{ section.id }}">Your Message</label>
                <textarea class="gh-cfi__textarea" id="GHCFI-message-{{ section.id }}" name="message" rows="6"></textarea>
              </div>
              <button type="submit" class="gh-cfi__submit">{{ section.settings.submit_label | default: 'SEND MESSAGE' }}</button>
              {% if section.settings.show_placeholder_notice and section.settings.placeholder_notice != blank %}
                <p class="gh-cfi__notice" data-cfi-notice hidden>{{ section.settings.placeholder_notice }}</p>
              {% endif %}
            </form>
          {% endif %}
        </div>

        <div class="gh-cfi__panel gh-cfi__panel--info">
          {% if section.settings.info_heading != blank %}
            <h2 class="gh-cfi__panel-heading">{{ section.settings.info_heading }}</h2>
            <div class="gh-cfi__panel-divider" role="presentation" aria-hidden="true"></div>
          {% endif %}
          {% if section.blocks.size > 0 %}
            <ul class="gh-cfi__details" role="list">
              {% for block in section.blocks %}
                {% case block.type %}
                  {% when 'contact_item' %}
                    {% liquid
                      assign detail_icon = block.settings.icon | default: 'auto'
                      assign detail_text = block.settings.title | append: ' ' | append: block.settings.details | strip_html | downcase
                      if detail_icon == 'auto'
                        if detail_text contains 'phone' or detail_text contains 'enquiries' or detail_text contains 'cucina'
                          assign detail_icon = 'phone'
                        elsif detail_text contains 'vineyard' or detail_text contains 'location' or detail_text contains 'road' or detail_text contains 'barossa'
                          assign detail_icon = 'location'
                        elsif detail_text contains 'postal' or detail_text contains 'po box'
                          assign detail_icon = 'mail'
                        elsif detail_text contains 'accommodation' or detail_text contains 'villa'
                          assign detail_icon = 'home'
                        else
                          assign detail_icon = 'info'
                        endif
                      endif
                    %}
                    <li class="gh-cfi__detail" {{ block.shopify_attributes }}>
                      <span class="gh-cfi__detail-icon gh-cfi__detail-icon--{{ detail_icon }}" aria-hidden="true">
                        {% case detail_icon %}
                          {% when 'phone' %}
                            <svg viewBox="0 0 24 24" fill="none" role="presentation">
                              <path d="M6.6 3.8 8.9 3c.7-.2 1.4.1 1.7.8l1.1 2.6c.3.6.1 1.3-.4 1.7L9.9 9.2c1 2 2.7 3.7 4.8 4.8l1.1-1.4c.4-.5 1.1-.7 1.7-.4l2.6 1.1c.7.3 1 1 .8 1.7l-.8 2.3c-.2.7-.9 1.1-1.6 1.1C10.9 18.4 5.6 13.1 5.6 5.5c0-.7.4-1.4 1-1.7Z" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                          {% when 'location' %}
                            <svg viewBox="0 0 24 24" fill="none" role="presentation">
                              <path d="M12 21s7-6.1 7-12a7 7 0 1 0-14 0c0 5.9 7 12 7 12Z" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                              <circle cx="12" cy="9" r="2.4" stroke="currentColor" stroke-width="1.6"/>
                            </svg>
                          {% when 'mail' %}
                            <svg viewBox="0 0 24 24" fill="none" role="presentation">
                              <path d="M4.5 7.5h15v10h-15v-10Z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>
                              <path d="m5 8 7 5 7-5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                          {% when 'home' %}
                            <svg viewBox="0 0 24 24" fill="none" role="presentation">
                              <path d="m4 11 8-7 8 7" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                              <path d="M6.5 10.5v8h11v-8" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                              <path d="M10 18.5v-5h4v5" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>
                            </svg>
                          {% else %}
                            <svg viewBox="0 0 24 24" fill="none" role="presentation">
                              <circle cx="12" cy="12" r="8" stroke="currentColor" stroke-width="1.6"/>
                              <path d="M12 11.5v4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
                              <path d="M12 8.2h.01" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                            </svg>
                        {% endcase %}
                      </span>
                      <div class="gh-cfi__detail-copy">
                        {% if block.settings.title != blank %}
                          <h3 class="gh-cfi__detail-title">{{ block.settings.title }}</h3>
                        {% endif %}
                        {% if block.settings.details != blank %}
                          <div class="gh-cfi__detail-body rte">{{ block.settings.details }}</div>
                        {% endif %}
                      </div>
                    </li>
                {% endcase %}
              {% endfor %}
            </ul>
          {% endif %}
        </div>
      </div>
    </div>
  </section>

  <style>
    #GHCFI-{{ section.id }}.gh-cfi {
      background: var(--gh-cfi-bg);
      padding-block: var(--gh-cfi-pt) var(--gh-cfi-pb);
      color: var(--gh-cfi-text);
    }
    #GHCFI-{{ section.id }} .gh-cfi__inner {
      width: min(100%, var(--gh-cfi-cw));
      margin-inline: auto;
      padding-inline: clamp(16px, 3vw, 32px);
    }
    #GHCFI-{{ section.id }} .gh-cfi__grid {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
      gap: var(--gh-cfi-gap);
      align-items: stretch;
    }
    #GHCFI-{{ section.id }} .gh-cfi__panel {
      background: var(--gh-cfi-left-bg);
      padding: var(--gh-cfi-pad);
    }
    #GHCFI-{{ section.id }} .gh-cfi__panel--info {
      background: var(--gh-cfi-right-bg);
    }
    #GHCFI-{{ section.id }} .gh-cfi__panel-heading {
      margin: 0 0 10px;
      font-family: Georgia, 'Times New Roman', serif;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      font-size: clamp(18px, 2.2vw, 22px);
      font-weight: 500;
      color: var(--gh-cfi-heading);
    }
    #GHCFI-{{ section.id }} .gh-cfi__panel-divider {
      width: 40px;
      height: 2px;
      background: var(--gh-cfi-heading);
      margin-bottom: 24px;
      opacity: 0.85;
    }
    #GHCFI-{{ section.id }} .gh-cfi__field { margin-bottom: 16px; }
    #GHCFI-{{ section.id }} .gh-cfi__label {
      display: block;
      font-size: 13px;
      margin-bottom: 6px;
      color: var(--gh-cfi-muted);
    }
    #GHCFI-{{ section.id }} .gh-cfi__input,
    #GHCFI-{{ section.id }} .gh-cfi__textarea {
      width: 100%;
      border: 1px solid var(--gh-cfi-input-border);
      background: #fff;
      padding: 10px 12px;
      font: inherit;
      font-size: 14px;
      color: var(--gh-cfi-text);
      border-radius: 0;
    }
    #GHCFI-{{ section.id }} .gh-cfi__textarea { resize: vertical; min-height: 120px; }
    #GHCFI-{{ section.id }} .gh-cfi__submit {
      margin-top: 8px;
      border: none;
      padding: 12px 24px;
      background: var(--gh-cfi-btn-bg);
      color: var(--gh-cfi-btn-text);
      text-transform: uppercase;
      letter-spacing: 0.08em;
      font-size: 12px;
      font-weight: 700;
      cursor: pointer;
      transition: background 0.2s ease, color 0.2s ease;
    }
    #GHCFI-{{ section.id }} .gh-cfi__submit:hover {
      background: var(--gh-cfi-btn-h-bg);
      color: var(--gh-cfi-btn-h-text);
    }
    #GHCFI-{{ section.id }} .gh-cfi__notice {
      margin-top: 12px;
      font-size: 12px;
      color: var(--gh-cfi-muted);
      font-style: italic;
    }
    #GHCFI-{{ section.id }} .gh-cfi__details {
      list-style: none;
      margin: 0;
      padding: 0;
    }
    #GHCFI-{{ section.id }} .gh-cfi__detail {
      display: grid;
      grid-template-columns: 34px minmax(0, 1fr);
      gap: 14px;
      padding-block: 16px;
      border-bottom: 1px solid var(--gh-cfi-div);
    }
    #GHCFI-{{ section.id }} .gh-cfi__detail:first-child { padding-top: 0; }
    #GHCFI-{{ section.id }} .gh-cfi__detail:last-child { border-bottom: none; padding-bottom: 0; }
    #GHCFI-{{ section.id }} .gh-cfi__detail-icon {
      width: 34px;
      height: 34px;
      border: 1px solid rgb(178 155 51 / 0.35);
      border-radius: 999px;
      color: var(--gh-cfi-heading);
      display: inline-flex;
      align-items: center;
      justify-content: center;
      margin-top: -2px;
    }
    #GHCFI-{{ section.id }} .gh-cfi__detail-icon svg {
      width: 18px;
      height: 18px;
      display: block;
    }
    #GHCFI-{{ section.id }} .gh-cfi__detail-title {
      margin: 0 0 8px;
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--gh-cfi-text);
    }
    #GHCFI-{{ section.id }} .gh-cfi__detail-body {
      font-size: 14px;
      line-height: 1.6;
      color: var(--gh-cfi-muted);
    }
    #GHCFI-{{ section.id }} .gh-cfi__detail-body :is(p, ul, ol) { margin: 0; }
    #GHCFI-{{ section.id }} .gh-cfi__detail-body :is(p + p) { margin-top: 0.5em; }
    #GHCFI-{{ section.id }} .gh-cfi__embed :is(input, textarea, select, button) {
      max-width: 100%;
    }
    @media screen and (max-width: 989px) {
      #GHCFI-{{ section.id }} .gh-cfi__grid { grid-template-columns: 1fr; }
    }
  </style>

  {% if show_static %}
    <script>
      (function () {
        var root = document.getElementById('GHCFI-{{ section.id }}');
        if (!root) return;
        var form = root.querySelector('[data-cfi-static-form]');
        var notice = root.querySelector('[data-cfi-notice]');
        if (!form) return;
        form.addEventListener('submit', function (e) {
          e.preventDefault();
          if (notice) notice.hidden = false;
        });
      })();
    </script>
  {% endif %}
{% endunless %}

{% schema %}
{
  "name": "Contact form info",
  "tag": "section",
  "class": "gh-contact-form-info",
  "max_blocks": 16,
  "settings": [
    { "type": "checkbox", "id": "section_enabled", "label": "Show section", "default": true },
    { "type": "color", "id": "section_background", "label": "Section background", "default": "#F3EDE3" },
    { "type": "range", "id": "container_width", "label": "Container max width", "min": 960, "max": 1440, "step": 20, "unit": "px", "default": 1200 },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 64 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 64 },
    { "type": "range", "id": "column_gap", "label": "Column gap", "min": 16, "max": 64, "step": 4, "unit": "px", "default": 32 },
    { "type": "color", "id": "left_panel_background", "label": "Left panel background", "default": "#FFFFFF" },
    { "type": "color", "id": "right_panel_background", "label": "Right panel background", "default": "#FFFFFF" },
    { "type": "range", "id": "panel_padding", "label": "Panel padding", "min": 20, "max": 56, "step": 4, "unit": "px", "default": 36 },
    { "type": "color", "id": "heading_color", "label": "Heading colour", "default": "#B29B33" },
    { "type": "color", "id": "text_color", "label": "Text colour", "default": "#1F1A14" },
    { "type": "color", "id": "muted_text_color", "label": "Muted text colour", "default": "#6B6560" },
    { "type": "color", "id": "divider_color", "label": "Divider colour", "default": "#E0D8CC" },
    { "type": "color", "id": "input_border_color", "label": "Input border colour", "default": "#D8D2C8" },
    { "type": "header", "content": "Form" },
    {
      "type": "select",
      "id": "form_mode",
      "label": "Form mode",
      "options": [
        { "value": "static", "label": "Static form placeholder" },
        { "value": "embed", "label": "Custom form embed HTML" }
      ],
      "default": "static"
    },
    { "type": "checkbox", "id": "enable_static_form", "label": "Enable static form", "default": true },
    { "type": "html", "id": "custom_form_embed", "label": "Custom form embed HTML", "info": "Paste app embed or iframe code when using embed mode." },
    { "type": "text", "id": "form_heading", "label": "Form column heading", "default": "SEND US A MESSAGE" },
    { "type": "text", "id": "submit_label", "label": "Submit button label", "default": "SEND MESSAGE" },
    { "type": "color", "id": "button_background", "label": "Button background", "default": "#B29B33" },
    { "type": "color", "id": "button_text_color", "label": "Button text", "default": "#FFFFFF" },
    { "type": "color", "id": "button_hover_background", "label": "Button hover background", "default": "#96782A" },
    { "type": "color", "id": "button_hover_text_color", "label": "Button hover text", "default": "#FFFFFF" },
    { "type": "checkbox", "id": "show_placeholder_notice", "label": "Show placeholder notice on submit", "default": false },
    {
      "type": "text",
      "id": "placeholder_notice",
      "label": "Placeholder notice text",
      "default": "Form placeholder only — replace with your preferred Shopify form app embed."
    },
    { "type": "header", "content": "Contact details" },
    { "type": "text", "id": "info_heading", "label": "Info column heading", "default": "OTHER WAYS TO REACH US" },
    { "type": "text", "id": "custom_css_class", "label": "Custom CSS class" }
  ],
  "blocks": [
    {
      "type": "contact_item",
      "name": "Contact item",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "Contact category" },
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "auto", "label": "Auto" },
            { "value": "phone", "label": "Phone" },
            { "value": "location", "label": "Location pin" },
            { "value": "mail", "label": "Mail / postal" },
            { "value": "home", "label": "Accommodation / home" },
            { "value": "info", "label": "Info" }
          ],
          "default": "auto"
        },
        { "type": "richtext", "id": "details", "label": "Details", "default": "<p>Phone: 0000 000 000</p>" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Contact form info",
      "category": "God's Hill",
      "blocks": [
        { "type": "contact_item", "settings": { "title": "CELLAR DOOR, GENERAL ENQUIRIES", "details": "<p>Phone: 0412 107 926</p>" } },
        { "type": "contact_item", "settings": { "title": "ENNIA CUCINA", "details": "<p>Phone: 0422 588 605</p>" } },
        { "type": "contact_item", "settings": { "title": "VINEYARD LOCATION", "details": "<p>Morphett Road<br>Lyndoch, Barossa Valley SA 5351</p>" } },
        { "type": "contact_item", "settings": { "title": "POSTAL", "details": "<p>PO Box 670 Lyndoch SA 5351</p>" } },
        { "type": "contact_item", "settings": { "title": "LOOKING FOR ACCOMMODATION?", "details": "<p>Villa Scalzi</p>" } }
      ]
    }
  ]
}
{% endschema %}
