{% comment %} Awards & Achievements vertical timeline · block per year {% endcomment %}
{% liquid
  assign show = section.settings.section_enabled | default: true
  assign div_o = section.settings.row_divider_opacity | divided_by: 100.0
  assign row_divider = section.settings.row_divider_color | color_modify: 'alpha', div_o
  assign root_class = 'gh-aat'
  if section.settings.custom_css_class != blank
    assign root_class = root_class | append: ' ' | append: section.settings.custom_css_class | strip
  endif
%}
{% unless show %}
  <div {{ section.shopify_attributes }} hidden></div>
{% else %}
  <section
    id="GHAAT-{{ section.id }}"
    class="{{ root_class }}"
    {{ section.shopify_attributes }}
    style="
      --gh-aat-bg: {{ section.settings.section_background }};
      --gh-aat-pt: {{ section.settings.padding_top }}px;
      --gh-aat-pb: {{ section.settings.padding_bottom }}px;
      --gh-aat-cw: {{ section.settings.container_width }}px;
      --gh-aat-content-max: {{ section.settings.content_max_width }}px;
      --gh-aat-row-gap: {{ section.settings.row_spacing }}px;
      --gh-aat-heading: {{ section.settings.heading_color }};
      --gh-aat-heading-m: {{ section.settings.heading_size_mobile }}px;
      --gh-aat-heading-d: {{ section.settings.heading_size_desktop }}px;
      --gh-aat-sub: {{ section.settings.subheading_color }};
      --gh-aat-sub-size: {{ section.settings.subheading_size }}px;
      --gh-aat-line: {{ section.settings.timeline_line_color }};
      --gh-aat-line-w: {{ section.settings.timeline_line_width }}px;
      --gh-aat-dot: {{ section.settings.timeline_dot_color }};
      --gh-aat-dot-size: {{ section.settings.timeline_dot_size }}px;
      --gh-aat-year: {{ section.settings.year_color }};
      --gh-aat-year-m: {{ section.settings.year_size_mobile }}px;
      --gh-aat-year-d: {{ section.settings.year_size_desktop }}px;
      --gh-aat-year-fw: {{ section.settings.year_font_weight }};
      --gh-aat-text: {{ section.settings.content_text_color }};
      --gh-aat-text-m: {{ section.settings.content_size_mobile }}px;
      --gh-aat-text-d: {{ section.settings.content_size_desktop }}px;
      --gh-aat-lh: {{ section.settings.content_line_height | divided_by: 100.0 }};
      --gh-aat-align: {{ section.settings.text_alignment }};
      --gh-aat-hdr-div: {{ section.settings.heading_divider_color }};
      --gh-aat-hdr-div-w: {{ section.settings.heading_divider_width }}px;
      --gh-aat-row-div: {{ row_divider }};
      --gh-aat-link: {{ section.settings.link_color }};
      --gh-aat-link-h: {{ section.settings.link_hover_color }};
      --gh-aat-year-col: {{ section.settings.year_column_width }}px;
    "
    data-show-row-dividers="{% if section.settings.show_row_dividers %}true{% else %}false{% endif %}"
    data-show-timeline="{% if section.settings.show_timeline %}true{% else %}false{% endif %}"
  >
    <div class="gh-aat__inner">
      {% if section.settings.show_heading %}
        <header class="gh-aat__header">
          {% if section.settings.heading != blank %}
            <h2 class="gh-aat__heading">{{ section.settings.heading }}</h2>
          {% endif %}
          {% if section.settings.subheading != blank %}
            <p class="gh-aat__subheading">{{ section.settings.subheading }}</p>
          {% endif %}
          {% if section.settings.show_heading_divider %}
            <div class="gh-aat__heading-divider" role="presentation" aria-hidden="true"></div>
          {% endif %}
        </header>
      {% endif %}

      {% if section.blocks.size == 0 %}
        <p class="gh-aat__empty">Add award year blocks in the theme editor.</p>
      {% else %}
        <ol class="gh-aat__timeline" role="list">
          {% for block in section.blocks %}
            {% case block.type %}
              {% when 'award_year' %}
                <li class="gh-aat__item" {{ block.shopify_attributes }}>
                  <div class="gh-aat__marker-col">
                    <span class="gh-aat__dot" aria-hidden="true"></span>
                    {% if block.settings.year != blank %}
                      <span class="gh-aat__year">{{ block.settings.year | escape }}</span>
                    {% endif %}
                  </div>
                  <div class="gh-aat__content">
                    {% if block.settings.category != blank %}
                      <p class="gh-aat__category">{{ block.settings.category | escape }}</p>
                    {% endif %}
                    {% if block.settings.content != blank %}
                      <div class="gh-aat__body rte">{{ block.settings.content }}</div>
                    {% endif %}
                    {% if block.settings.link_label != blank and block.settings.link_url != blank %}
                      <a href="{{ block.settings.link_url }}" class="gh-aat__link">
                        {{ block.settings.link_label | escape }}
                        <span aria-hidden="true">&rsaquo;</span>
                      </a>
                    {% endif %}
                  </div>
                </li>
            {% endcase %}
          {% endfor %}
        </ol>
      {% endif %}
    </div>
  </section>

  <style>
    #GHAAT-{{ section.id }}.gh-aat {
      background: var(--gh-aat-bg);
      padding-block: var(--gh-aat-pt) var(--gh-aat-pb);
      color: var(--gh-aat-text);
    }
    #GHAAT-{{ section.id }} .gh-aat__inner {
      width: min(100%, var(--gh-aat-cw));
      margin-inline: auto;
      padding-inline: clamp(16px, 3vw, 32px);
    }
    #GHAAT-{{ section.id }} .gh-aat__header {
      text-align: center;
      max-width: var(--gh-aat-content-max);
      margin: 0 auto clamp(32px, 5vw, 56px);
    }
    #GHAAT-{{ section.id }} .gh-aat__heading {
      margin: 0 0 10px;
      font-family: Georgia, 'Times New Roman', serif;
      font-size: clamp(var(--gh-aat-heading-m), 3.5vw, var(--gh-aat-heading-d));
      font-weight: 500;
      color: var(--gh-aat-heading);
      line-height: 1.1;
    }
    #GHAAT-{{ section.id }} .gh-aat__subheading {
      margin: 0 0 16px;
      font-family: Georgia, 'Times New Roman', serif;
      font-size: var(--gh-aat-sub-size);
      color: var(--gh-aat-sub);
      line-height: 1.4;
    }
    #GHAAT-{{ section.id }} .gh-aat__heading-divider {
      width: var(--gh-aat-hdr-div-w);
      height: 2px;
      background: var(--gh-aat-hdr-div);
      margin-inline: auto;
      border-radius: 1px;
    }
    #GHAAT-{{ section.id }} .gh-aat__empty {
      text-align: center;
      opacity: 0.7;
      margin: 0;
    }
    #GHAAT-{{ section.id }} .gh-aat__timeline {
      list-style: none;
      margin: 0 auto;
      padding: 0;
      max-width: var(--gh-aat-content-max);
      position: relative;
    }
    #GHAAT-{{ section.id }}[data-show-timeline='true'] .gh-aat__timeline::before {
      content: '';
      position: absolute;
      left: calc(var(--gh-aat-dot-size) / 2 - var(--gh-aat-line-w) / 2);
      top: 0.75rem;
      bottom: 0.75rem;
      width: var(--gh-aat-line-w);
      background: var(--gh-aat-line);
    }
    #GHAAT-{{ section.id }} .gh-aat__item {
      display: grid;
      grid-template-columns: var(--gh-aat-year-col) minmax(0, 1fr);
      gap: clamp(16px, 3vw, 32px);
      align-items: start;
      padding-block: var(--gh-aat-row-gap);
      position: relative;
    }
    #GHAAT-{{ section.id }}[data-show-row-dividers='true'] .gh-aat__item + .gh-aat__item {
      border-top: 1px solid var(--gh-aat-row-div);
    }
    #GHAAT-{{ section.id }} .gh-aat__marker-col {
      display: flex;
      align-items: flex-start;
      gap: clamp(12px, 2vw, 20px);
      position: relative;
      z-index: 1;
    }
    #GHAAT-{{ section.id }} .gh-aat__dot {
      flex: 0 0 var(--gh-aat-dot-size);
      width: var(--gh-aat-dot-size);
      height: var(--gh-aat-dot-size);
      border-radius: 50%;
      background: var(--gh-aat-dot);
      margin-top: 0.35em;
      box-shadow: 0 0 0 3px var(--gh-aat-bg);
    }
    #GHAAT-{{ section.id }} .gh-aat__year {
      font-family: Georgia, 'Times New Roman', serif;
      font-size: clamp(var(--gh-aat-year-m), 2.5vw, var(--gh-aat-year-d));
      font-weight: var(--gh-aat-year-fw);
      color: var(--gh-aat-year);
      line-height: 1.1;
      min-width: 3.5ch;
    }
    #GHAAT-{{ section.id }} .gh-aat__content {
      text-align: var(--gh-aat-align);
      min-width: 0;
    }
    #GHAAT-{{ section.id }} .gh-aat__category {
      margin: 0 0 8px;
      font-family: Georgia, 'Times New Roman', serif;
      font-size: 0.95em;
      color: var(--gh-aat-year);
      letter-spacing: 0.04em;
    }
    #GHAAT-{{ section.id }} .gh-aat__body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
      font-size: clamp(var(--gh-aat-text-m), 1.6vw, var(--gh-aat-text-d));
      line-height: var(--gh-aat-lh);
      color: var(--gh-aat-text);
    }
    #GHAAT-{{ section.id }} .gh-aat__body :is(p, ul, ol) {
      margin: 0;
    }
    #GHAAT-{{ section.id }} .gh-aat__body :is(p + p, p + ul, p + ol, ul + p, ol + p) {
      margin-top: 0.65em;
    }
    #GHAAT-{{ section.id }} .gh-aat__link {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      margin-top: 12px;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      font-size: 11px;
      font-weight: 700;
      color: var(--gh-aat-link);
      text-decoration: none;
      transition: color 0.2s ease;
    }
    #GHAAT-{{ section.id }} .gh-aat__link:hover {
      color: var(--gh-aat-link-h);
    }
    @media screen and (max-width: 749px) {
      #GHAAT-{{ section.id }} .gh-aat__item {
        grid-template-columns: 1fr;
        gap: 12px;
      }
      #GHAAT-{{ section.id }}[data-show-timeline='true'] .gh-aat__timeline::before {
        left: calc(var(--gh-aat-dot-size) / 2 - var(--gh-aat-line-w) / 2);
      }
      #GHAAT-{{ section.id }} .gh-aat__marker-col {
        padding-left: 0;
      }
      #GHAAT-{{ section.id }} .gh-aat__content {
        padding-left: calc(var(--gh-aat-dot-size) + 12px);
      }
    }
  </style>
{% endunless %}

{% schema %}
{
