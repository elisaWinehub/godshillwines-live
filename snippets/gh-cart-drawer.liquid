{%- doc -%}
  Horizon cart drawer for God's Hill custom header (and other layouts without header-actions).
  @param {string} section_id - Shopify section id for cart-items-component / cart-summary
  @param {boolean} [include_trigger] - Render hidden trigger button (Horizon header-actions uses its own)
{%- enddoc -%}

{% liquid
  assign drawer_section_id = section_id
  assign show_trigger = include_trigger | default: false
%}

{% if settings.cart_type == 'drawer' and template.name != 'cart' %}
  <script
    src="{{ 'cart-drawer.js' | asset_url }}"
    type="module"
    fetchpriority="low"
  ></script>

  {% capture empty_cart_drawer_content %}
    <div class="cart-drawer__header">
      <button
        ref="closeButton"
        on:click="cart-drawer-component/close"
        class="button close-button cart-drawer__close-button button-unstyled"
        aria-label="{{ 'actions.close_dialog' | t }}"
      >
        <span class="svg-wrapper">
          {{- 'icon-close.svg' | inline_asset_content -}}
        </span>
      </button>
    </div>

    <div
      class="cart-drawer__content"
      aria-label="{{ 'accessibility.cart' | t }}"
    >
      <h2
        class="cart-drawer__heading h4 cart-drawer__heading--empty"
        id="cart-drawer-heading-empty"
      >
        {{ 'content.your_cart_is_empty' | t }}
      </h2>

      <div class="cart-drawer__items">
        {% render 'cart-products', force_empty: true %}
      </div>
    </div>
  {% endcapture %}

  <cart-drawer-component
    class="cart-drawer gh-cart-drawer"
    data-gh-cart-drawer
    {% if settings.auto_open_cart_drawer %}
      auto-open
    {% endif %}
  >
    <template id="empty-cart-template">
      {{ empty_cart_drawer_content }}
    </template>

    {% if show_trigger %}
      <button
        class="header-actions__action button-unstyled"
        on:click="/open"
        aria-haspopup="dialog"
        aria-label="{{ 'accessibility.cart' | t }}"
        data-testid="cart-drawer-trigger"
        hidden
      ></button>
    {% endif %}

    <dialog
      ref="dialog"
      class="cart-drawer__dialog dialog-modal dialog-drawer color-{{ settings.drawer_color_scheme }}{% if cart.empty? %} cart-drawer--empty{% endif %}"
      data-testid="cart-drawer-dialog"
      aria-labelledby="{% if cart.empty? %}cart-drawer-heading-empty{% else %}cart-drawer-heading{% endif %}"
      scroll-lock
      cart-summary-sticky="true"
    >
      <span
        ref="liveRegion"
        class="visually-hidden"
        role="status"
      ></span>
      <div
        class="cart-drawer__inner"
        data-hydration-key="cart-drawer-inner"
      >
        {% capture cart_items_children %}
          {%- if cart.empty? -%}
            {{ empty_cart_drawer_content }}
          {%- else -%}
            <div
              class="cart-drawer__header"
              id="cart-drawer-header"
            >
              <h2
                class="cart-drawer__heading h4"
                id="cart-drawer-heading"
              >
                {{ 'content.cart_title' | t }}
                {% render 'cart-bubble' %}
              </h2>

              <button
                ref="closeButton"
                on:click="cart-drawer-component/close"
                class="button close-button cart-drawer__close-button button-unstyled"
                aria-label="{{ 'actions.close_dialog' | t }}"
              >
                <span class="svg-wrapper">
                  {{- 'icon-close.svg' | inline_asset_content -}}
                </span>
              </button>
            </div>

            <scroll-hint
              class="cart-drawer__content"
              aria-label="{{ 'accessibility.cart' | t }}"
              style="--header-height: 60px;"
            >
              <scroll-hint
                class="cart-drawer__items"
              >
                {% render 'cart-products' %}
              </scroll-hint>

              <div
                class="cart-drawer__summary"
              >
                {% render 'cart-summary', section_id: drawer_section_id %}
              </div>
            </scroll-hint>
          {%- endif -%}
        {% endcapture %}
        {% render 'cart-items-component', children: cart_items_children, is_drawer: true, section_id: drawer_section_id %}
      </div>
    </dialog>
  </cart-drawer-component>

  <style>
    .gh-cart-drawer.cart-drawer {
      --cart-drawer-padding: var(--padding-xl) var(--padding-xl);
      --cart-drawer-padding-desktop: var(--padding-xl) var(--padding-2xl);
    }
    @media screen and (min-width: 750px) {
      .gh-cart-drawer.cart-drawer {
        margin-inline-end: calc(var(--gap-xs) * -1);
      }
    }
    .gh-cart-drawer .cart-drawer__dialog {
      position: fixed;
      overflow: hidden;
      border-radius: 0;
      width: 100%;
      height: 100%;
      margin: 0 0 0 auto;
      padding: 0;
      border-left: var(--style-border-drawer);
      box-shadow: var(--shadow-drawer);
      background-color: var(--color-background);
    }
    @media screen and (min-width: 750px) {
      .gh-cart-drawer .cart-drawer__dialog {
        width: var(--sidebar-width);
        max-width: 95vw;
      }
    }
    .gh-cart-drawer .cart-drawer__dialog:modal {
      max-height: 100dvh;
      overflow-y: hidden;
    }
    .gh-cart-drawer .cart-drawer__inner {
      height: 100%;
      overflow: hidden;
    }
    .gh-cart-drawer .cart-drawer__content {
      height: calc(100% - var(--header-height));
      display: flex;
      flex-direction: column;
      padding: 0;
      background-color: var(--color-background);
      flex-grow: 1;
      overflow-y: auto;
    }
    .gh-cart-drawer .cart-drawer__heading {
      display: flex;
      align-items: center;
      gap: var(--gap-xs);
      margin-bottom: 0;
    }
    .gh-cart-drawer .cart-drawer__summary {
      --cart-drawer-summary-padding: var(--padding-lg);
      position: sticky;
      bottom: 0;
      z-index: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: var(--gap-xl);
      padding: var(--cart-drawer-summary-padding);
      margin-top: auto;
      background-color: var(--color-background);
      mask-image: linear-gradient(to bottom, transparent, black var(--cart-drawer-summary-padding));
    }
    .gh-cart-drawer .cart-drawer__items {
      display: flex;
      flex-direction: column;
      padding-inline: var(--cart-drawer-padding);
      overflow-y: auto;
    }
    @media screen and (min-width: 750px) {
      .gh-cart-drawer .cart-drawer__items {
        padding-inline: var(--cart-drawer-padding-desktop);
      }
    }
    .gh-cart-drawer .cart-drawer__header {
      background-color: var(--color-background);
      display: flex;
      align-items: center;
      justify-content: space-between;
      width: 100%;
      padding: var(--cart-drawer-padding);
      position: sticky;
      top: 0;
      z-index: 1;
    }
    @media screen and (min-width: 750px) {
      .gh-cart-drawer .cart-drawer__header {
        padding-inline: var(--cart-drawer-padding-desktop);
      }
    }
  </style>

  <script>
    (function () {
      function openGhCartDrawer() {
        var drawer = document.querySelector('cart-drawer-component[data-gh-cart-drawer]');
        if (drawer && typeof drawer.open === 'function') {
          drawer.open();
        }
      }

      document.addEventListener('click', function (event) {
        var trigger = event.target.closest('[data-gh-open-cart-drawer]');
        if (!trigger) return;
        event.preventDefault();
        openGhCartDrawer();
      });

      document.addEventListener('cart:update', function (event) {
        if (event.detail?.data?.didError) return;
        var drawer = document.querySelector('cart-drawer-component[data-gh-cart-drawer]');
        if (!drawer) return;
        if (drawer.hasAttribute('auto-open')) return;
        openGhCartDrawer();
      });
    })();
  </script>
{% endif %}
