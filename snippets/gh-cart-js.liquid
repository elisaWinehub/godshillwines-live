<script>
  (function () {
    if (window.__ghCartJsLoaded) return;
    window.__ghCartJsLoaded = true;

    function openGhCartDrawer() {
      var drawer = document.querySelector('cart-drawer-component[data-gh-cart-drawer]') || document.querySelector('cart-drawer-component');
      if (drawer && typeof drawer.open === 'function') {
        drawer.open();
        return;
      }
      var trigger = document.querySelector('[data-gh-open-cart-drawer], [data-testid="cart-drawer-trigger"]');
      if (trigger && typeof trigger.click === 'function') {
        trigger.click();
        return;
      }
      if (window.customElements && typeof window.customElements.whenDefined === 'function') {
        window.customElements.whenDefined('cart-drawer-component').then(function () {
          var deferredDrawer = document.querySelector('cart-drawer-component[data-gh-cart-drawer]') || document.querySelector('cart-drawer-component');
          if (deferredDrawer && typeof deferredDrawer.open === 'function') {
            deferredDrawer.open();
          }
        });
      }
      document.dispatchEvent(new CustomEvent('cart:open'));
      document.dispatchEvent(new CustomEvent('cart:refresh'));
    }

    function updateCartCount() {
      return fetch('/cart.js', { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
        .then(function (response) { return response.json(); })
        .then(function (cart) {
          document.querySelectorAll('[data-cart-count], .cart-count, .js-cart-count').forEach(function (el) {
            el.textContent = cart.item_count;
          });
          return cart;
        })
        .catch(function () { return null; });
    }

    function updateButtonState(button, isLoading) {
      if (!button) return;
      if (!button.dataset.originalHtml) {
        button.dataset.originalHtml = button.innerHTML;
      }
      if (isLoading) {
        button.innerHTML = 'Adding...';
        button.disabled = true;
        return;
      }
      button.innerHTML = button.dataset.originalHtml || 'Add to cart';
      if (button.dataset.originalDisabled == 'true') {
        button.disabled = true;
      } else {
        button.disabled = false;
      }
    }

    document.addEventListener('submit', function (event) {
      var form = event.target;
      if (!(form instanceof HTMLFormElement)) return;

      var addTrigger = form.querySelector('[name="add"], [data-cart-trigger], [data-mcp-atc-btn]');
      var idInput = form.querySelector('input[name="id"]');
      if (!addTrigger || !idInput) return;

      var submitBtn = form.querySelector('[data-cart-trigger], .gh-add-to-cart-btn, [name="add"]');
      if (!submitBtn) return;
      if (submitBtn.disabled) return;

      var variantId = (idInput.value || '').trim();
      if (!variantId) return;

      event.preventDefault();

      var formData = new FormData(form);

      var qty = parseInt(formData.get('quantity'), 10);
      if (!qty || qty < 1) qty = 1;

      submitBtn.dataset.originalDisabled = submitBtn.disabled ? 'true' : 'false';
      updateButtonState(submitBtn, true);

      fetch('/cart/add.js', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'X-Requested-With': 'XMLHttpRequest'
        },
        body: JSON.stringify({ id: variantId, quantity: qty })
      })
        .then(function (response) {
          if (!response.ok) throw new Error('Add to cart failed');
          return response.json();
        })
        .then(function () {
          return updateCartCount();
        })
        .then(function (cart) {
          document.dispatchEvent(new CustomEvent('cart:update', {
            bubbles: true,
            detail: {
              resource: cart || {},
              data: {
                itemCount: cart && typeof cart.item_count === 'number' ? cart.item_count : undefined
              }
            }
          }));
          updateButtonState(submitBtn, false);
          openGhCartDrawer();
        })
        .catch(function () {
          updateButtonState(submitBtn, false);
        });
    });

    document.addEventListener('click', function (event) {
      var minusBtn = event.target.closest('.gh-qty-minus, .gh-qty-btn.gh-qty-minus');
      if (minusBtn) {
        var minusStepper = minusBtn.closest('.gh-qty-stepper');
        var minusInput = minusStepper ? minusStepper.querySelector('.gh-qty-input, input[name="quantity"]') : null;
        if (minusInput && !minusInput.disabled) {
          var minusValue = parseInt(minusInput.value || '1', 10);
          if (!minusValue || minusValue < 1) minusValue = 1;
          minusInput.value = Math.max(1, minusValue - 1);
        }
      }

      var plusBtn = event.target.closest('.gh-qty-plus, .gh-qty-btn.gh-qty-plus');
      if (plusBtn) {
        var plusStepper = plusBtn.closest('.gh-qty-stepper');
        var plusInput = plusStepper ? plusStepper.querySelector('.gh-qty-input, input[name="quantity"]') : null;
        if (plusInput && !plusInput.disabled) {
          var plusValue = parseInt(plusInput.value || '1', 10);
          if (!plusValue || plusValue < 1) plusValue = 1;
          plusInput.value = plusValue + 1;
        }
      }

      var mcpMinusBtn = event.target.closest('[data-mcp-qty-minus], .mcp-qty-btn--minus');
      if (mcpMinusBtn) {
        var mcpMinusStepper = mcpMinusBtn.closest('.mcp-qty-stepper');
        var mcpMinusInput = mcpMinusStepper ? mcpMinusStepper.querySelector('.mcp-qty, input[name="quantity"]') : null;
        if (mcpMinusInput && !mcpMinusInput.disabled) {
          var mcpMinusValue = parseInt(mcpMinusInput.value || '1', 10);
          if (!mcpMinusValue || mcpMinusValue < 1) mcpMinusValue = 1;
          mcpMinusInput.value = Math.max(1, mcpMinusValue - 1);
          mcpMinusInput.dispatchEvent(new Event('change', { bubbles: true }));
        }
      }

      var mcpPlusBtn = event.target.closest('[data-mcp-qty-plus], .mcp-qty-btn--plus');
      if (mcpPlusBtn) {
        var mcpPlusStepper = mcpPlusBtn.closest('.mcp-qty-stepper');
        var mcpPlusInput = mcpPlusStepper ? mcpPlusStepper.querySelector('.mcp-qty, input[name="quantity"]') : null;
        if (mcpPlusInput && !mcpPlusInput.disabled) {
          var mcpPlusValue = parseInt(mcpPlusInput.value || '1', 10);
          if (!mcpPlusValue || mcpPlusValue < 1) mcpPlusValue = 1;
          mcpPlusInput.value = mcpPlusValue + 1;
          mcpPlusInput.dispatchEvent(new Event('change', { bubbles: true }));
        }
      }
    });
  })();
</script>
